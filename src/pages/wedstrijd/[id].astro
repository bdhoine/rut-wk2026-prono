---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import ScoreBoxes from '@/components/ScoreBoxes.astro';
import PointsBadge from '@/components/PointsBadge.astro';
import { matches, getMatch, sideLabel, predictionsForMatch } from '@/lib/data';
import { ROUND_LABELS } from '@/lib/types';
import { explainScore, formatKickoff } from '@/lib/format';

export function getStaticPaths() {
  return matches.map((m) => ({ params: { id: m.id } }));
}

const { id } = Astro.params;
const match = getMatch(id!);
if (!match) return Astro.redirect('/404');

const home = sideLabel(match, 'home');
const away = sideLabel(match, 'away');
const rows = predictionsForMatch(match.id);
const finished = match.status === 'finished' && match.result;

// Per-match stats across all participants (finished matches only).
const scored = (finished ? rows.map((r) => r.score) : []).filter((s): s is NonNullable<typeof s> => s !== null);
const n = scored.length;
const avgPoints = n ? scored.reduce((sum, s) => sum + s.points, 0) / n : 0;
const exactCount = scored.filter((s) => s.exact).length;
const resultCount = scored.filter((s) => s.outcomeCorrect && !s.exact).length;
const wrongCount = scored.filter((s) => s.points === 0).length;
const stats = [
  { label: 'Gem. punten', value: avgPoints.toFixed(1) },
  { label: 'Exacte uitslag', value: exactCount },
  { label: 'Juiste 1X2', value: resultCount },
  { label: 'Fout', value: wrongCount },
];
---
<Layout title={`${home.label} – ${away.label}`}>
  <a href="/kalender" class="mb-4 inline-block text-sm text-muted-foreground hover:text-foreground">← Kalender</a>

  <header class="mb-6 rounded-2xl border bg-card p-5 shadow-sm">
    <div class="mb-4 flex items-center justify-between text-xs text-muted-foreground">
      <span>{ROUND_LABELS[match.round]}{match.matchday ? ` · Speeldag ${match.matchday}` : ''}</span>
      <span>{formatKickoff(match.kickoff)}</span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <div class="flex flex-1 flex-col items-center gap-2 text-center">
        <Flag iso={home.team?.iso} name={home.label} class="text-4xl" />
        <span class="text-sm font-medium">{home.label}</span>
      </div>
      <div class="shrink-0">
        {finished
          ? <ScoreBoxes home={match.result!.home} away={match.result!.away} size="lg" />
          : <span class="text-xl font-bold text-muted-foreground">vs</span>}
      </div>
      <div class="flex flex-1 flex-col items-center gap-2 text-center">
        <Flag iso={away.team?.iso} name={away.label} class="text-4xl" />
        <span class="text-sm font-medium">{away.label}</span>
      </div>
    </div>
    <p class="mt-4 text-center text-xs text-muted-foreground">{match.venue}</p>
  </header>

  {finished && (
    <div class="mb-6 grid grid-cols-2 gap-2 sm:grid-cols-4">
      {stats.map((s) => (
        <div class="rounded-xl border bg-card p-3 text-center shadow-sm">
          <div class="text-2xl font-bold tabular-nums">{s.value}</div>
          <div class="mt-0.5 text-xs text-muted-foreground">{s.label}</div>
        </div>
      ))}
    </div>
  )}

  <section>
    <h2 class="mb-2 text-lg font-semibold">Pronostieken {finished ? '(gesorteerd op punten)' : ''}</h2>
    <div class="overflow-hidden rounded-xl border bg-card">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-muted-foreground">
            <th class="px-3 py-2 text-left font-medium">Deelnemer</th>
            <th class="px-2 py-2 text-center font-medium">Prono</th>
            {finished && <th class="px-3 py-2 text-right font-medium">Punten</th>}
          </tr>
        </thead>
        <tbody>
          {rows.map(({ participant, prediction, score }) => (
            <tr class="border-b last:border-0">
              <td class="px-3 py-2.5">
                <a href={`/deelnemer/${participant.id}`} class="font-medium hover:underline">{participant.name}</a>
              </td>
              <td class="px-2 py-2.5">
                <div class="flex justify-center">
                  <ScoreBoxes home={prediction?.home} away={prediction?.away} size="sm" />
                </div>
              </td>
              {finished && (
                <td class="px-3 py-2.5">
                  <div class="flex justify-end">
                    {score ? <PointsBadge points={score.points} exact={score.exact} explanation={explainScore(score)} /> : <span class="text-muted-foreground">0</span>}
                  </div>
                </td>
              )}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>
