---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import ScoreBoxes from '@/components/ScoreBoxes.astro';
import PointsBadge from '@/components/PointsBadge.astro';
import {
  participants, getParticipant, getTeam, sideLabel, positionOf, predictionsForParticipant, outcomes, settings,
} from '@/lib/data';
import { bonusBreakdown } from '@/lib/scoring';
import { ROUND_LABELS, ROUND_ORDER, type BonusPicks } from '@/lib/types';
import { explainScore } from '@/lib/format';

export function getStaticPaths() {
  return participants.map((p) => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const participant = getParticipant(id!);
if (!participant) return Astro.redirect('/404');

const rank = positionOf(participant.id);
const rows = predictionsForParticipant(participant.id);
const bonus = bonusBreakdown(participant.bonus, outcomes, settings);

const BONUS_LABELS: Record<keyof BonusPicks, string> = {
  topScorer: 'Topschutter',
  winnerTeamId: 'Eindwinnaar',
  mostConcededTeamId: 'Meeste tegendoelpunten',
  mostScoredTeamId: 'Meeste doelpunten',
};

const byRound = ROUND_ORDER
  .map((round) => ({
    round,
    items: rows.filter((r) => r.match.round === round).sort((a, b) => a.match.kickoff.localeCompare(b.match.kickoff)),
  }))
  .filter((g) => g.items.length > 0);

const pick = (key: keyof BonusPicks) => participant.bonus[key];

// Form: last 5 finished matches (chronological) as coloured dots.
const formScores = rows
  .filter((r) => r.score)
  .sort((a, b) => a.match.kickoff.localeCompare(b.match.kickoff))
  .slice(-5)
  .map((r) => ({
    cls: r.score!.exact ? 'bg-emerald-500' : r.score!.points > 0 ? 'bg-amber-400' : 'bg-red-500',
  }));
const medal = rank?.position === 1 ? 'bg-amber-300 text-black' : rank?.position === 2 ? 'bg-zinc-200 text-black' : rank?.position === 3 ? 'bg-[oklch(0.62_0.12_55)] text-white' : 'bg-white/20 text-white';
---
<Layout title={`${participant.name} — Rut Prono WK 2026`}>
  <a href="/" class="mb-4 inline-block text-sm text-muted-foreground hover:text-foreground">← Klassement</a>

  <header class="mb-6 overflow-hidden rounded-2xl border bg-gradient-to-br from-primary to-primary/80 text-primary-foreground shadow-sm">
    <div class="flex items-center justify-between gap-4 p-5">
      <div class="flex items-center gap-3">
        <div class:list={['grid size-12 shrink-0 place-items-center rounded-full text-lg font-bold tabular-nums', medal]}>{rank?.position ?? '—'}</div>
        <div>
          <div class="text-xs font-medium uppercase tracking-wide text-primary-foreground/70">Deelnemer</div>
          <h1 class="text-2xl font-bold leading-tight">{participant.name}</h1>
        </div>
      </div>
      <div class="text-right">
        <div class="text-4xl font-bold leading-none tabular-nums">{rank?.total ?? 0}</div>
        <div class="mt-1 text-xs text-primary-foreground/80">punten</div>
      </div>
    </div>
    <div class="flex flex-wrap items-center justify-between gap-x-3 gap-y-2 border-t border-white/15 px-5 py-2.5 text-xs text-primary-foreground/90">
      <div class="flex items-center gap-3">
        <span><strong class="font-semibold tabular-nums">{rank?.matchPoints ?? 0}</strong> uit wedstrijden</span>
        <span class="text-primary-foreground/40">•</span>
        <span><strong class="font-semibold tabular-nums">{rank?.bonusPoints ?? 0}</strong> bonus</span>
      </div>
      {formScores.length > 0 && (
        <div class="flex items-center gap-1.5 rounded-full bg-white/95 px-2.5 py-1.5 shadow-sm">
          {formScores.map((f) => (
            <span class:list={['size-2.5 rounded-full', f.cls]}></span>
          ))}
        </div>
      )}
    </div>
  </header>

  <section class="mb-8">
    <h2 class="mb-2 text-lg font-semibold">Bonusvoorspellingen</h2>
    <div class="grid grid-cols-2 gap-2">
      {bonus.items.map((item) => {
        const value = pick(item.key);
        const team = item.key === 'topScorer' ? undefined : getTeam(value);
        return (
          <div class:list={[
            'rounded-xl border bg-card p-3',
            item.correct === true && 'border-emerald-500/60 bg-emerald-50 dark:bg-emerald-950/30',
            item.correct === false && 'opacity-70',
          ]}>
            <div class="text-xs text-muted-foreground">{BONUS_LABELS[item.key]}</div>
            <div class="mt-1 flex items-center gap-2 font-medium">
              {team && <Flag iso={team.iso} name={team.name} class="text-base" />}
              <span class="truncate">{team ? team.name : (value || '—')}</span>
            </div>
            <div class="mt-1 text-xs">
              {item.correct === null ? <span class="text-muted-foreground">Nog niet bekend</span>
                : item.correct ? <span class="font-semibold text-emerald-600">+{item.points}</span>
                : <span class="text-muted-foreground">0 punten</span>}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-lg font-semibold">Pronostieken</h2>
    <div class="space-y-6">
      {byRound.map((g) => (
        <div>
          <h3 class="mb-2 text-sm font-semibold text-muted-foreground">{ROUND_LABELS[g.round]}</h3>
          <div class="space-y-2">
            {g.items.map(({ match, prediction, score }) => {
              const home = sideLabel(match, 'home');
              const away = sideLabel(match, 'away');
              return (
                <div class="relative flex items-center gap-3 rounded-xl border bg-card px-4 py-3 shadow-sm transition-all hover:border-primary/40 hover:shadow-md">
                  <a href={`/wedstrijd/${match.id}`} class="absolute inset-0 rounded-xl" aria-label={`${home.label} tegen ${away.label}`}></a>
                  <div class="min-w-0 flex-1">
                    <div class="mb-1 text-center text-[10px] font-medium uppercase tracking-wide text-muted-foreground">prono</div>
                    <div class="flex items-center justify-center gap-2.5">
                      <span class="min-w-0 flex-1 truncate text-right text-sm font-medium">{home.label}</span>
                      <Flag iso={home.team?.iso} name={home.label} class="shrink-0 text-base" />
                      <ScoreBoxes home={prediction?.home} away={prediction?.away} size="md" />
                      <Flag iso={away.team?.iso} name={away.label} class="shrink-0 text-base" />
                      <span class="min-w-0 flex-1 truncate text-sm font-medium">{away.label}</span>
                    </div>
                    <div class="mt-1.5 flex h-5 items-center justify-center">
                      {match.result
                        ? <ScoreBoxes home={match.result.home} away={match.result.away} size="sm" muted />
                        : <span class="text-xs text-muted-foreground">–</span>}
                    </div>
                  </div>
                  <div class="relative z-10 shrink-0">
                    {score ? <PointsBadge points={score.points} exact={score.exact} explanation={explainScore(score)} /> : <span class="text-xs text-muted-foreground">—</span>}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
