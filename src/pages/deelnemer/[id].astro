---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import LiveScores from '@/components/LiveScores.astro';
import PredictionDayList from '@/components/PredictionDayList.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import RankChart from '@/components/RankChart.astro';
import {
  participants, getParticipant, getTeam, positionOf, predictionsForParticipant, outcomes, settings,
  eliminatedTeamIds, currentBonusLeaders, bonusPickAlive, ranking, matches, rankingTimeline, mathematicalOutlook,
} from '@/lib/data';
import { bonusBreakdown } from '@/lib/scoring';
import { byKickoff, dayKey } from '@/lib/format';
import { PRIZES } from '@/lib/prizes';
import { ROUND_LABELS, ROUND_ORDER, type BonusPicks, type RoundId } from '@/lib/types';

export function getStaticPaths() {
  return participants.map((p) => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const participant = getParticipant(id!);
if (!participant) return Astro.redirect('/404');

const rank = positionOf(participant.id);
const rows = predictionsForParticipant(participant.id);
const bonus = bonusBreakdown(participant.bonus, outcomes, settings);

// Position-over-time (one ranking snapshot per calendar day with results),
// capped at the 10 most recent days so the chart stays readable.
const rankPoints = rankingTimeline()
  .map((s) => ({ day: s.day, position: s.posById.get(participant.id) }))
  .filter((p): p is { day: string; position: number } => p.position != null)
  .slice(-10);

// Speeldag / knockout-round boundaries for the chart: the last calendar day on
// which each matchday/round had a finished match (a dashed divider shows e.g.
// where Speeldag 1 ended). Only those within the visible window draw a line.
const finishedForMarkers = matches.filter((m) => m.status === 'finished' && m.result);
const lastDayWith = (pred: (m: typeof matches[number]) => boolean): string | null => {
  const days = finishedForMarkers.filter(pred).map((m) => dayKey(m.kickoff)).sort();
  return days.at(-1) ?? null;
};
const KO_MARKERS: [RoundId, string][] = [['r32', '1/16'], ['r16', '1/8'], ['qf', 'KF'], ['sf', 'HF'], ['third', '3e'], ['final', 'F']];
const rankMarkers = [
  ...([1, 2, 3] as const).map((md) => ({ day: lastDayWith((m) => m.round === 'group' && m.matchday === md), label: `S${md}` })),
  ...KO_MARKERS.map(([round, label]) => ({ day: lastDayWith((m) => m.round === round), label })),
].filter((mk): mk is { day: string; label: string } => mk.day != null);

// Mathematical outlook: can this participant still finish in the money / on the
// podium / first? Simple worst-case-for-others upper bound (see data.ts). Only
// shown from the quarter-finals onward (i.e. once the round of 16 is complete);
// earlier the bound is so loose that everyone is trivially still "Ja".
const r16Matches = matches.filter((m) => m.round === 'r16');
const qfReached =
  (r16Matches.length > 0 && r16Matches.every((m) => m.status === 'finished')) ||
  matches.some((m) => ['qf', 'sf', 'third', 'final'].includes(m.round) && m.status === 'finished');
const outlook = mathematicalOutlook(participant.id);
const outlookCards = outlook
  ? [
      { title: 'Geld winnen', sub: 'top 5', can: outlook.canMoney },
      { title: 'Op het podium', sub: 'top 3', can: outlook.canPodium },
      { title: 'Winnen', sub: '1e plaats', can: outlook.canWin },
    ]
  : [];

const BONUS_LABELS: Record<keyof BonusPicks, string> = {
  topScorer: 'Topschutter',
  winnerTeamId: 'Eindwinnaar',
  mostConcededTeamId: 'Meeste tegendoelpunten',
  mostScoredTeamId: 'Meeste doelpunten',
};

const byRound = ROUND_ORDER
  .map((round) => ({
    round,
    items: rows.filter((r) => r.match.round === round).sort((a, b) => byKickoff(a.match, b.match)),
  }))
  .filter((g) => g.items.length > 0);

// Group stage split per speeldag as collapsible sections (72 matches is too
// long as one flat list). Exactly one section is open at a time: the one that
// is currently in progress (the first that isn't fully played). Fully-played
// sections (e.g. a completed Speeldag 1) start collapsed; fully-future ones
// also start collapsed. If the whole tournament is finished, the last section
// stays open so there is always at least one expanded.
const groupItems = byRound.find((g) => g.round === 'group')?.items ?? [];
const koGroups = byRound.filter((g) => g.round !== 'group');
const matchdays = ([1, 2, 3] as const)
  .map((md) => {
    const items = groupItems.filter((r) => r.match.matchday === md);
    return {
      md,
      items,
      finished: items.filter((r) => r.score).length,
      points: items.reduce((s, r) => s + (r.score?.points ?? 0), 0),
    };
  })
  .filter((g) => g.items.length > 0);
const koRounds = koGroups.map((g) => ({
  round: g.round,
  items: g.items,
  finished: g.items.filter((r) => r.score).length,
  points: g.items.reduce((s, r) => s + (r.score?.points ?? 0), 0),
}));

// Walk all sections in chronological order; the open one is the first that is
// not fully played, falling back to the last section once everything is done.
const sections = [
  ...matchdays.map((g) => ({ key: `md-${g.md}`, finished: g.finished, total: g.items.length })),
  ...koRounds.map((g) => ({ key: `ko-${g.round}`, finished: g.finished, total: g.items.length })),
];
const openKey = (sections.find((s) => s.finished < s.total) ?? sections.at(-1))?.key;

const pick = (key: keyof BonusPicks) => participant.bonus[key];

// Provisional bonus state (without affecting the points calculation).
const eliminated = eliminatedTeamIds();
const leaders = currentBonusLeaders();
/** Returns how a bonus pick currently stands while the tournament is ongoing. */
function provisional(key: keyof BonusPicks): { tone: 'good' | 'bad' | 'open'; label: string } | null {
  const value = pick(key);
  if (!value) return null;
  if (key === 'winnerTeamId') {
    return eliminated.has(value)
      ? { tone: 'bad', label: 'Niet meer mogelijk' }
      : { tone: 'open', label: 'Nog in de running' };
  }
  const lead = key === 'topScorer' ? leaders.topScorer
    : key === 'mostScoredTeamId' ? leaders.mostScoredTeamId
    : leaders.mostConcededTeamId;
  if (!lead.length) return { tone: 'open', label: 'Voorlopig geen punten' };
  if (lead.includes(value)) return { tone: 'good', label: `Voorlopig juist · +${settings.bonusPoints}` };
  return bonusPickAlive(key, value, eliminated, leaders)
    ? { tone: 'open', label: 'Voorlopig geen punten' }
    : { tone: 'bad', label: 'Niet meer mogelijk' };
}

// Form: last 5 finished matches (chronological) as coloured dots.
const formScores = rows
  .filter((r) => r.score)
  .sort((a, b) => byKickoff(a.match, b.match))
  .slice(-5)
  .map((r) => ({
    cls: r.score!.exact ? 'bg-emerald-500' : r.score!.points > 0 ? 'bg-amber-400' : 'bg-red-500',
  }));
const medal = rank?.position === 1 ? 'bg-gradient-to-b from-[#f6d873] to-[#dca21f] text-[#5a3d08] ring-2 ring-[#caa12e]/60'
  : rank?.position === 2 ? 'bg-gradient-to-b from-zinc-100 to-zinc-300 text-zinc-700 ring-2 ring-zinc-400/50'
  : rank?.position === 3 ? 'bg-gradient-to-b from-[#e3b27e] to-[#a96a32] text-white ring-2 ring-[#8a531f]/50'
  : 'bg-white/15 text-white ring-2 ring-white/20';

// Easter eggs (only once the tournament is under way, so a season-start tie
// where everyone shares position 1 doesn't trigger them for everyone):
//  - top-5 (prize spots) -> 8-bit money rain with the amount they'd win
//  - dead last           -> an 8-bit dog pops up from the bottom, laughing
// The trigger uses the LIVE position when live mode is on: the client recomputes
// this participant's provisional position from all participants' static totals +
// the live deltas dispatched by LiveScores.
const finishedCount = matches.filter((m) => m.status === 'finished').length;
const liveEggData = {
  pid: participant.id,
  totals: ranking().map((r) => [r.participantId, r.total] as [string, number]),
  staticTotal: rank?.total ?? 0,
  staticMp: rank?.matchPoints ?? 0,
  finished: finishedCount,
  prizes: PRIZES,
};

// 8-bit laughing dog (Duck Hunt style), painted from a pixel map (1 char = 1px).
const DOG_PX = 6;
const DOG_COLORS: Record<string, string> = {
  D: '#5a3a20', // dark-brown ears
  L: '#cea062', // tan head
  W: '#f4e9d6', // white snout / teeth
  K: '#1a1410', // outline / eyes / mouth
  P: '#e2728e', // tongue
  G: '#782834', // inner mouth
};
const DOG_ART = [
  '......DDD......DDD........',
  '.....DDDDD....DDDDD.......',
  '....DDDDDDD..DDDDDDD......',
  '....DDDDDDDDDDDDDDDD......',
  '...DDDDLLLLLLLLLLDDDD.....',
  '...DDDLLLLLLLLLLLLDDD.....',
  '...DDLLLLLLLLLLLLLLDD.....',
  '...DDLLKLKLLLLKLKLLDD.....',
  '...DDLLLKLLLLLLKLLLDD.....',
  '....DLLLLLLLLLLLLLLD......',
  '....DLLLWWWWWWWWLLLD......',
  '.....LLWWWWWWWWWWLL.......',
  '.....LWWWKKKKKKWWWL.......',
  '.....LWWKGGGGGGKWWL.......',
  '.....LWKGGWWWWGGKWL.......',
  '.....LLKGPPPPPPGKLL.......',
  '......LKGGGGGGGGKL........',
  '......LLKKKKKKKKLL........',
  '.....LLLL....LLLL.........',
];
const dogRects = DOG_ART.flatMap((row, y) =>
  [...row].map((ch, x) => (DOG_COLORS[ch] ? { x: x * DOG_PX, y: y * DOG_PX, fill: DOG_COLORS[ch] } : null))
).filter((r): r is { x: number; y: number; fill: string } => r !== null);
const dogW = Math.max(...DOG_ART.map((r) => r.length)) * DOG_PX;
const dogH = DOG_ART.length * DOG_PX;

// 8-bit crying dunce ("de kenner", donkey ears included) — Maxim's personal
// visitor. Same pixel-map approach as the dog; the tears are separate divs so
// they can drip on their own loop.
const EZEL_COLORS: Record<string, string> = {
  E: '#8a7258', // donkey-ear outside
  I: '#c9a6b0', // donkey-ear inside
  S: '#f2c99c', // skin
  H: '#6b4a2b', // hair
  K: '#1a1410', // outline / closed eyes / mouth
  W: '#f4e9d6', // shirt
};
const EZEL_ART = [
  '..EE..............EE..',
  '.EIIE............EIIE.',
  '.EIIE............EIIE.',
  '.EIIE............EIIE.',
  '..EIIE..........EIIE..',
  '...EIIE.HHHHHH.EIIE...',
  '....EEHHHHHHHHHHEE....',
  '.....KHHSSSSSSHHK.....',
  '.....KSSSSSSSSSSK.....',
  '....KSSKKSSSSKKSSK....',
  '....KSSSSSSSSSSSSK....',
  '....KSSSSSKKSSSSSK....',
  '....KSSSSSSSSSSSSK....',
  '.....KSSKKKKKKSSK.....',
  '.....KSKSSSSSSKSK.....',
  '......KSSSSSSSSK......',
  '.......KKKKKKKK.......',
  '......KWWWWWWWWK......',
  '.....KWWWWWWWWWWK.....',
];
const ezelRects = EZEL_ART.flatMap((row, y) =>
  [...row].map((ch, x) => (EZEL_COLORS[ch] ? { x: x * DOG_PX, y: y * DOG_PX, fill: EZEL_COLORS[ch] } : null))
).filter((r): r is { x: number; y: number; fill: string } => r !== null);
const ezelW = Math.max(...EZEL_ART.map((r) => r.length)) * DOG_PX;
const ezelH = EZEL_ART.length * DOG_PX;
---
<Layout title={`${participant.name} — Rut Prono WK 2026`} analytics={{ username: participant.name }}>
  <header class="hero-panel qc-decor mb-6 shadow-sm">
    <div class="flex items-center justify-between gap-4 p-5">
      <div class="flex min-w-0 items-center gap-3">
        <div id="hdr-pos" class:list={['grid size-12 shrink-0 place-items-center rounded-full font-display text-lg font-bold tabular-nums', medal]}>{rank?.position ?? '—'}</div>
        <div class="min-w-0">
          <h1 class="truncate text-2xl font-extrabold leading-tight">{participant.name}</h1>
        </div>
      </div>
      <div class="shrink-0 text-right">
        <div class="flex items-center justify-end gap-1.5">
          <span id="hdr-live-dot" class="hidden size-2.5 shrink-0 animate-pulse rounded-full bg-red-500" title="live tussenstand"></span>
          <div id="hdr-total" class="font-display text-4xl font-extrabold leading-none tabular-nums text-gold">{rank?.total ?? 0}</div>
        </div>
        <div class="mt-1 text-xs text-ink-foreground/70">punten</div>
      </div>
    </div>
    <div class="flex flex-wrap items-center justify-between gap-x-3 gap-y-2 border-t border-white/10 px-5 py-2.5 text-xs text-ink-foreground/80">
      <div class="flex items-center gap-3">
        <span><strong id="hdr-mp" class="font-semibold tabular-nums">{rank?.matchPoints ?? 0}</strong> uit wedstrijden</span>
        <span class="text-primary-foreground/40">•</span>
        <span><strong class="font-semibold tabular-nums">{rank?.bonusPoints ?? 0}</strong> bonus</span>
      </div>
      {formScores.length > 0 && (
        <div class="flex items-center gap-1.5 rounded-full bg-white/95 px-2.5 py-1.5 shadow-sm">
          {formScores.map((f) => (
            <span class:list={['size-2.5 rounded-full', f.cls]}></span>
          ))}
        </div>
      )}
    </div>
  </header>

  {participant.id === 'maxim' && (
    <div class="kenner-banner mb-6 mt-3 flex flex-col items-center rounded-xl border border-gold/40 bg-card px-6 py-5" aria-label="Eretitel: de kenner">
      <div class="flex items-center gap-3">
        <span class="kenner-l text-3xl" aria-hidden="true">👎</span>
        <span class="font-display text-2xl font-extrabold tracking-widest text-gold" aria-hidden="true">
          {'DE KENNER'.split('').map((ch, i) => (
            <span class="kenner-ch inline-block" style={`animation-delay:${0.4 + i * 0.09}s`}>{ch === ' ' ? ' ' : ch}</span>
          ))}
        </span>
        <span class="kenner-l kenner-l-alt text-3xl" aria-hidden="true">👎</span>
      </div>
      <p class="kenner-sub mt-1 text-xs text-muted-foreground">officieel erkende titel · uitgereikt door heel De Rut</p>
    </div>
  )}

  <script>
    // Count the big points total up from 0 on load. Bails out the moment
    // something else (the LiveScores recompute) writes the element, and is
    // skipped under prefers-reduced-motion.
    const totalEl = document.getElementById('hdr-total');
    const target = Number(totalEl?.textContent);
    if (totalEl && Number.isFinite(target) && target > 0 && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Reserve the final width and keep the digits right-aligned inside it,
      // so shorter intermediate numbers don't hug the left edge of the box
      // (especially visible in the compact mobile hero).
      totalEl.style.minWidth = `${totalEl.offsetWidth}px`;
      totalEl.style.textAlign = 'right';
      const dur = 800;
      let t0: number | null = null;
      let last = totalEl.textContent;
      const tick = (now: number) => {
        if (totalEl.textContent !== last) return; // external update took over
        t0 ??= now;
        const p = Math.min((now - t0) / dur, 1);
        last = String(Math.round(target * (1 - Math.pow(1 - p, 3))));
        totalEl.textContent = last;
        if (p < 1) requestAnimationFrame(tick);
        else {
          totalEl.style.minWidth = '';
          totalEl.style.textAlign = '';
          // Small settle pop so the final number registers.
          totalEl.animate?.(
            [{ transform: 'scale(1.14)' }, { transform: 'scale(1)' }],
            { duration: 280, easing: 'ease-out' },
          );
        }
      };
      // Give the hero's entrance a beat before the digits start rolling.
      setTimeout(() => requestAnimationFrame(tick), 350);
    }
  </script>

  <a href={`/vergelijk?a=${participant.id}`} class="mb-6 flex items-center justify-center gap-1.5 rounded-lg border bg-card px-4 py-2.5 text-sm font-semibold transition-colors hover:bg-muted">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-gold"><path d="M8 3 4 7l4 4" /><path d="M4 7h16" /><path d="m16 21 4-4-4-4" /><path d="M20 17H4" /></svg>
    Vergelijk met een andere deelnemer
  </a>

  <LiveScores ranking />
  <p id="live-basis-note" class="-mt-2 mb-4 hidden text-xs font-medium text-red-600 dark:text-red-400">
    Plaats, klassement en punten zijn gebaseerd op de live tussenstand.
  </p>

  {rankPoints.length >= 2 && (
    <section class="mb-8">
      <SectionHeading title="Klassementsverloop">
        <InfoToggle text="Plaats in het klassement na elke speeldag met resultaten (max. 10 dagen). Tik op een punt voor de plaats; stippellijnen tonen het einde van een speeldag/ronde. Lager getal = hoger geklasseerd." />
      </SectionHeading>
      <RankChart points={rankPoints} markers={rankMarkers} />
    </section>
  )}

  <section class="mb-8">
    <SectionHeading title="Bonusvoorspellingen" />
    <div class="grid grid-cols-2 gap-2">
      {bonus.items.map((item) => {
        const value = pick(item.key);
        const team = item.key === 'topScorer' ? undefined : getTeam(value);
        const prov = item.correct === null ? provisional(item.key) : null;
        return (
          <div class:list={[
            'flex flex-col rounded-xl border bg-card p-3',
            item.correct === true && 'border-emerald-500/60 bg-emerald-50 dark:bg-emerald-950/30',
            item.correct === false && 'opacity-70',
            prov?.tone === 'good' && 'border-emerald-500/50 bg-emerald-50/60 dark:bg-emerald-950/20',
            prov?.tone === 'bad' && 'border-red-400/50 bg-red-50/70 dark:bg-red-950/20',
          ]}>
            <div class="text-[11px] font-semibold uppercase tracking-wide text-muted-foreground/80">{BONUS_LABELS[item.key]}</div>
            {team ? (
              <a href={`/land/${team.id}`} class="my-1.5 flex items-center gap-2 font-semibold hover:underline">
                <Flag iso={team.iso} name={team.name} class="shrink-0 text-base" />
                <span class="truncate">{team.name}</span>
              </a>
            ) : (
              <div class="my-1.5 flex items-center gap-2 font-semibold">
                <span class="truncate">{value || '—'}</span>
              </div>
            )}
            <div class="mt-auto border-t border-border/60 pt-1.5 text-xs">
              {item.correct === true ? <span class="font-semibold text-emerald-600">+{item.points}</span>
                : item.correct === false ? <span class="text-muted-foreground">0 punten</span>
                : prov?.tone === 'good' ? <span class="font-semibold text-emerald-600">{prov.label}</span>
                : prov?.tone === 'bad' ? <span class="font-medium text-red-600">{prov.label}</span>
                : prov ? <span class="text-muted-foreground">{prov.label}</span>
                : null}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section>
    <SectionHeading title="Pronostieken">
      <InfoToggle text="De grote score is de voorspelling, daaronder staat de uitslag van de wedstrijd." />
    </SectionHeading>
    <div class="space-y-3">
      {matchdays.map((g) => (
        <details open={`md-${g.md}` === openKey} class="group rounded-xl border bg-card shadow-sm">
          <summary class="flex cursor-pointer select-none items-center gap-2 rounded-xl px-4 py-3 font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden">
            Speeldag {g.md}
            <span class="text-sm font-normal text-muted-foreground">{g.finished}/{g.items.length} gespeeld</span>
            {g.finished > 0 && <span class="ml-auto rounded-md bg-gold/15 px-2 py-0.5 text-sm font-bold tabular-nums text-primary">{g.points} ptn</span>}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class:list={['size-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180', g.finished === 0 && 'ml-auto']}><path d="m6 9 6 6 6-6" /></svg>
          </summary>
          <PredictionDayList items={g.items} />
        </details>
      ))}

      {koRounds.map((g) => (
        <details open={`ko-${g.round}` === openKey} class="group rounded-xl border bg-card shadow-sm">
          <summary class="flex cursor-pointer select-none items-center gap-2 rounded-xl px-4 py-3 font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden">
            {ROUND_LABELS[g.round]}
            <span class="text-sm font-normal text-muted-foreground">{g.finished}/{g.items.length} gespeeld</span>
            {g.finished > 0 && <span class="ml-auto rounded-md bg-gold/15 px-2 py-0.5 text-sm font-bold tabular-nums text-primary">{g.points} ptn</span>}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class:list={['size-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180', g.finished === 0 && 'ml-auto']}><path d="m6 9 6 6 6-6" /></svg>
          </summary>
          <PredictionDayList items={g.items} />
        </details>
      ))}
    </div>
  </section>

  {qfReached && outlook && (
    <section class="mt-8">
      <SectionHeading title="Mathematisch kan het nog">
        <InfoToggle text="Eenvoudige inschatting: kan deze deelnemer wiskundig nog top 5 (geld), top 3 (podium) of de eerste plaats halen? We gaan uit van het beste geval — jij pakt het maximum op alle resterende wedstrijden en nog mogelijke bonuspunten, terwijl niemand anders nog punten bijdoet." />
      </SectionHeading>
      <div class="grid grid-cols-3 gap-2 sm:gap-3">
        {outlookCards.map((c) => (
          <div class="flex flex-col items-center rounded-xl border bg-card p-3 text-center shadow-sm">
            <div class="flex min-h-[2.5em] items-center justify-center text-[11px] font-semibold uppercase leading-tight tracking-wide text-muted-foreground/80">{c.title}</div>
            <div class="text-[10px] text-muted-foreground/60">{c.sub}</div>
            <div class:list={['mt-1.5 font-display text-2xl font-extrabold leading-none', c.can ? 'text-emerald-600 dark:text-emerald-400' : 'text-red-600 dark:text-red-400']}>{c.can ? 'Ja' : 'Nee'}</div>
          </div>
        ))}
      </div>
      <p class="mt-2 text-center text-xs text-muted-foreground">
        {outlook.decided
          ? <>De eindstand is definitief: plaats {outlook.bestPos}e.</>
          : <>In het beste geval (jij scoort alles, de rest niets meer) eindig je op plaats <strong class="tabular-nums">{outlook.bestPos}e</strong> — nog max <strong class="tabular-nums">{outlook.remaining}</strong> punten te verdienen.</>}
      </p>
    </section>
  )}

  {/* Easter-egg data + a dog sprite template; the script below decides which (if
      any) to show from the live-aware position and animates it once. */}
  {participant.id === 'maxim' && (
    <div class="kenner-man pointer-events-none fixed inset-x-0 bottom-0 z-40 flex justify-end pr-6" aria-hidden="true">
      <div class="kenner-man-cycle flex flex-col items-center gap-1.5">
        <span class="laugh-bubble">BUHU… IK WIST HET NOCHTANS ZEKER…</span>
        <div class="relative">
          <svg class="block h-auto w-[130px]" viewBox={`0 0 ${ezelW} ${ezelH}`} shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
            {ezelRects.map((r) => (
              <rect x={r.x} y={r.y} width={DOG_PX} height={DOG_PX} fill={r.fill} />
            ))}
          </svg>
          <span class="kenner-tear" style="left: 29%; top: 46%;"></span>
          <span class="kenner-tear" style="left: 64%; top: 46%; animation-delay: 0.7s;"></span>
        </div>
      </div>
    </div>
  )}

  <script type="application/json" id="live-egg-data" set:html={JSON.stringify(liveEggData)} />
  <template id="dog-template">
    <svg class="dog-laughs block h-auto w-[160px]" viewBox={`0 0 ${dogW} ${dogH}`} shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
      {dogRects.map((r) => (
        <rect x={r.x} y={r.y} width={DOG_PX} height={DOG_PX} fill={r.fill} />
      ))}
    </svg>
  </template>

  <style is:global>
    /* 8-bit easter-egg styling for the participant page. */
    .coin { image-rendering: pixelated; }

    /* A prediction row showing a live score/points gets extra breathing room
       below so the live badge + score pill aren't cramped. The meta line (live
       badge + minute) gets space above it so it's clearly separated from the
       prediction, and the live score pill sits a touch lower. */
    .live-row { padding-bottom: 0.85rem; }
    .live-row .match-meta { margin-top: 0.5rem; }
    .live-row .match-score { margin-top: 0.5rem; }

    /* Top-5: the won amount, centred, big. The whole overlay fades after 3s. */
    .pixel-amount {
      font-family: ui-monospace, "Courier New", monospace;
      font-weight: 800;
      letter-spacing: 0.04em;
      font-size: clamp(3.5rem, 18vw, 8rem);
      color: #ffd64a;
      text-shadow: 4px 4px 0 rgba(0, 0, 0, 0.55), 0 0 1px #b9831a;
      image-rendering: pixelated;
      animation: amount-pop 0.45s steps(5, end) both;
    }
    @keyframes amount-pop {
      0% { transform: scale(0.4); opacity: 0; }
      70% { transform: scale(1.15); }
      100% { transform: scale(1); opacity: 1; }
    }
    @keyframes coin-fall {
      0% { transform: translateY(-14vh) rotate(0deg); opacity: 0; }
      12% { opacity: 1; }
      100% { transform: translateY(114vh) rotate(360deg); opacity: 1; }
    }
    @keyframes egg-fade { 0%, 72% { opacity: 1; } 100% { opacity: 0; } }
    #money-egg { animation: egg-fade 3s ease-out forwards; }

    /* Last place: a readable speech bubble + the dog popping up to laugh, then
       both drop back down and stay gone. */
    .laugh-bubble {
      display: inline-block;
      font-family: ui-monospace, "Courier New", monospace;
      font-weight: 800;
      font-size: 15px;
      letter-spacing: 0.02em;
      color: #111;
      background: #fff;
      border: 3px solid #111;
      border-radius: 9px;
      padding: 3px 9px;
      white-space: nowrap;
      box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.35);
    }
    @keyframes dog-cycle {
      0% { transform: translateY(110%); }
      18% { transform: translateY(0); }
      82% { transform: translateY(0); }
      100% { transform: translateY(110%); }
    }
    @keyframes dog-laugh {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-9%); }
    }
    .dog-pop { animation: dog-cycle 4.5s ease-in-out forwards; }
    .dog-laughs { animation: dog-laugh 0.26s steps(2, end) infinite; }

    /* "De kenner" komt wenen: het ezelsoren-mannetje schuift op Maxims pagina
       vanaf onder in beeld, snikt even na (schokschouderend) en zakt weer weg.
       De tranen druppen op hun eigen loop uit de (dichte) ogen. */
    @keyframes kenner-man-cycle {
      0% { transform: translateY(115%); }
      12% { transform: translateY(0); }
      86% { transform: translateY(0); }
      100% { transform: translateY(115%); }
    }
    @keyframes kenner-sob {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-4%); }
    }
    .kenner-man-cycle { animation: kenner-man-cycle 8s ease-in-out 1.2s both; }
    .kenner-man-cycle svg { animation: kenner-sob 0.55s steps(2, end) infinite; }
    .kenner-tear {
      position: absolute;
      width: 6px;
      height: 9px;
      border-radius: 0 0 3px 3px;
      background: #58b5f0;
      animation: kenner-tear-fall 1.3s ease-in infinite;
    }
    @keyframes kenner-tear-fall {
      0% { transform: translateY(0); opacity: 0; }
      15% { opacity: 1; }
      100% { transform: translateY(42px); opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .kenner-man { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      .pixel-amount, #money-egg { animation: none; }
      .dog-pop { animation: none; transform: translateY(0); }
      .dog-laughs { animation: none; }
    }
  </style>

  <script is:inline>
    // Live-aware 8-bit easter eggs. The trigger position uses the live
    // provisional standing when live mode is on (LiveScores dispatches deltas);
    // otherwise the static standing. Both eggs fire once and then vanish (≈3s
    // money, ≈4.5s dog), even under reduced motion (we just remove them).
    (() => {
      const dataEl = document.getElementById('live-egg-data');
      if (!dataEl) return;
      const D = JSON.parse(dataEl.textContent || '{}');
      if (!D.finished) return; // tournament not under way -> no eggs
      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const PID = D.pid;
      const totals = D.totals || [];
      const prizes = D.prizes || {};

      const MEDAL_BASE = 'grid size-12 shrink-0 place-items-center rounded-full font-display text-lg font-bold tabular-nums';
      const MEDALS = {
        1: 'bg-gradient-to-b from-[#f6d873] to-[#dca21f] text-[#5a3d08] ring-2 ring-[#caa12e]/60',
        2: 'bg-gradient-to-b from-zinc-100 to-zinc-300 text-zinc-700 ring-2 ring-zinc-400/50',
        3: 'bg-gradient-to-b from-[#e3b27e] to-[#a96a32] text-white ring-2 ring-[#8a531f]/50',
      };
      const MEDAL_DEFAULT = 'bg-white/15 text-white ring-2 ring-white/20';

      // Recompute this participant's provisional position from the live deltas.
      function compute(deltas) {
        const rows = totals.map((t) => ({ id: t[0], total: t[1] + (deltas[t[0]] || 0) }));
        rows.sort((a, b) => b.total - a.total);
        const posById = {};
        let pos = 0, last = null;
        rows.forEach((r, i) => { if (last === null || r.total !== last) { pos = i + 1; last = r.total; } posById[r.id] = pos; });
        const maxPos = rows.length ? posById[rows[rows.length - 1].id] : 0;
        const myPos = posById[PID];
        const tied = rows.filter((r) => posById[r.id] === myPos).length; // people sharing this position
        const mine = rows.find((r) => r.id === PID);
        return { pos: myPos, tied, maxPos, total: mine ? mine.total : D.staticTotal };
      }

      // Prize per person, accounting for ties (mirrors prizeFor in lib/prizes.ts):
      // `tied` people on `pos` occupy ranks pos..pos+tied-1; pool that money and
      // split it. So 2 tied for 4th split 4th+5th = (90+60)/2 = 75 each, with no
      // separate 5th place.
      function sharedPrize(pos, tied) {
        if (!tied || tied < 1) return 0;
        let pool = 0;
        for (let p = pos; p < pos + tied; p++) pool += prizes[p] || 0;
        return pool / tied;
      }

      const posEl = document.getElementById('hdr-pos');
      const totalEl = document.getElementById('hdr-total');
      const mpEl = document.getElementById('hdr-mp');
      const chartSvg = document.querySelector('[data-rank-chart]');
      const chartDot = chartSvg?.querySelector('[data-live-dot]');
      const chartLine = chartSvg?.querySelector('[data-live-line]');
      const chartSeries = chartSvg?.querySelector('[data-series]');
      const chartLastDot = chartSvg?.querySelector('[data-last-dot]');
      const seriesFull = chartSeries?.getAttribute('points') || '';
      const seriesTrim = seriesFull.trim().split(/\s+/).slice(0, -1).join(' '); // drop last point
      let liveActive = false; // ≥1 live match is currently adjusting this page
      let lastDeltas = {};
      // While live: the last leg of the curve becomes a red "live trend" segment
      // ending in a red dot at the live position; the last yellow dot is hidden
      // and the yellow line trimmed so there's no doubled-up endpoint.
      function updateChartDot(pos) {
        if (!chartSvg || !chartDot) return;
        if (!liveActive || pos == null) {
          chartDot.classList.add('hidden');
          chartLine?.classList.add('hidden');
          chartLastDot?.classList.remove('hidden');
          if (chartSeries && seriesFull) chartSeries.setAttribute('points', seriesFull);
          return;
        }
        const padT = +chartSvg.dataset.padT, span = +chartSvg.dataset.span, denom = +chartSvg.dataset.denom;
        const lastX = +chartSvg.dataset.lastX, axisY = +chartSvg.dataset.axisY;
        const prevX = +chartSvg.dataset.prevX, prevY = +chartSvg.dataset.prevY;
        const cy = Math.max(padT, Math.min(padT + ((pos - 1) / denom) * span, axisY));
        if (chartSeries && seriesTrim) chartSeries.setAttribute('points', seriesTrim);
        chartLastDot?.classList.add('hidden');
        if (chartLine) {
          chartLine.setAttribute('x1', String(prevX));
          chartLine.setAttribute('y1', String(prevY));
          chartLine.setAttribute('x2', String(lastX));
          chartLine.setAttribute('y2', cy.toFixed(1));
          chartLine.classList.remove('hidden');
        }
        chartDot.setAttribute('cx', String(lastX));
        chartDot.setAttribute('cy', cy.toFixed(1));
        chartDot.classList.remove('hidden');
      }
      function updateHeader(deltas) {
        lastDeltas = deltas;
        const r = compute(deltas);
        // Live cue: a red ring on the position badge (overrides the medal ring).
        if (posEl && r.pos != null) { posEl.textContent = String(r.pos); posEl.className = MEDAL_BASE + ' ' + (MEDALS[r.pos] || MEDAL_DEFAULT) + (liveActive ? ' !ring-red-500' : ''); }
        if (totalEl) totalEl.textContent = String(r.total);
        if (mpEl) mpEl.textContent = String(D.staticMp + (deltas[PID] || 0));
        updateChartDot(r.pos);
      }

      // ---- Live indicators: per-match provisional points + header red cues ----
      // Mirrors LiveScores' scoring so the per-match badges agree with the header
      // total. #live-scoring is embedded because this page uses <LiveScores ranking />.
      const scoring = JSON.parse(document.getElementById('live-scoring')?.textContent || 'null');
      const scoreByPair = new Map();
      if (scoring) for (const m of scoring.matches) { scoreByPair.set(m.h + '|' + m.a, m); scoreByPair.set(m.a + '|' + m.h, m); }
      const basePts = (ph, pa, rh, ra) => {
        if (ph === rh && pa === ra) return 9;
        if (Math.sign(ph - pa) !== Math.sign(rh - ra)) return 0;
        return Math.max(3, 7 - (Math.abs(ph - rh) + Math.abs(pa - ra)));
      };
      const pointsColor = (pts, exact) => pts === 0
        ? 'bg-red-200 text-red-800 dark:bg-red-950/60 dark:text-red-300'
        : exact
          ? 'bg-emerald-200 text-emerald-800 dark:bg-emerald-950/60 dark:text-emerald-300'
          : 'bg-amber-200 text-amber-900 dark:bg-amber-950/60 dark:text-amber-300';
      const liveNote = document.getElementById('live-basis-note');
      const liveDot = document.getElementById('hdr-live-dot');
      const liveRows = new Set();

      function clearLivePoints() {
        for (const card of liveRows) {
          const slot = card.querySelector('[data-points-slot]');
          if (slot && slot.dataset.orig != null) { slot.innerHTML = slot.dataset.orig; delete slot.dataset.orig; }
          card.classList.remove('live-row');
        }
        liveRows.clear();
      }

      function applyLiveMatches(list) {
        clearLivePoints();
        liveActive = (list || []).length > 0 && !!scoring;
        liveNote?.classList.toggle('hidden', !liveActive);
        liveDot?.classList.toggle('hidden', !liveActive);
        for (const lm of list || []) {
          const m = scoreByPair.get(lm.homeTeamId + '|' + lm.awayTeamId);
          if (!m) continue;
          const pred = (scoring.preds[m.id] || {})[PID];
          if (!pred) continue; // this participant didn't (validly) predict it
          const swapped = m.h !== lm.homeTeamId;
          const rh = swapped ? lm.goalsAway : lm.goalsHome;
          const ra = swapped ? lm.goalsHome : lm.goalsAway;
          const base = basePts(pred[0], pred[1], rh, ra);
          const mult = scoring.multipliers[m.round] ?? 1;
          const pts = base * mult;
          const card = document.querySelector('[data-match-card][data-match-id="' + m.id + '"]');
          const slot = card?.querySelector('[data-points-slot]');
          if (!slot) continue;
          if (slot.dataset.orig == null) slot.dataset.orig = slot.innerHTML;
          slot.innerHTML = '<span class="inline-flex min-w-9 items-center justify-center rounded-md px-2 py-1.5 text-sm font-bold tabular-nums ring-2 ring-red-500 ' + pointsColor(pts, base === 9) + '" title="Voorlopige punten (live)">' + pts + '</span>';
          card.classList.add('live-row');
          liveRows.add(card);
        }
        updateHeader(lastDeltas); // re-apply the position ring for the new live state
      }
      window.addEventListener('rut:live-matches', (e) => applyLiveMatches((e.detail && e.detail.matches) || []));

      const COIN = '<svg class="coin" viewBox="0 0 12 11" width="100%" height="100%" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="12" height="11" rx="1" fill="#1b7a3a"/><rect x="1" y="1" width="10" height="9" fill="#2eb35a"/><g fill="#ffd64a"><rect x="5" y="0" width="2" height="11"/><rect x="3" y="2" width="6" height="1"/><rect x="3" y="5" width="6" height="1"/><rect x="3" y="8" width="6" height="1"/><rect x="3" y="2" width="1" height="3"/><rect x="8" y="6" width="1" height="3"/></g></svg>';
      function showMoney(prize) {
        const host = document.createElement('div');
        host.id = 'money-egg';
        host.className = 'pointer-events-none fixed inset-0 z-[60] overflow-hidden';
        host.setAttribute('aria-hidden', 'true');
        const amount = Number.isInteger(prize) ? String(prize) : (Math.round(prize * 100) / 100).toFixed(2).replace('.', ',');
        host.innerHTML = '<div class="absolute inset-0 grid place-items-center"><span class="pixel-amount select-none">€' + amount + '</span></div>';
        document.body.appendChild(host);
        if (!reduce) {
          for (let i = 0; i < 26; i++) {
            const c = document.createElement('span');
            const size = 16 + Math.round(Math.random() * 18);
            c.style.position = 'absolute';
            c.style.top = '0';
            c.style.left = Math.round(Math.random() * 100) + 'vw';
            c.style.width = size + 'px';
            c.style.height = size + 'px';
            c.style.animation = 'coin-fall ' + (1.8 + Math.random() * 1).toFixed(2) + 's linear ' + (Math.random() * 0.8).toFixed(2) + 's both';
            c.innerHTML = COIN;
            host.appendChild(c);
          }
        }
        setTimeout(() => host.remove(), 3200);
      }
      function showDog() {
        const tpl = document.getElementById('dog-template');
        if (!tpl) return;
        const host = document.createElement('div');
        host.id = 'dog-egg';
        host.className = 'pointer-events-none fixed inset-x-0 bottom-0 z-[60] flex justify-center';
        host.setAttribute('aria-hidden', 'true');
        const inner = document.createElement('div');
        inner.className = 'dog-pop flex flex-col items-center';
        inner.innerHTML = '<div class="dog-laughs mb-1 select-none"><span class="laugh-bubble">HA HA HA!</span></div>';
        inner.appendChild(tpl.content.cloneNode(true));
        host.appendChild(inner);
        document.body.appendChild(host);
        setTimeout(() => host.remove(), 4700);
      }

      // Fire once, using the live position if a live result is already in.
      let fired = false;
      function fireEgg() {
        if (fired) return;
        fired = true;
        const r = compute(window.__rutLiveDeltas || {});
        if (r.pos == null) return;
        const prize = sharedPrize(r.pos, r.tied);
        if (prize > 0) showMoney(prize);
        else if (r.pos === r.maxPos && r.maxPos > 5) showDog();
      }

      window.addEventListener('rut:live-ranking', (e) => updateHeader((e.detail && e.detail.deltas) || {}));
      window.addEventListener('rut:live-ranking', fireEgg, { once: true });
      setTimeout(fireEgg, 2500); // fallback if LiveScores never dispatches
    })();
  </script>

  <script is:inline define:vars={{ participantId: participant.id, participantName: participant.name, participantPosition: rank?.position ?? null, participantTotal: rank?.total ?? 0 }}>
    window.posthog?.capture('participant_profile_viewed', {
      participant_id: participantId,
      participant_name: participantName,
      participant_position: participantPosition,
      participant_total: participantTotal,
    });
  </script>
</Layout>
