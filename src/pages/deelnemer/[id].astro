---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import LiveScores from '@/components/LiveScores.astro';
import PredictionDayList from '@/components/PredictionDayList.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import {
  participants, getParticipant, getTeam, positionOf, predictionsForParticipant, outcomes, settings,
  eliminatedTeamIds, currentBonusLeaders, ranking, matches,
} from '@/lib/data';
import { bonusBreakdown } from '@/lib/scoring';
import { PRIZES } from '@/lib/prizes';
import { ROUND_LABELS, ROUND_ORDER, type BonusPicks } from '@/lib/types';

export function getStaticPaths() {
  return participants.map((p) => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const participant = getParticipant(id!);
if (!participant) return Astro.redirect('/404');

const rank = positionOf(participant.id);
const rows = predictionsForParticipant(participant.id);
const bonus = bonusBreakdown(participant.bonus, outcomes, settings);

const BONUS_LABELS: Record<keyof BonusPicks, string> = {
  topScorer: 'Topschutter',
  winnerTeamId: 'Eindwinnaar',
  mostConcededTeamId: 'Meeste tegendoelpunten',
  mostScoredTeamId: 'Meeste doelpunten',
};

const byRound = ROUND_ORDER
  .map((round) => ({
    round,
    items: rows.filter((r) => r.match.round === round).sort((a, b) => a.match.kickoff.localeCompare(b.match.kickoff)),
  }))
  .filter((g) => g.items.length > 0);

// Group stage split per speeldag as collapsible sections (72 matches is too
// long as one flat list). A speeldag starts open when it has results or is
// the next one up; fully-future speeldagen start collapsed.
const groupItems = byRound.find((g) => g.round === 'group')?.items ?? [];
const koRounds = byRound.filter((g) => g.round !== 'group');
const matchdays = ([1, 2, 3] as const)
  .map((md) => {
    const items = groupItems.filter((r) => r.match.matchday === md);
    return {
      md,
      items,
      finished: items.filter((r) => r.score).length,
      points: items.reduce((s, r) => s + (r.score?.points ?? 0), 0),
    };
  })
  .filter((g) => g.items.length > 0);
const currentMd = matchdays.find((g) => g.finished < g.items.length)?.md;

const pick = (key: keyof BonusPicks) => participant.bonus[key];

// Provisional bonus state (without affecting the points calculation).
const eliminated = eliminatedTeamIds();
const leaders = currentBonusLeaders();
/** Returns how a bonus pick currently stands while the tournament is ongoing. */
function provisional(key: keyof BonusPicks): { tone: 'good' | 'bad' | 'open'; label: string } | null {
  const value = pick(key);
  if (!value) return null;
  if (key === 'winnerTeamId') {
    return eliminated.has(value)
      ? { tone: 'bad', label: 'Niet meer mogelijk' }
      : { tone: 'open', label: 'Nog in de running' };
  }
  const leaderKey = key === 'topScorer' ? leaders.topScorer
    : key === 'mostScoredTeamId' ? leaders.mostScoredTeamId
    : leaders.mostConcededTeamId;
  if (!leaderKey) return { tone: 'open', label: 'Voorlopig geen punten' };
  return value === leaderKey
    ? { tone: 'good', label: `Voorlopig juist · +${settings.bonusPoints}` }
    : { tone: 'open', label: 'Voorlopig geen punten' };
}

// Form: last 5 finished matches (chronological) as coloured dots.
const formScores = rows
  .filter((r) => r.score)
  .sort((a, b) => a.match.kickoff.localeCompare(b.match.kickoff))
  .slice(-5)
  .map((r) => ({
    cls: r.score!.exact ? 'bg-emerald-500' : r.score!.points > 0 ? 'bg-amber-400' : 'bg-red-500',
  }));
const medal = rank?.position === 1 ? 'bg-gradient-to-b from-[#f6d873] to-[#dca21f] text-[#5a3d08] ring-2 ring-[#caa12e]/60'
  : rank?.position === 2 ? 'bg-gradient-to-b from-zinc-100 to-zinc-300 text-zinc-700 ring-2 ring-zinc-400/50'
  : rank?.position === 3 ? 'bg-gradient-to-b from-[#e3b27e] to-[#a96a32] text-white ring-2 ring-[#8a531f]/50'
  : 'bg-white/15 text-white ring-2 ring-white/20';

// Easter eggs (only once the tournament is under way, so a season-start tie
// where everyone shares position 1 doesn't trigger them for everyone):
//  - top-5 (prize spots) -> 8-bit money rain with the amount they'd win
//  - dead last           -> an 8-bit dog pops up from the bottom, laughing
// The trigger uses the LIVE position when live mode is on: the client recomputes
// this participant's provisional position from all participants' static totals +
// the live deltas dispatched by LiveScores.
const finishedCount = matches.filter((m) => m.status === 'finished').length;
const liveEggData = {
  pid: participant.id,
  totals: ranking().map((r) => [r.participantId, r.total] as [string, number]),
  staticTotal: rank?.total ?? 0,
  staticMp: rank?.matchPoints ?? 0,
  finished: finishedCount,
  prizes: PRIZES,
};

// 8-bit laughing dog (Duck Hunt style), painted from a pixel map (1 char = 1px).
const DOG_PX = 6;
const DOG_COLORS: Record<string, string> = {
  D: '#5a3a20', // dark-brown ears
  L: '#cea062', // tan head
  W: '#f4e9d6', // white snout / teeth
  K: '#1a1410', // outline / eyes / mouth
  P: '#e2728e', // tongue
  G: '#782834', // inner mouth
};
const DOG_ART = [
  '......DDD......DDD........',
  '.....DDDDD....DDDDD.......',
  '....DDDDDDD..DDDDDDD......',
  '....DDDDDDDDDDDDDDDD......',
  '...DDDDLLLLLLLLLLDDDD.....',
  '...DDDLLLLLLLLLLLLDDD.....',
  '...DDLLLLLLLLLLLLLLDD.....',
  '...DDLLKLKLLLLKLKLLDD.....',
  '...DDLLLKLLLLLLKLLLDD.....',
  '....DLLLLLLLLLLLLLLD......',
  '....DLLLWWWWWWWWLLLD......',
  '.....LLWWWWWWWWWWLL.......',
  '.....LWWWKKKKKKWWWL.......',
  '.....LWWKGGGGGGKWWL.......',
  '.....LWKGGWWWWGGKWL.......',
  '.....LLKGPPPPPPGKLL.......',
  '......LKGGGGGGGGKL........',
  '......LLKKKKKKKKLL........',
  '.....LLLL....LLLL.........',
];
const dogRects = DOG_ART.flatMap((row, y) =>
  [...row].map((ch, x) => (DOG_COLORS[ch] ? { x: x * DOG_PX, y: y * DOG_PX, fill: DOG_COLORS[ch] } : null))
).filter((r): r is { x: number; y: number; fill: string } => r !== null);
const dogW = Math.max(...DOG_ART.map((r) => r.length)) * DOG_PX;
const dogH = DOG_ART.length * DOG_PX;
---
<Layout title={`${participant.name} — Rut Prono WK 2026`} analytics={{ username: participant.name }}>
  <header class="hero-panel qc-decor mb-6 shadow-sm">
    <div class="flex items-center justify-between gap-4 p-5">
      <div class="flex min-w-0 items-center gap-3">
        <div id="hdr-pos" class:list={['grid size-12 shrink-0 place-items-center rounded-full font-display text-lg font-bold tabular-nums', medal]}>{rank?.position ?? '—'}</div>
        <div class="min-w-0">
          <h1 class="truncate text-2xl font-extrabold leading-tight">{participant.name}</h1>
        </div>
      </div>
      <div class="shrink-0 text-right">
        <div id="hdr-total" class="font-display text-4xl font-extrabold leading-none tabular-nums text-gold">{rank?.total ?? 0}</div>
        <div class="mt-1 text-xs text-ink-foreground/70">punten</div>
      </div>
    </div>
    <div class="flex flex-wrap items-center justify-between gap-x-3 gap-y-2 border-t border-white/10 px-5 py-2.5 text-xs text-ink-foreground/80">
      <div class="flex items-center gap-3">
        <span><strong id="hdr-mp" class="font-semibold tabular-nums">{rank?.matchPoints ?? 0}</strong> uit wedstrijden</span>
        <span class="text-primary-foreground/40">•</span>
        <span><strong class="font-semibold tabular-nums">{rank?.bonusPoints ?? 0}</strong> bonus</span>
      </div>
      {formScores.length > 0 && (
        <div class="flex items-center gap-1.5 rounded-full bg-white/95 px-2.5 py-1.5 shadow-sm">
          {formScores.map((f) => (
            <span class:list={['size-2.5 rounded-full', f.cls]}></span>
          ))}
        </div>
      )}
    </div>
  </header>

  <LiveScores mode="list" showRecent={false} />

  <section class="mb-8">
    <SectionHeading title="Bonusvoorspellingen" />
    <div class="grid grid-cols-2 gap-2">
      {bonus.items.map((item) => {
        const value = pick(item.key);
        const team = item.key === 'topScorer' ? undefined : getTeam(value);
        const prov = item.correct === null ? provisional(item.key) : null;
        return (
          <div class:list={[
            'flex flex-col rounded-xl border bg-card p-3',
            item.correct === true && 'border-emerald-500/60 bg-emerald-50 dark:bg-emerald-950/30',
            item.correct === false && 'opacity-70',
            prov?.tone === 'good' && 'border-emerald-500/50 bg-emerald-50/60 dark:bg-emerald-950/20',
            prov?.tone === 'bad' && 'border-red-400/50 bg-red-50/70 dark:bg-red-950/20',
          ]}>
            <div class="text-[11px] font-semibold uppercase tracking-wide text-muted-foreground/80">{BONUS_LABELS[item.key]}</div>
            {team ? (
              <a href={`/land/${team.id}`} class="my-1.5 flex items-center gap-2 font-semibold hover:underline">
                <Flag iso={team.iso} name={team.name} class="shrink-0 text-base" />
                <span class="truncate">{team.name}</span>
              </a>
            ) : (
              <div class="my-1.5 flex items-center gap-2 font-semibold">
                <span class="truncate">{value || '—'}</span>
              </div>
            )}
            <div class="mt-auto border-t border-border/60 pt-1.5 text-xs">
              {item.correct === true ? <span class="font-semibold text-emerald-600">+{item.points}</span>
                : item.correct === false ? <span class="text-muted-foreground">0 punten</span>
                : prov?.tone === 'good' ? <span class="font-semibold text-emerald-600">{prov.label}</span>
                : prov?.tone === 'bad' ? <span class="font-medium text-red-600">{prov.label}</span>
                : prov ? <span class="text-muted-foreground">{prov.label}</span>
                : null}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section>
    <SectionHeading title="Pronostieken">
      <InfoToggle text="De grote score is de voorspelling, daaronder staat de uitslag van de wedstrijd." />
    </SectionHeading>
    <div class="space-y-3">
      {matchdays.map((g) => (
        <details open={g.finished > 0 || g.md === currentMd} class="group rounded-xl border bg-card shadow-sm">
          <summary class="flex cursor-pointer select-none items-center gap-2 rounded-xl px-4 py-3 font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden">
            Speeldag {g.md}
            <span class="text-sm font-normal text-muted-foreground">{g.finished}/{g.items.length} gespeeld</span>
            {g.finished > 0 && <span class="ml-auto rounded-md bg-gold/15 px-2 py-0.5 text-sm font-bold tabular-nums text-primary">{g.points} ptn</span>}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class:list={['size-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180', g.finished === 0 && 'ml-auto']}><path d="m6 9 6 6 6-6" /></svg>
          </summary>
          <PredictionDayList items={g.items} />
        </details>
      ))}

      {koRounds.map((g) => {
        const finished = g.items.filter((r) => r.score).length;
        const points = g.items.reduce((s, r) => s + (r.score?.points ?? 0), 0);
        return (
          <details open={finished > 0} class="group rounded-xl border bg-card shadow-sm">
            <summary class="flex cursor-pointer select-none items-center gap-2 rounded-xl px-4 py-3 font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden">
              {ROUND_LABELS[g.round]}
              <span class="text-sm font-normal text-muted-foreground">{finished}/{g.items.length} gespeeld</span>
              {finished > 0 && <span class="ml-auto rounded-md bg-gold/15 px-2 py-0.5 text-sm font-bold tabular-nums text-primary">{points} ptn</span>}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class:list={['size-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180', finished === 0 && 'ml-auto']}><path d="m6 9 6 6 6-6" /></svg>
            </summary>
            <PredictionDayList items={g.items} />
          </details>
        );
      })}
    </div>
  </section>

  {/* Easter-egg data + a dog sprite template; the script below decides which (if
      any) to show from the live-aware position and animates it once. */}
  <script type="application/json" id="live-egg-data" set:html={JSON.stringify(liveEggData)} />
  <template id="dog-template">
    <svg class="dog-laughs block h-auto w-[160px]" viewBox={`0 0 ${dogW} ${dogH}`} shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
      {dogRects.map((r) => (
        <rect x={r.x} y={r.y} width={DOG_PX} height={DOG_PX} fill={r.fill} />
      ))}
    </svg>
  </template>

  <style is:global>
    /* 8-bit easter-egg styling for the participant page. */
    .coin { image-rendering: pixelated; }

    /* Top-5: the won amount, centred, big. The whole overlay fades after 3s. */
    .pixel-amount {
      font-family: ui-monospace, "Courier New", monospace;
      font-weight: 800;
      letter-spacing: 0.04em;
      font-size: clamp(3.5rem, 18vw, 8rem);
      color: #ffd64a;
      text-shadow: 4px 4px 0 rgba(0, 0, 0, 0.55), 0 0 1px #b9831a;
      image-rendering: pixelated;
      animation: amount-pop 0.45s steps(5, end) both;
    }
    @keyframes amount-pop {
      0% { transform: scale(0.4); opacity: 0; }
      70% { transform: scale(1.15); }
      100% { transform: scale(1); opacity: 1; }
    }
    @keyframes coin-fall {
      0% { transform: translateY(-14vh) rotate(0deg); opacity: 0; }
      12% { opacity: 1; }
      100% { transform: translateY(114vh) rotate(360deg); opacity: 1; }
    }
    @keyframes egg-fade { 0%, 72% { opacity: 1; } 100% { opacity: 0; } }
    #money-egg { animation: egg-fade 3s ease-out forwards; }

    /* Last place: a readable speech bubble + the dog popping up to laugh, then
       both drop back down and stay gone. */
    .laugh-bubble {
      display: inline-block;
      font-family: ui-monospace, "Courier New", monospace;
      font-weight: 800;
      font-size: 15px;
      letter-spacing: 0.02em;
      color: #111;
      background: #fff;
      border: 3px solid #111;
      border-radius: 9px;
      padding: 3px 9px;
      white-space: nowrap;
      box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.35);
    }
    @keyframes dog-cycle {
      0% { transform: translateY(110%); }
      18% { transform: translateY(0); }
      82% { transform: translateY(0); }
      100% { transform: translateY(110%); }
    }
    @keyframes dog-laugh {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-9%); }
    }
    .dog-pop { animation: dog-cycle 4.5s ease-in-out forwards; }
    .dog-laughs { animation: dog-laugh 0.26s steps(2, end) infinite; }

    @media (prefers-reduced-motion: reduce) {
      .pixel-amount, #money-egg { animation: none; }
      .dog-pop { animation: none; transform: translateY(0); }
      .dog-laughs { animation: none; }
    }
  </style>

  <script is:inline>
    // Live-aware 8-bit easter eggs. The trigger position uses the live
    // provisional standing when live mode is on (LiveScores dispatches deltas);
    // otherwise the static standing. Both eggs fire once and then vanish (≈3s
    // money, ≈4.5s dog), even under reduced motion (we just remove them).
    (() => {
      const dataEl = document.getElementById('live-egg-data');
      if (!dataEl) return;
      const D = JSON.parse(dataEl.textContent || '{}');
      if (!D.finished) return; // tournament not under way -> no eggs
      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const PID = D.pid;
      const totals = D.totals || [];
      const prizes = D.prizes || {};

      const MEDAL_BASE = 'grid size-12 shrink-0 place-items-center rounded-full font-display text-lg font-bold tabular-nums';
      const MEDALS = {
        1: 'bg-gradient-to-b from-[#f6d873] to-[#dca21f] text-[#5a3d08] ring-2 ring-[#caa12e]/60',
        2: 'bg-gradient-to-b from-zinc-100 to-zinc-300 text-zinc-700 ring-2 ring-zinc-400/50',
        3: 'bg-gradient-to-b from-[#e3b27e] to-[#a96a32] text-white ring-2 ring-[#8a531f]/50',
      };
      const MEDAL_DEFAULT = 'bg-white/15 text-white ring-2 ring-white/20';

      // Recompute this participant's provisional position from the live deltas.
      function compute(deltas) {
        const rows = totals.map((t) => ({ id: t[0], total: t[1] + (deltas[t[0]] || 0) }));
        rows.sort((a, b) => b.total - a.total);
        const posById = {};
        let pos = 0, last = null;
        rows.forEach((r, i) => { if (last === null || r.total !== last) { pos = i + 1; last = r.total; } posById[r.id] = pos; });
        const maxPos = rows.length ? posById[rows[rows.length - 1].id] : 0;
        const mine = rows.find((r) => r.id === PID);
        return { pos: posById[PID], maxPos, total: mine ? mine.total : D.staticTotal };
      }

      const posEl = document.getElementById('hdr-pos');
      const totalEl = document.getElementById('hdr-total');
      const mpEl = document.getElementById('hdr-mp');
      function updateHeader(deltas) {
        const r = compute(deltas);
        if (posEl && r.pos != null) { posEl.textContent = String(r.pos); posEl.className = MEDAL_BASE + ' ' + (MEDALS[r.pos] || MEDAL_DEFAULT); }
        if (totalEl) totalEl.textContent = String(r.total);
        if (mpEl) mpEl.textContent = String(D.staticMp + (deltas[PID] || 0));
      }

      const COIN = '<svg class="coin" viewBox="0 0 12 11" width="100%" height="100%" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="12" height="11" rx="1" fill="#1b7a3a"/><rect x="1" y="1" width="10" height="9" fill="#2eb35a"/><g fill="#ffd64a"><rect x="5" y="0" width="2" height="11"/><rect x="3" y="2" width="6" height="1"/><rect x="3" y="5" width="6" height="1"/><rect x="3" y="8" width="6" height="1"/><rect x="3" y="2" width="1" height="3"/><rect x="8" y="6" width="1" height="3"/></g></svg>';
      function showMoney(prize) {
        const host = document.createElement('div');
        host.id = 'money-egg';
        host.className = 'pointer-events-none fixed inset-0 z-[60] overflow-hidden';
        host.setAttribute('aria-hidden', 'true');
        host.innerHTML = '<div class="absolute inset-0 grid place-items-center"><span class="pixel-amount select-none">€' + prize + '</span></div>';
        document.body.appendChild(host);
        if (!reduce) {
          for (let i = 0; i < 26; i++) {
            const c = document.createElement('span');
            const size = 16 + Math.round(Math.random() * 18);
            c.style.position = 'absolute';
            c.style.top = '0';
            c.style.left = Math.round(Math.random() * 100) + 'vw';
            c.style.width = size + 'px';
            c.style.height = size + 'px';
            c.style.animation = 'coin-fall ' + (1.8 + Math.random() * 1).toFixed(2) + 's linear ' + (Math.random() * 0.8).toFixed(2) + 's both';
            c.innerHTML = COIN;
            host.appendChild(c);
          }
        }
        setTimeout(() => host.remove(), 3200);
      }
      function showDog() {
        const tpl = document.getElementById('dog-template');
        if (!tpl) return;
        const host = document.createElement('div');
        host.id = 'dog-egg';
        host.className = 'pointer-events-none fixed inset-x-0 bottom-0 z-[60] flex justify-center';
        host.setAttribute('aria-hidden', 'true');
        const inner = document.createElement('div');
        inner.className = 'dog-pop flex flex-col items-center';
        inner.innerHTML = '<div class="dog-laughs mb-1 select-none"><span class="laugh-bubble">HA HA HA!</span></div>';
        inner.appendChild(tpl.content.cloneNode(true));
        host.appendChild(inner);
        document.body.appendChild(host);
        setTimeout(() => host.remove(), 4700);
      }

      // Fire once, using the live position if a live result is already in.
      let fired = false;
      function fireEgg() {
        if (fired) return;
        fired = true;
        const r = compute(window.__rutLiveDeltas || {});
        if (r.pos == null) return;
        const prize = prizes[r.pos] || 0;
        if (prize > 0) showMoney(prize);
        else if (r.pos === r.maxPos && r.maxPos > 5) showDog();
      }

      window.addEventListener('rut:live-ranking', (e) => updateHeader((e.detail && e.detail.deltas) || {}));
      window.addEventListener('rut:live-ranking', fireEgg, { once: true });
      setTimeout(fireEgg, 2500); // fallback if LiveScores never dispatches
    })();
  </script>

  <script is:inline define:vars={{ participantId: participant.id, participantName: participant.name, participantPosition: rank?.position ?? null, participantTotal: rank?.total ?? 0 }}>
    window.posthog?.capture('participant_profile_viewed', {
      participant_id: participantId,
      participant_name: participantName,
      participant_position: participantPosition,
      participant_total: participantTotal,
    });
  </script>
</Layout>
