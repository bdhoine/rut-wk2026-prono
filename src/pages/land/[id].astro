---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import MatchCard from '@/components/MatchCard.astro';
import StandingsTable from '@/components/StandingsTable.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import PickersTable from '@/components/PickersTable.astro';
import { teams, getTeam, matchesForTeam, standingsForGroup, winnerPickers, mostScoredPickers, mostConcededPickers, goalscorersForTeam } from '@/lib/data';

export function getStaticPaths() {
  return teams.map((t) => ({ params: { id: t.id } }));
}

const { id } = Astro.params;
const team = getTeam(id!);
if (!team) return Astro.redirect('/404');

const fixtures = matchesForTeam(team.id);
const standings = standingsForGroup(team.group);

const teamScorers = goalscorersForTeam(team.id);

// Who picked this country for which bonus, ranked by klassement position.
// Kept as three separate sections; empty ones collapse to a compact row.
const pickSections = [
  { title: 'Getipt als eindwinnaar', info: 'Deelnemers die dit land als WK-winnaar tipten, op volgorde van hun plaats in het klassement.', rows: winnerPickers(team.id), empty: `Niemand tipte ${team.name} als eindwinnaar.` },
  { title: 'Getipt voor meeste doelpunten', info: 'Deelnemers die dit land tipten als ploeg met de meeste doelpunten, op volgorde van hun plaats in het klassement.', rows: mostScoredPickers(team.id), empty: `Niemand tipte ${team.name} voor de meeste doelpunten.` },
  { title: 'Getipt voor meeste tegendoelpunten', info: 'Deelnemers die dit land tipten als ploeg met de meeste tegendoelpunten, op volgorde van hun plaats in het klassement.', rows: mostConcededPickers(team.id), empty: `Niemand tipte ${team.name} voor de meeste tegendoelpunten.` },
];
---
<Layout title={`${team.name} — Rut Prono WK 2026`}>
  <header class="mb-6 flex items-center gap-3 rounded-xl border border-t-4 border-t-gold bg-card p-4 shadow-sm">
    <Flag iso={team.iso} name={team.name} class="text-4xl" />
    <div>
      <h1 class="text-2xl font-bold tracking-tight">{team.name}</h1>
      <div class="text-sm text-muted-foreground">Groep {team.group}</div>
    </div>
  </header>

  <section class="mb-8">
    <SectionHeading title="Programma" />
    {fixtures.length === 0 ? (
      <p class="text-muted-foreground">Nog geen wedstrijden.</p>
    ) : (
      <div class="space-y-2">
        {fixtures.map((m) => <MatchCard match={m} href={`/wedstrijd/${m.id}`} />)}
      </div>
    )}
  </section>

  <section class="mb-8">
    <SectionHeading title={`Stand groep ${team.group}`} />
    <StandingsTable rows={standings} highlightTop={2} />
    <p class="mt-2 flex items-center gap-1.5 px-1 text-xs text-muted-foreground">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 text-emerald-600 dark:text-emerald-400" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
      Naar de volgende ronde
    </p>
    <a href="/poules" class="mt-3 flex items-center justify-center gap-1.5 rounded-lg border bg-card px-4 py-2.5 text-sm font-semibold transition-colors hover:bg-muted">
      Toon alle groepen
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </section>

  <section class="mb-8">
    <SectionHeading title="Doelpuntenmakers" />
    {teamScorers.length === 0 ? (
      <p class="rounded-xl border border-dashed px-3 py-3 text-sm text-muted-foreground">Nog geen doelpunten.</p>
    ) : (
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="px-2 py-2 text-left font-medium">Speler</th>
              <th class="w-16 px-2 py-2 text-center font-medium" title="Doelpunten">Goals</th>
            </tr>
          </thead>
          <tbody>
            {teamScorers.map((s) => (
              <tr class="border-b last:border-0">
                <td class="px-2 py-2.5">
                  <div class="flex min-w-0 items-center gap-2 font-medium">
                    <Flag iso={team.iso} name={team.name} class="shrink-0 text-base" />
                    <span class="truncate">{s.player}</span>
                  </div>
                </td>
                <td class="px-2 py-2.5 text-center font-bold tabular-nums">{s.goals}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>

  {pickSections.map((s) => (
    s.rows.length > 0 ? (
      <section class="mb-8">
        <SectionHeading title={s.title}>
          <InfoToggle text={s.info} />
        </SectionHeading>
        <PickersTable rows={s.rows} empty={s.empty} />
      </section>
    ) : (
      <details class="group mb-3 rounded-xl border bg-card shadow-sm">
        <summary class="flex cursor-pointer select-none items-center gap-2 rounded-xl px-4 py-3 text-sm font-medium text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden">
          {s.title}
          <span class="text-muted-foreground/70">· niemand</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto size-4 shrink-0 transition-transform group-open:rotate-180"><path d="m6 9 6 6 6-6" /></svg>
        </summary>
        <p class="px-4 pb-3 text-sm text-muted-foreground">{s.empty}</p>
      </details>
    )
  ))}

  <script is:inline define:vars={{ teamId: team.id, teamName: team.name, teamGroup: team.group }}>
    window.posthog?.capture('team_profile_viewed', {
      team_id: teamId,
      team_name: teamName,
      team_group: teamGroup,
    });
  </script>
</Layout>
