---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import MatchCard from '@/components/MatchCard.astro';
import StandingsTable from '@/components/StandingsTable.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import PickersTable from '@/components/PickersTable.astro';
import { teams, getTeam, matchesForTeam, standingsForGroup, winnerPickers, mostScoredPickers, mostConcededPickers } from '@/lib/data';

export function getStaticPaths() {
  return teams.map((t) => ({ params: { id: t.id } }));
}

const { id } = Astro.params;
const team = getTeam(id!);
if (!team) return Astro.redirect('/404');

const fixtures = matchesForTeam(team.id);
const standings = standingsForGroup(team.group);

// Who picked this country for which bonus, ranked by klassement position.
const pickedAsWinner = winnerPickers(team.id);
const pickedMostScored = mostScoredPickers(team.id);
const pickedMostConceded = mostConcededPickers(team.id);
---
<Layout title={`${team.name} — Rut Prono WK 2026`}>
  <a href="/poules" class="mb-4 inline-block text-sm text-muted-foreground hover:text-foreground">← Poules</a>

  <header class="mb-6 flex items-center gap-3 rounded-xl border border-t-4 border-t-gold bg-card p-4 shadow-sm">
    <Flag iso={team.iso} name={team.name} class="text-4xl" />
    <div>
      <h1 class="text-2xl font-bold tracking-tight">{team.name}</h1>
      <div class="text-sm text-muted-foreground">Groep {team.group}</div>
    </div>
  </header>

  <section class="mb-8">
    <SectionHeading title="Programma" />
    {fixtures.length === 0 ? (
      <p class="text-muted-foreground">Nog geen wedstrijden.</p>
    ) : (
      <div class="space-y-2">
        {fixtures.map((m) => <MatchCard match={m} href={`/wedstrijd/${m.id}`} />)}
      </div>
    )}
  </section>

  <section class="mb-8">
    <SectionHeading title={`Stand groep ${team.group}`} />
    <StandingsTable rows={standings} highlightTop={2} />
  </section>

  <section class="mb-8">
    <SectionHeading title="Getipt als eindwinnaar">
      <InfoToggle text="Deelnemers die dit land als WK-winnaar tipten, op volgorde van hun plaats in het klassement." />
    </SectionHeading>
    <PickersTable rows={pickedAsWinner} empty={`Niemand tipte ${team.name} als eindwinnaar.`} />
  </section>

  <section class="mb-8">
    <SectionHeading title="Getipt voor meeste doelpunten">
      <InfoToggle text="Deelnemers die dit land tipten als ploeg met de meeste doelpunten, op volgorde van hun plaats in het klassement." />
    </SectionHeading>
    <PickersTable rows={pickedMostScored} empty={`Niemand tipte ${team.name} voor de meeste doelpunten.`} />
  </section>

  <section>
    <SectionHeading title="Getipt voor meeste tegendoelpunten">
      <InfoToggle text="Deelnemers die dit land tipten als ploeg met de meeste tegendoelpunten, op volgorde van hun plaats in het klassement." />
    </SectionHeading>
    <PickersTable rows={pickedMostConceded} empty={`Niemand tipte ${team.name} voor de meeste tegendoelpunten.`} />
  </section>
</Layout>
