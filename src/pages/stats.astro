---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import { topScorers, mostGoalsScored, mostGoalsConceded } from '@/lib/data';

const scorers = topScorers();
const scored = mostGoalsScored();
const conceded = mostGoalsConceded();
---
<Layout title="Statistieken">
  <h1 class="mb-1 text-2xl font-bold tracking-tight">Statistieken</h1>
  <p class="mb-6 text-sm text-muted-foreground">Doelpunten in de verlengingen tellen mee; strafschoppenreeksen niet.</p>

  <section class="mb-8">
    <h2 class="mb-2 text-lg font-semibold">Topschutters</h2>
    <div class="overflow-x-auto rounded-xl border bg-card">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-muted-foreground">
            <th class="w-6 px-2 py-2 text-left font-medium">#</th>
            <th class="px-2 py-2 text-left font-medium">Speler</th>
            <th class="px-2 py-2 text-left font-medium">Land</th>
            <th class="px-2 py-2 text-right font-medium">Goals</th>
          </tr>
        </thead>
        <tbody>
          {scorers.map((s, i) => (
            <tr class="border-b last:border-0">
              <td class="px-2 py-2 tabular-nums text-muted-foreground">{i + 1}</td>
              <td class="px-2 py-2 font-medium">{s.player}</td>
              <td class="px-2 py-2">
                {s.team ? (
                  <a href={`/land/${s.team.id}`} class="flex items-center gap-2 hover:underline">
                    <Flag iso={s.team.iso} name={s.team.name} class="text-base" />
                    <span>{s.team.name}</span>
                  </a>
                ) : '—'}
              </td>
              <td class="px-2 py-2 text-right font-bold tabular-nums">{s.goals}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <div class="grid gap-8 md:grid-cols-2">
    <section>
      <h2 class="mb-2 text-lg font-semibold">Meeste doelpunten</h2>
      <div class="overflow-x-auto rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="px-2 py-2 text-left font-medium">Land</th>
              <th class="px-2 py-2 text-right font-medium">Voor</th>
            </tr>
          </thead>
          <tbody>
            {scored.map((t) => (
              <tr class="border-b last:border-0">
                <td class="px-2 py-2">
                  <a href={`/land/${t.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={t.team.iso} name={t.team.name} class="text-base" />
                    <span>{t.team.name}</span>
                  </a>
                </td>
                <td class="px-2 py-2 text-right font-bold tabular-nums">{t.scored}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2 class="mb-2 text-lg font-semibold">Meeste tegendoelpunten</h2>
      <div class="overflow-x-auto rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="px-2 py-2 text-left font-medium">Land</th>
              <th class="px-2 py-2 text-right font-medium">Tegen</th>
            </tr>
          </thead>
          <tbody>
            {conceded.map((t) => (
              <tr class="border-b last:border-0">
                <td class="px-2 py-2">
                  <a href={`/land/${t.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={t.team.iso} name={t.team.name} class="text-base" />
                    <span>{t.team.name}</span>
                  </a>
                </td>
                <td class="px-2 py-2 text-right font-bold tabular-nums">{t.conceded}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</Layout>
