---
import Layout from '@/layouts/Layout.astro';
import MatchCard from '@/components/MatchCard.astro';
import LiveScores from '@/components/LiveScores.astro';
import { upcomingMatches } from '@/lib/data';

const matches = upcomingMatches();
---
<Layout title="Programma">
  <h1 class="mb-4 text-2xl font-bold tracking-tight">Programma</h1>
  <LiveScores />
  {matches.length === 0 ? (
    <p class="text-muted-foreground">Geen komende wedstrijden.</p>
  ) : (
    <div class="space-y-3">
      {matches.map((m) => <MatchCard match={m} href={`/wedstrijd/${m.id}`} />)}
    </div>
  )}
</Layout>
