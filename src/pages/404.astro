---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Pagina niet gevonden — Rut Prono WK 2026">
  <section class="hero-panel qc-decor animate-rise mx-auto mt-8 max-w-md p-8 text-center">
    <p class="font-display text-7xl font-extrabold tracking-tight text-gold">404</p>
    <h1 class="mt-2 font-display text-xl font-bold">Buitenspel!</h1>
    <p class="mt-2 text-sm text-ink-foreground/75">Deze pagina bestaat niet (meer).</p>
    <div class="mt-5 flex flex-wrap justify-center gap-2">
      <a href="/" class="rounded-md bg-gold px-4 py-2 text-sm font-semibold text-gold-foreground hover:brightness-105">Naar het klassement</a>
      <a href="/kalender" class="rounded-md border border-white/20 px-4 py-2 text-sm font-semibold hover:bg-white/10">Kalender</a>
    </div>
  </section>
</Layout>
