---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import LiveScores from '@/components/LiveScores.astro';
import LivePoules from '@/components/LivePoules.astro';
import StandingsTable from '@/components/StandingsTable.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import PageHeader from '@/components/PageHeader.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { groups, standingsForGroup, bestThirdPlaced } from '@/lib/data';

const groupTables = groups.map((g) => ({ id: g.id, rows: standingsForGroup(g.id) }));
const thirds = bestThirdPlaced();
// Same gating as StandingsTable: no qualification verdict before any results.
const thirdsHaveResults = thirds.some((t) => t.played > 0);
---
<Layout title="Groepen">
  <PageHeader title="Groepen">
    <InfoToggle text="Top 2 per groep plaatst zich rechtstreeks. Tik op een land voor het programma." />
  </PageHeader>
  <LiveScores />
  <LivePoules />

  <div class="grid gap-6 md:grid-cols-2">
    {groupTables.map((g) => (
      <section>
        <SectionHeading title={`Groep ${g.id}`} />
        <StandingsTable rows={g.rows} highlightTop={2} groupId={g.id} />
      </section>
    ))}
  </div>

  <p class="mt-3 flex items-center gap-1.5 px-1 text-xs text-muted-foreground">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 text-emerald-600 dark:text-emerald-400" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
    Naar de volgende ronde
  </p>

  <section class="mt-8">
    <SectionHeading title="Beste nummers 3">
      <InfoToggle text="De 8 beste derdes plaatsen zich voor de 1/16de finales (✓)." />
    </SectionHeading>
    <div class="overflow-hidden rounded-xl border bg-card">
      <table class="w-full table-fixed text-sm">
        <colgroup>
          <col class="w-8" />
          <col />
          <col class="w-16" />
          <col class="w-12" />
          <col class="w-12" />
        </colgroup>
        <thead>
          <tr class="border-b text-muted-foreground">
            <th class="px-2 py-2 text-center font-medium">#</th>
            <th class="px-2 py-2 text-left font-medium">Land</th>
            <th class="py-2 text-center font-medium">Groep</th>
            <th class="py-2 text-center font-medium" title="Doelsaldo">+/-</th>
            <th class="px-2 py-2 text-center font-medium">Ptn</th>
          </tr>
        </thead>
        <tbody data-live-thirds>
          {thirds.map((t, i) => (
            <tr class:list={['border-b last:border-0', thirdsHaveResults && t.qualifies && 'bg-emerald-50/70 dark:bg-emerald-950/30']}>
              <td class="px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
              <td class="px-2 py-2.5">
                <a href={`/land/${t.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                  <Flag iso={t.team.iso} name={t.team.name} class="shrink-0 text-base" />
                  <span class="truncate">{t.team.name}</span>
                  {thirdsHaveResults && t.qualifies && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-3 shrink-0 text-emerald-600 dark:text-emerald-400" role="img" aria-label="geplaatst"><path d="M20 6 9 17l-5-5" /></svg>
                  )}
                </a>
              </td>
              <td class="py-2.5 text-center tabular-nums">{t.group}</td>
              <td class="py-2.5 text-center tabular-nums">{t.goalDiff > 0 ? `+${t.goalDiff}` : t.goalDiff}</td>
              <td class="px-2 py-2.5 text-center font-bold tabular-nums">{t.points}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>
