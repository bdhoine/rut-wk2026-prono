---
import Layout from '@/layouts/Layout.astro';
import RankingTable from '@/components/RankingTable.tsx';
import LiveScores from '@/components/LiveScores.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import PageHeader from '@/components/PageHeader.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { ranking, getParticipant, getTeam, participantForm } from '@/lib/data';

const rows = ranking().map((r) => {
  const winner = getTeam(getParticipant(r.participantId)?.bonus.winnerTeamId);
  return {
    position: r.position,
    participantId: r.participantId,
    name: r.name,
    total: r.total,
    matchPoints: r.matchPoints,
    bonusPoints: r.bonusPoints,
    winnerIso: winner?.iso ?? null,
    winnerName: winner?.name ?? null,
    form: participantForm(r.participantId, 5),
  };
});
---
<Layout title="Klassement — Rut Prono WK 2026">
  <PageHeader title="Klassement" eyebrow="Volledige stand" />
  <LiveScores mode="list" showRecent={false} />
  <SectionHeading title="Stand">
    <InfoToggle text="Tik op een deelnemer voor zijn pronostieken. Tik op de ster om favorieten te volgen. De vlag toont de getipte eindwinnaar. De groen-getinte rijen zijn de prijsplaatsen (top 5). Zoek hieronder op naam." />
  </SectionHeading>
  <RankingTable client:load rows={rows} searchable />
</Layout>
