---
import Layout from '@/layouts/Layout.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import PageHeader from '@/components/PageHeader.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { settings } from '@/lib/data';
import { PRIZES } from '@/lib/prizes';
import { ROUND_LABELS, ROUND_ORDER, ROUND_DEADLINES, type RoundId } from '@/lib/types';
import { formatKickoff } from '@/lib/format';

// Single source of truth for prize money (src/lib/prizes.ts).
const prizeRows = Object.entries(PRIZES)
  .map(([pos, prize]) => ({ pos: Number(pos), prize }))
  .sort((a, b) => a.pos - b.pos);

// Multiplier per round (group ×1 … final ×5).
const multiplierRows = ROUND_ORDER.map((r) => ({
  label: ROUND_LABELS[r],
  mult: settings.multipliers[r],
  max: 9 * settings.multipliers[r],
}));

// What to hand in by when (one row per submission moment).
const submissions: { round: RoundId; what: string }[] = [
  { round: 'group', what: 'Alle groepswedstrijden (speeldag 1, 2 én 3) + de tornooivoorspellingen' },
  { round: 'r32', what: '1/16de finales' },
  { round: 'r16', what: '1/8ste finales' },
  { round: 'qf', what: 'Kwartfinales' },
  { round: 'sf', what: 'Halve finales' },
  { round: 'third', what: 'Troostfinale + finale' },
];
---
<Layout title="Reglement">
  <PageHeader title="Reglement">
    <InfoToggle text="De spelregels van de Rut Prono en wanneer je wat moet indienen." />
  </PageHeader>

  <!-- Puntenverdeling -->
  <section class="mb-8">
    <SectionHeading title="Puntenverdeling per wedstrijd" />
    <div class="space-y-2 rounded-xl border bg-card p-4 text-sm leading-relaxed">
      <p>Het is de bedoeling de uitslag zo correct mogelijk te voorspellen. Enkel de winnaar aanduiden is niet genoeg. Per wedstrijd zijn er maximaal <strong>9 punten</strong> te verdienen:</p>
      <ul class="ml-1 space-y-1.5">
        <li class="flex gap-2"><span class="w-10 shrink-0 text-center font-bold tabular-nums text-emerald-700">9</span><span>Exacte uitslag juist.</span></li>
        <li class="flex gap-2"><span class="w-10 shrink-0 whitespace-nowrap text-center font-bold tabular-nums text-amber-700">3–7</span><span>Juiste winnaar (of gelijkspel): <strong>7 punten min het aantal goals dat je ernaast zit</strong>, met een minimum van 3.</span></li>
        <li class="flex gap-2"><span class="w-10 shrink-0 text-center font-bold tabular-nums text-red-700">0</span><span>Verkeerde winnaar → geen punten.</span></li>
      </ul>
      <p class="text-muted-foreground">Bij verlengingen telt de stand na 120 minuten. Strafschoppenreeksen tellen niet mee.</p>
    </div>
  </section>

  <!-- Multipliers -->
  <section class="mb-8">
    <SectionHeading title="Punten per ronde" />
    <p class="mb-2 text-sm text-muted-foreground">Hoe verder in het tornooi, hoe zwaarder de punten tellen.</p>
    <div class="overflow-hidden rounded-xl border bg-card">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-muted-foreground">
            <th class="px-3 py-2 text-left font-medium">Ronde</th>
            <th class="px-3 py-2 text-center font-medium">Factor</th>
            <th class="px-3 py-2 text-right font-medium">Max. punten</th>
          </tr>
        </thead>
        <tbody>
          {multiplierRows.map((r) => (
            <tr class="border-b last:border-0">
              <td class="px-3 py-2.5 font-medium">{r.label}</td>
              <td class="px-3 py-2.5 text-center tabular-nums">×{r.mult}</td>
              <td class="px-3 py-2.5 text-right font-bold tabular-nums">{r.max}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Bonus -->
  <section class="mb-8">
    <SectionHeading title="Bonusvoorspellingen" />
    <div class="rounded-xl border bg-card p-4 text-sm leading-relaxed">
      <p class="mb-2">Op het eerste pronostiekblad voorspel je ook 4 zaken over het hele tornooi. Elk juist = <strong>{settings.bonusPoints} punten</strong>:</p>
      <ul class="ml-4 list-disc space-y-1">
        <li>Topschutter</li>
        <li>Eindwinnaar</li>
        <li>Land met de meeste gemaakte doelpunten</li>
        <li>Land met de meeste tegendoelpunten</li>
      </ul>
      <p class="mt-2 text-muted-foreground">Doelpunten in de verlengingen tellen mee. Strafschoppenreeksen niet.</p>
    </div>
  </section>

  <!-- Deadlines -->
  <section class="mb-8">
    <SectionHeading title="Wanneer wat indienen?" />
    <p class="mb-2 text-sm text-muted-foreground">Telkens ten laatste 1 uur vóór de eerste wedstrijd van de ronde (Belgische tijd).</p>
    <div class="overflow-hidden rounded-xl border bg-card">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-muted-foreground">
            <th class="px-3 py-2 text-left font-medium">In te dienen</th>
            <th class="px-3 py-2 text-right font-medium">Deadline</th>
          </tr>
        </thead>
        <tbody>
          {submissions.map((s) => (
            <tr class="border-b last:border-0">
              <td class="px-3 py-2.5">{s.what}</td>
              <td class="px-3 py-2.5 text-right font-semibold tabular-nums whitespace-nowrap">{formatKickoff(ROUND_DEADLINES[s.round])}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Prijzengeld -->
  <section class="mb-8">
    <SectionHeading title="Prijzengeld" />
    <p class="mb-2 text-sm text-muted-foreground">De eerste vijf in het eindklassement winnen een prijs.</p>
    <div class="overflow-hidden rounded-xl border bg-card">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-muted-foreground">
            <th class="px-3 py-2 text-left font-medium">Plaats</th>
            <th class="px-3 py-2 text-right font-medium">Prijs</th>
          </tr>
        </thead>
        <tbody>
          {prizeRows.map(({ pos, prize }) => (
            <tr class="border-b last:border-0">
              <td class="px-3 py-2.5 font-medium">{pos}<sup>e</sup> plaats</td>
              <td class="px-3 py-2.5 text-right font-bold tabular-nums">€{prize}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-sm text-muted-foreground">Eindigen er meerdere deelnemers ex aequo op dezelfde plaats, dan wordt het prijzengeld van die plaatsen samengeteld en gelijk onder hen verdeeld.</p>
  </section>

  <!-- Deelname & indienen -->
  <section>
    <SectionHeading title="Deelname & indienen" />
    <div class="space-y-2 rounded-xl border bg-card p-4 text-sm leading-relaxed">
      <p><strong>Inzet:</strong> €10, te betalen aan den toog in café De Rut. Inschrijven kan enkel in het café. Je deelname is pas geldig na afgifte van de groepsbladen én betaling.</p>
      <p><strong>Groepsfase:</strong> alle pronostieken van de groepswedstrijden breng je <strong>op papier</strong> binnen in De Rut, vóór de start van het WK.</p>
      <p><strong>Vanaf de knock-outfase:</strong> op papier in de box aan den toog, of als een duidelijke foto via WhatsApp naar <strong>0478 64 77 06</strong> (Hakke). Zet je naam steeds op de foto.</p>
      <p class="text-muted-foreground">Te laat ingediend = 0 punten voor de reeds gestarte wedstrijden. Eenmaal ingediend kan een blad niet meer aangepast worden.</p>
    </div>
  </section>

  <!-- Geldig klassement -->
  <section class="mt-8">
    <div class="rounded-xl border border-amber-300/60 bg-amber-50 p-4 text-sm leading-relaxed text-amber-950 dark:bg-amber-950/20 dark:text-amber-100">
      <p><strong>Let op:</strong> het klassement op deze website is informatief. Enkel het <strong>officiële klassement dat in de WhatsApp-groep</strong> wordt gedeeld, is geldig.</p>
    </div>
  </section>
</Layout>
