---
import Layout from '@/layouts/Layout.astro';
import MatchCard from '@/components/MatchCard.astro';
import { matches } from '@/lib/data';
import { ROUND_LABELS, type RoundId } from '@/lib/types';

const KO_ROUNDS: RoundId[] = ['r32', 'r16', 'qf', 'sf', 'third', 'final'];
const byRound = KO_ROUNDS
  .map((round) => ({
    round,
    items: matches.filter((m) => m.round === round).sort((a, b) => a.kickoff.localeCompare(b.kickoff)),
  }))
  .filter((g) => g.items.length > 0);
---
<Layout title="Knock-outfase">
  <h1 class="mb-1 text-2xl font-bold tracking-tight">Knock-outfase</h1>
  <p class="mb-5 text-sm text-muted-foreground">Het schema vult zich met landen naarmate de resultaten bekend zijn.</p>

  <div class="space-y-6">
    {byRound.map((g) => (
      <section>
        <h2 class="mb-2 text-lg font-semibold">{ROUND_LABELS[g.round]}</h2>
        <div class="space-y-2">
          {g.items.map((m) => <MatchCard match={m} href={`/wedstrijd/${m.id}`} />)}
        </div>
      </section>
    ))}
  </div>
</Layout>
