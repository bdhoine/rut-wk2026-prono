---
import Layout from '@/layouts/Layout.astro';
import HomeHero from '@/components/HomeHero.astro';
import RankingTable from '@/components/RankingTable.tsx';
import LiveScores from '@/components/LiveScores.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import MovementSection from '@/components/MovementSection.astro';
import { ranking, getParticipant, getTeam, participantForm } from '@/lib/data';

const rows = ranking().map((r) => {
  const winner = getTeam(getParticipant(r.participantId)?.bonus.winnerTeamId);
  return {
    position: r.position,
    participantId: r.participantId,
    name: r.name,
    total: r.total,
    matchPoints: r.matchPoints,
    bonusPoints: r.bonusPoints,
    winnerIso: winner?.iso ?? null,
    winnerName: winner?.name ?? null,
    form: participantForm(r.participantId, 5),
  };
});
---
<Layout title="Rut Prono WK 2026">
  <HomeHero />
  <LiveScores mode="list" />
  <SectionHeading title="Klassement">
    <InfoToggle text="Tik op een deelnemer voor zijn pronostieken. Tik op de ster om favorieten te volgen. De vlag toont de getipte eindwinnaar. Een muntje markeert de prijsplaatsen (top 5) — tik erop voor het bedrag. Klassement en resultaten updaten niet meteen na een wedstrijd — dit kan even duren." />
  </SectionHeading>
  <RankingTable client:load rows={rows} limit={10} moreHref="/klassement" />

  <div class="mt-8">
    <MovementSection />
  </div>

  <a
    href="/statistieken"
    id="stats-cta"
    class="mt-8 flex items-center justify-center gap-1.5 rounded-lg border bg-card px-4 py-2.5 text-sm font-semibold transition-colors hover:bg-muted"
  >
    Bekijk de statistieken
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
  </a>

  <script>
    document.getElementById('stats-cta')?.addEventListener('click', () => {
      (window as unknown as { posthog?: { capture: (e: string) => void } }).posthog?.capture('statistics_cta_clicked');
    });
  </script>
</Layout>
