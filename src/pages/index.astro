---
import Layout from '@/layouts/Layout.astro';
import HomeHero from '@/components/HomeHero.astro';
import RankingTable from '@/components/RankingTable.tsx';
import LiveScores from '@/components/LiveScores.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import MovementSection from '@/components/MovementSection.astro';
import { ranking, getParticipant, getTeam, participantForm, recapData } from '@/lib/data';
import { SUPPORT_HREF } from '@/lib/links';

// Once the final has a result in the committed data (the site rebuilds when
// the results bot commits it), the recap is "live": the replay + pint buttons
// render visible for everyone. Before that they only appear for visitors who
// already saw the recap (QA via ?ff-recap=1), revealed by the script below.
const recapReady = recapData().champion !== null;

const rows = ranking().map((r) => {
  const winner = getTeam(getParticipant(r.participantId)?.bonus.winnerTeamId);
  return {
    position: r.position,
    participantId: r.participantId,
    name: r.name,
    total: r.total,
    matchPoints: r.matchPoints,
    bonusPoints: r.bonusPoints,
    winnerIso: winner?.iso ?? null,
    winnerName: winner?.name ?? null,
    form: participantForm(r.participantId, 5),
  };
});
---
<Layout title="Rut Prono WK 2026">
  <HomeHero />

  <div id="recap-cta" hidden={!recapReady} class="mb-6 flex flex-col gap-2">
    <button
      type="button"
      id="recap-replay"
      class="flex w-full items-center justify-center gap-1.5 rounded-lg border bg-card px-4 py-2.5 text-sm font-semibold transition-colors hover:bg-muted"
    >
      🏆 Toon Rut Prono WK 2026 recap
    </button>
    <a
      href={SUPPORT_HREF}
      class="flex w-full items-center justify-center gap-1.5 rounded-lg border bg-card px-4 py-2.5 text-sm font-semibold transition-colors hover:bg-muted"
    >
      🍺 Trakteer op een pint
    </a>
  </div>
  <script>
    // Before the final is played the block only appears once the recap has
    // actually been shown (localStorage flag set by Recap.tsx on close), and
    // reveals itself live if the recap is dismissed while already on this
    // page — no reload needed. Once the rebuilt site marks the recap ready,
    // the block is visible from the start (no `hidden` attribute).
    const cta = document.getElementById('recap-cta');
    const btn = document.getElementById('recap-replay') as HTMLButtonElement | null;
    if (cta && btn) {
      const SEEN_KEY = 'rut-wk2026-recap-seen';
      const reveal = () => { try { if (localStorage.getItem(SEEN_KEY)) cta.hidden = false; } catch { /* ignore */ } };
      if (cta.hidden) { reveal(); window.addEventListener('rut:recap-seen', reveal); }
      btn.addEventListener('click', () => {
        (window as unknown as { posthog?: { capture: (e: string) => void } }).posthog?.capture('recap_replay_clicked');
        window.dispatchEvent(new CustomEvent('rut:open-recap'));
      });
    }
  </script>

  <LiveScores mode="list" />
  <SectionHeading title="Klassement">
    <InfoToggle text="Tik op een deelnemer voor zijn pronostieken. Tik op de ster om favorieten te volgen. De vlag toont de getipte eindwinnaar. Een muntje markeert de prijsplaatsen (top 5) — tik erop voor het bedrag. Klassement en resultaten updaten niet meteen na een wedstrijd — dit kan even duren." />
  </SectionHeading>
  <RankingTable client:load rows={rows} limit={10} moreHref="/klassement" favCompareHref="/favorieten" />

  <div class="mt-8">
    <MovementSection />
  </div>

  <a
    href="/statistieken"
    id="stats-cta"
    class="mt-8 flex items-center justify-center gap-1.5 rounded-lg border bg-card px-4 py-2.5 text-sm font-semibold transition-colors hover:bg-muted"
  >
    Bekijk de statistieken
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
  </a>

  <script>
    document.getElementById('stats-cta')?.addEventListener('click', () => {
      (window as unknown as { posthog?: { capture: (e: string) => void } }).posthog?.capture('statistics_cta_clicked');
    });
  </script>
</Layout>
