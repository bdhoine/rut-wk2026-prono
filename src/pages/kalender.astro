---
import Layout from '@/layouts/Layout.astro';
import MatchCard from '@/components/MatchCard.astro';
import DeadlineBadge from '@/components/DeadlineBadge.astro';
import LiveScores from '@/components/LiveScores.astro';
import { matches } from '@/lib/data';
import { ROUND_LABELS, type RoundId } from '@/lib/types';

const byKickoff = (a: { kickoff: string }, b: { kickoff: string }) => a.kickoff.localeCompare(b.kickoff);

// Group stage split per matchday (speeldag).
const matchdays = [1, 2, 3].map((md) => ({
  md,
  items: matches.filter((m) => m.round === 'group' && m.matchday === md).sort(byKickoff),
}));

// Knockout rounds, each its own section.
const KO_ROUNDS: RoundId[] = ['r32', 'r16', 'qf', 'sf', 'third', 'final'];
const koRounds = KO_ROUNDS
  .map((round) => ({ round, items: matches.filter((m) => m.round === round).sort(byKickoff) }))
  .filter((g) => g.items.length > 0);
---
<Layout title="Kalender">
  <h1 class="mb-5 text-2xl font-bold tracking-tight">Kalender</h1>
  <LiveScores />

  <section class="mb-8">
    <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-lg font-semibold">{ROUND_LABELS.group}</h2>
      <DeadlineBadge round="group" />
    </div>
    <div class="space-y-5">
      {matchdays.map((d) => (
        <div>
          <h3 class="mb-2 text-sm font-semibold text-muted-foreground">Speeldag {d.md}</h3>
          <div class="space-y-2">
            {d.items.map((m) => <MatchCard match={m} href={`/wedstrijd/${m.id}`} />)}
          </div>
        </div>
      ))}
    </div>
  </section>

  {koRounds.map((g) => (
    <section class="mb-8">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-lg font-semibold">{ROUND_LABELS[g.round]}</h2>
        <DeadlineBadge round={g.round} />
      </div>
      <div class="space-y-2">
        {g.items.map((m) => <MatchCard match={m} href={`/wedstrijd/${m.id}`} />)}
      </div>
    </section>
  ))}
</Layout>
