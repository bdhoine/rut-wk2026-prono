---
import Layout from '@/layouts/Layout.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import KnockoutBracket from '@/components/KnockoutBracket.astro';
import MatchCard from '@/components/MatchCard.astro';
import DeadlineBadge from '@/components/DeadlineBadge.astro';
import LiveScores from '@/components/LiveScores.astro';
import PageHeader from '@/components/PageHeader.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { matches } from '@/lib/data';
import { byKickoff, formatDay } from '@/lib/format';
import { ROUND_LABELS, type RoundId } from '@/lib/types';
import type { Match } from '@/lib/types';

// Group a sorted match list by calendar day (Belgian time) for day subheadings.
const byDay = (items: Match[]): [string, Match[]][] => {
  const map = new Map<string, Match[]>();
  for (const m of items) {
    const day = formatDay(m.kickoff);
    if (!map.has(day)) map.set(day, []);
    map.get(day)!.push(m);
  }
  return [...map.entries()];
};

// Group stage split per matchday (speeldag).
const matchdays = [1, 2, 3].map((md) => ({
  md,
  days: byDay(matches.filter((m) => m.round === 'group' && m.matchday === md).sort(byKickoff)),
}));

// Knockout rounds, each its own section.
const KO_ROUNDS: RoundId[] = ['r32', 'r16', 'qf', 'sf', 'third', 'final'];
const koRounds = KO_ROUNDS
  .map((round) => ({ round, days: byDay(matches.filter((m) => m.round === round).sort(byKickoff)) }))
  .filter((g) => g.days.length > 0);

// Every stage is a collapsible <details>; only the stage in progress (the
// first not fully played) is open — finished stages collapse automatically,
// future ones start collapsed too. When everything is played, the last stage
// stays open (same pattern as the speeldag sections on deelnemer/[id]).
const stageStats = (round: RoundId) => {
  const items = matches.filter((m) => m.round === round);
  return { total: items.length, finished: items.filter((m) => m.status === 'finished').length };
};
const stageKeys: RoundId[] = ['group', ...koRounds.map((g) => g.round)];
const stats = new Map(stageKeys.map((r) => [r, stageStats(r)]));
const openKey = stageKeys.find((r) => stats.get(r)!.finished < stats.get(r)!.total) ?? stageKeys[stageKeys.length - 1];
---
<Layout title="Kalender">
  <PageHeader title="Kalender" />
  <LiveScores />

  {koRounds.length > 0 && (
    <section class="mb-8">
      <SectionHeading title="Knock-outschema">
        <InfoToggle text="De weg naar de finale: van de 1/16de finales aan de buitenkant naar de finale in het midden. De winnaar van elke wedstrijd is goud gemarkeerd. Tik op een wedstrijd voor de uitslag, details en pronostieken." />
      </SectionHeading>
      <KnockoutBracket />
    </section>
  )}

  <SectionHeading title="Wedstrijden" />
  <div class="space-y-3">
    <details open={openKey === 'group'} class="group rounded-xl border bg-card shadow-sm">
      <summary class="flex cursor-pointer select-none flex-col gap-1.5 rounded-xl px-4 py-3 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden">
        <span class="flex items-center gap-2">
          <span class="font-medium">{ROUND_LABELS.group}</span>
          <span class="ml-auto text-sm font-normal tabular-nums text-muted-foreground">{stats.get('group')!.finished}/{stats.get('group')!.total} gespeeld</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180"><path d="m6 9 6 6 6-6" /></svg>
        </span>
        <DeadlineBadge round="group" class="self-start" />
      </summary>
      <div class="space-y-5 px-3 pb-3 sm:px-4">
        {matchdays.map((d) => (
          <div>
            <h3 class="mb-2 text-sm font-semibold text-muted-foreground">Speeldag {d.md}</h3>
            <div class="space-y-4">
              {d.days.map(([day, items]) => (
                <div>
                  <h4 class="mb-1.5 text-xs font-semibold uppercase tracking-wide text-muted-foreground">{day}</h4>
                  <div class="space-y-1.5">
                    {items.map((m) => <MatchCard match={m} compact href={`/wedstrijd/${m.id}`} />)}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </details>

    {koRounds.map((g) => (
      <details open={openKey === g.round} class="group rounded-xl border bg-card shadow-sm">
        <summary class="flex cursor-pointer select-none flex-col gap-1.5 rounded-xl px-4 py-3 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden">
          <span class="flex items-center gap-2">
            <span class="font-medium">{ROUND_LABELS[g.round]}</span>
            <span class="ml-auto text-sm font-normal tabular-nums text-muted-foreground">{stats.get(g.round)!.finished}/{stats.get(g.round)!.total} gespeeld</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180"><path d="m6 9 6 6 6-6" /></svg>
          </span>
          <DeadlineBadge round={g.round} class="self-start" />
        </summary>
        <div class="space-y-4 px-3 pb-3 sm:px-4">
          {g.days.map(([day, items]) => (
            <div>
              <h4 class="sticky top-16 z-10 -mx-1 mb-1.5 rounded bg-card/95 px-1 py-1.5 text-xs font-semibold uppercase tracking-wide text-muted-foreground backdrop-blur">{day}</h4>
              <div class="space-y-1.5">
                {items.map((m) => <MatchCard match={m} compact href={`/wedstrijd/${m.id}`} />)}
              </div>
            </div>
          ))}
        </div>
      </details>
    ))}
  </div>
</Layout>
