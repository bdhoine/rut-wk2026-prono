---
import Layout from '@/layouts/Layout.astro';
import MatchCard from '@/components/MatchCard.astro';
import DeadlineBadge from '@/components/DeadlineBadge.astro';
import LiveScores from '@/components/LiveScores.astro';
import PageHeader from '@/components/PageHeader.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { matches } from '@/lib/data';
import { byKickoff, formatDay } from '@/lib/format';
import { ROUND_LABELS, type RoundId } from '@/lib/types';
import type { Match } from '@/lib/types';

// Group a sorted match list by calendar day (Belgian time) for day subheadings.
const byDay = (items: Match[]): [string, Match[]][] => {
  const map = new Map<string, Match[]>();
  for (const m of items) {
    const day = formatDay(m.kickoff);
    if (!map.has(day)) map.set(day, []);
    map.get(day)!.push(m);
  }
  return [...map.entries()];
};

// Group stage split per matchday (speeldag).
const matchdays = [1, 2, 3].map((md) => ({
  md,
  days: byDay(matches.filter((m) => m.round === 'group' && m.matchday === md).sort(byKickoff)),
}));

// Knockout rounds, each its own section.
const KO_ROUNDS: RoundId[] = ['r32', 'r16', 'qf', 'sf', 'third', 'final'];
const koRounds = KO_ROUNDS
  .map((round) => ({ round, days: byDay(matches.filter((m) => m.round === round).sort(byKickoff)) }))
  .filter((g) => g.days.length > 0);
---
<Layout title="Kalender">
  <PageHeader title="Kalender" />
  <LiveScores />

  <section class="mb-8">
    <SectionHeading title={ROUND_LABELS.group}>
      <DeadlineBadge round="group" />
    </SectionHeading>
    <div class="space-y-5">
      {matchdays.map((d) => (
        <div>
          <h3 class="mb-2 text-sm font-semibold text-muted-foreground">Speeldag {d.md}</h3>
          <div class="space-y-4">
            {d.days.map(([day, items]) => (
              <div>
                <h4 class="mb-1.5 text-xs font-semibold uppercase tracking-wide text-muted-foreground">{day}</h4>
                <div class="space-y-1.5">
                  {items.map((m) => <MatchCard match={m} compact href={`/wedstrijd/${m.id}`} />)}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  {koRounds.map((g) => (
    <section class="mb-8">
      <SectionHeading title={ROUND_LABELS[g.round]}>
        <DeadlineBadge round={g.round} />
      </SectionHeading>
      <div class="space-y-4">
        {g.days.map(([day, items]) => (
          <div>
            <h4 class="sticky top-16 z-10 -mx-1 mb-1.5 bg-background/95 px-1 py-1.5 text-xs font-semibold uppercase tracking-wide text-muted-foreground backdrop-blur">{day}</h4>
            <div class="space-y-1.5">
              {items.map((m) => <MatchCard match={m} compact href={`/wedstrijd/${m.id}`} />)}
            </div>
          </div>
        ))}
      </div>
    </section>
  ))}
</Layout>
