---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import MatchStatRow from '@/components/MatchStatRow.astro';
import ScoreBoxes from '@/components/ScoreBoxes.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import PageHeader from '@/components/PageHeader.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BestFormCard from '@/components/BestFormCard.astro';
import { topScorers, mostGoalsScored, mostGoalsConceded, topMatchesByPoints, topMatchesByWrong, topChosenWinners, topChosenTopScorers, popularScorelines, pickedTopScorerSlugs, topCorrectOutcomes, topExactScores, bonusStandings, bestForm, longestOutcomeStreak, longestExactStreak } from '@/lib/data';
import type { BonusPicks } from '@/lib/types';

const scorers = topScorers();
// Slug per picked top scorer -> link those names to their profile page.
const pickedSlugs = pickedTopScorerSlugs();
const scored = mostGoalsScored();
const conceded = mostGoalsConceded();
// Hide all-zero rows of teams that haven't played yet behind "Toon alle"
// (early in the tournament they're just alphabetical noise).
const anyPlayed = scored.some((t) => t.played > 0);
const goalRowHidden = (t: { played: number }, i: number) => i >= 10 || (anyPlayed && t.played === 0);
const topPoints = topMatchesByPoints(10);
const topWrong = topMatchesByWrong(10);
// Participants by number of correct 1X2 predictions (top 5 + "Toon alle").
const correctOutcomes = topCorrectOutcomes();
const anyOutcomePlayed = correctOutcomes.some((r) => r.played > 0);
// Participants by number of fully-correct (exact-score) predictions.
const exactScores = topExactScores();
const anyExactPlayed = exactScores.some((r) => r.played > 0);
// Best form: highest points total over any 5 consecutive played matches (all
// tied toppers, cycled in a carousel).
const FORM_WINDOW = 5;
const bestFormers = bestForm(FORM_WINDOW);
// Longest run of consecutive correct 1X2 / exact predictions.
const outcomeStreaks = longestOutcomeStreak();
const exactStreaks = longestExactStreak();
const anyStreakPlayed = outcomeStreaks.some((r) => r.played > 0);
// Show the top 5 by default; the rest is revealed with a "Toon alle" button.
const chosenWinners = topChosenWinners(Infinity);
const chosenScorers = topChosenTopScorers(Infinity);
const popular = popularScorelines(8);
const popularMax = popular[0]?.count ?? 1;
// Provisional bonus standings (decided at the final; this is the live picture).
const bonusRows = bonusStandings();
const BONUS_COLS: { key: keyof BonusPicks; short: string; title: string }[] = [
  { key: 'winnerTeamId', short: 'W', title: 'Eindwinnaar' },
  { key: 'topScorer', short: 'T', title: 'Topschutter' },
  { key: 'mostScoredTeamId', short: 'D+', title: 'Meeste doelpunten' },
  { key: 'mostConcededTeamId', short: 'D−', title: 'Meeste tegendoelpunten' },
];
---
<Layout title="Statistieken">
  <PageHeader title="Statistieken">
    <InfoToggle text="Doelpunten in de verlengingen tellen mee. Strafschoppenreeksen niet." />
  </PageHeader>

  <section class="mb-8">
    <SectionHeading title="Topschutters" />
    <div class="overflow-x-auto rounded-xl border bg-card">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-muted-foreground">
            <th class="w-6 px-2 py-2 text-left font-medium">#</th>
            <th class="px-2 py-2 text-left font-medium">Speler</th>
            <th class="px-2 py-2 text-left font-medium">Land</th>
            <th class="px-2 py-2 text-center font-medium">Goals</th>
          </tr>
        </thead>
        <tbody>
          {scorers.map((s, i) => (
            <tr class:list={['border-b last:border-0', i >= 10 && 'more-row hidden']}>
              <td class="px-2 py-2.5 tabular-nums text-muted-foreground">{i + 1}</td>
              <td class="px-2 py-2.5 font-medium">
                {pickedSlugs.has(s.player)
                  ? <a href={`/topschutter/${pickedSlugs.get(s.player)}`} class="hover:underline">{s.player}</a>
                  : s.player}
              </td>
              <td class="px-2 py-2.5">
                {s.team ? (
                  <a href={`/land/${s.team.id}`} class="flex items-center gap-2 hover:underline">
                    <Flag iso={s.team.iso} name={s.team.name} class="text-base" />
                    <span>{s.team.name}</span>
                  </a>
                ) : '—'}
              </td>
              <td class="px-2 py-2.5 text-center font-bold tabular-nums">{s.goals}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    {scorers.length > 10 && (
      <div class="mt-3 flex justify-center">
        <button type="button" data-show-more data-label={`Toon alle ${scorers.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
          <span data-more-label>Toon alle {scorers.length}</span>
          <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
        </button>
      </div>
    )}
  </section>

  <div class="grid gap-8 md:grid-cols-2">
    <section>
      <SectionHeading title="Meeste doelpunten" />
      <div class="overflow-x-auto rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="px-2 py-2 text-left font-medium">Land</th>
              <th class="px-2 py-2 text-center font-medium">Voor</th>
            </tr>
          </thead>
          <tbody>
            {scored.map((t, i) => (
              <tr class:list={['border-b last:border-0', goalRowHidden(t, i) && 'more-row hidden']}>
                <td class="px-2 py-2.5">
                  <a href={`/land/${t.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={t.team.iso} name={t.team.name} class="text-base" />
                    <span>{t.team.name}</span>
                  </a>
                </td>
                <td class="px-2 py-2.5 text-center font-bold tabular-nums">{t.scored}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {scored.length > 10 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${scored.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {scored.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>

    <section>
      <SectionHeading title="Meeste tegendoelpunten" />
      <div class="overflow-x-auto rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="px-2 py-2 text-left font-medium">Land</th>
              <th class="px-2 py-2 text-center font-medium">Tegen</th>
            </tr>
          </thead>
          <tbody>
            {conceded.map((t, i) => (
              <tr class:list={['border-b last:border-0', goalRowHidden(t, i) && 'more-row hidden']}>
                <td class="px-2 py-2.5">
                  <a href={`/land/${t.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={t.team.iso} name={t.team.name} class="text-base" />
                    <span>{t.team.name}</span>
                  </a>
                </td>
                <td class="px-2 py-2.5 text-center font-bold tabular-nums">{t.conceded}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {conceded.length > 10 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${conceded.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {conceded.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>
  </div>

  <section class="mt-8">
    <SectionHeading title="Top 10 — meeste punten">
      <InfoToggle text="Gemiddeld aantal punten dat deelnemers per wedstrijd scoorden." />
    </SectionHeading>
    <div class="space-y-2">
      {topPoints.map((s, i) => (
        <MatchStatRow match={s.match} rank={i + 1} metric={s.avg.toFixed(1)} metricClass="bg-emerald-200 text-emerald-800 dark:bg-emerald-950/60 dark:text-emerald-300" />
      ))}
    </div>
  </section>

  <section class="mt-8">
    <SectionHeading title="Top 10 — meeste foute prono's">
      <InfoToggle text="Aantal deelnemers met 0 punten voor de wedstrijd." />
    </SectionHeading>
    <div class="space-y-2">
      {topWrong.map((s, i) => (
        <MatchStatRow match={s.match} rank={i + 1} metric={String(s.wrong)} metricClass="bg-red-200 text-red-800 dark:bg-red-950/60 dark:text-red-300" />
      ))}
    </div>
  </section>

  {bestFormers.length > 0 && (
    <section class="mt-8">
      <SectionHeading title="Beste vorm">
        <InfoToggle text={`Wie het hoogste puntentotaal pakte over ${FORM_WINDOW} opeenvolgende gespeelde wedstrijden. Bolletjes: groen = exacte uitslag, oranje = juiste uitslag, rood = mis.`} />
      </SectionHeading>
      <BestFormCard entries={bestFormers} windowSize={FORM_WINDOW} />
    </section>
  )}

  <div class="mt-8 grid gap-8 md:grid-cols-2">
  {anyOutcomePlayed && (
    <section>
      <SectionHeading title="Meeste juiste 1X2">
        <InfoToggle text="Deelnemers met de meeste juiste 1X2-voorspellingen (juiste winnaar of gelijkspel) over alle gespeelde wedstrijden." />
      </SectionHeading>
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full table-fixed text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="w-10 px-2 py-2 text-center font-medium">#</th>
              <th class="px-2 py-2 text-left font-medium">Deelnemer</th>
              <th class="w-20 px-2 py-2 text-center font-medium" title="Juiste 1X2 / gespeeld">Juist</th>
            </tr>
          </thead>
          <tbody>
            {correctOutcomes.map((r, i) => (
              <tr class:list={['border-b last:border-0', i >= 5 && 'more-row hidden']}>
                <td class="w-6 px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
                <td class="px-2 py-2.5">
                  <div class="flex min-w-0 items-center gap-2">
                    {r.winnerIso && <Flag iso={r.winnerIso} name={r.winnerName ?? undefined} class="shrink-0 text-base" />}
                    <a href={`/deelnemer/${r.participantId}`} class="min-w-0 truncate font-medium hover:underline">{r.name}</a>
                    {r.position != null && (
                      <span class="inline-flex h-5 min-w-[1.4rem] shrink-0 items-center justify-center rounded bg-muted px-1 text-[11px] font-semibold tabular-nums text-muted-foreground" title="Plaats in het klassement">{r.position}</span>
                    )}
                  </div>
                </td>
                <td class="whitespace-nowrap px-2 py-2.5 text-center tabular-nums">
                  <span class="font-bold">{r.correct}</span><span class="text-muted-foreground"> / {r.played}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {correctOutcomes.length > 5 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${correctOutcomes.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {correctOutcomes.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>
  )}

  {anyExactPlayed && (
    <section>
      <SectionHeading title="Meeste exacte uitslagen">
        <InfoToggle text="Deelnemers met de meeste volledig juiste voorspellingen (exacte uitslag) over alle gespeelde wedstrijden." />
      </SectionHeading>
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full table-fixed text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="w-10 px-2 py-2 text-center font-medium">#</th>
              <th class="px-2 py-2 text-left font-medium">Deelnemer</th>
              <th class="w-20 px-2 py-2 text-center font-medium" title="Exacte uitslag / gespeeld">Exact</th>
            </tr>
          </thead>
          <tbody>
            {exactScores.map((r, i) => (
              <tr class:list={['border-b last:border-0', i >= 5 && 'more-row hidden']}>
                <td class="w-6 px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
                <td class="px-2 py-2.5">
                  <div class="flex min-w-0 items-center gap-2">
                    {r.winnerIso && <Flag iso={r.winnerIso} name={r.winnerName ?? undefined} class="shrink-0 text-base" />}
                    <a href={`/deelnemer/${r.participantId}`} class="min-w-0 truncate font-medium hover:underline">{r.name}</a>
                    {r.position != null && (
                      <span class="inline-flex h-5 min-w-[1.4rem] shrink-0 items-center justify-center rounded bg-muted px-1 text-[11px] font-semibold tabular-nums text-muted-foreground" title="Plaats in het klassement">{r.position}</span>
                    )}
                  </div>
                </td>
                <td class="whitespace-nowrap px-2 py-2.5 text-center tabular-nums">
                  <span class="font-bold">{r.correct}</span><span class="text-muted-foreground"> / {r.played}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {exactScores.length > 5 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${exactScores.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {exactScores.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>
  )}
  </div>

  {anyStreakPlayed && (
  <div class="mt-8 grid gap-8 md:grid-cols-2">
    <section>
      <SectionHeading title="Juiste uitslagen op een rij">
        <InfoToggle text="Langste reeks opeenvolgende juiste 1X2-voorspellingen (juiste winnaar of gelijkspel), in speelvolgorde. Een foute of te late voorspelling breekt de reeks." />
      </SectionHeading>
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full table-fixed text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="w-10 px-2 py-2 text-center font-medium">#</th>
              <th class="px-2 py-2 text-left font-medium">Deelnemer</th>
              <th class="w-20 px-2 py-2 text-center font-medium" title="Langste reeks juiste uitslagen op een rij">Op een rij</th>
            </tr>
          </thead>
          <tbody>
            {outcomeStreaks.map((r, i) => (
              <tr class:list={['border-b last:border-0', i >= 10 && 'more-row hidden']}>
                <td class="w-6 px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
                <td class="px-2 py-2.5">
                  <div class="flex min-w-0 items-center gap-2">
                    {r.winnerIso && <Flag iso={r.winnerIso} name={r.winnerName ?? undefined} class="shrink-0 text-base" />}
                    <a href={`/deelnemer/${r.participantId}`} class="min-w-0 truncate font-medium hover:underline">{r.name}</a>
                    {r.position != null && (
                      <span class="inline-flex h-5 min-w-[1.4rem] shrink-0 items-center justify-center rounded bg-muted px-1 text-[11px] font-semibold tabular-nums text-muted-foreground" title="Plaats in het klassement">{r.position}</span>
                    )}
                  </div>
                </td>
                <td class="whitespace-nowrap px-2 py-2.5 text-center font-bold tabular-nums">{r.correct}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {outcomeStreaks.length > 10 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${outcomeStreaks.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {outcomeStreaks.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>

    <section>
      <SectionHeading title="Exacte uitslagen op een rij">
        <InfoToggle text="Langste reeks opeenvolgende volledig juiste voorspellingen (exacte uitslag), in speelvolgorde. Een niet-exacte of te late voorspelling breekt de reeks." />
      </SectionHeading>
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full table-fixed text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="w-10 px-2 py-2 text-center font-medium">#</th>
              <th class="px-2 py-2 text-left font-medium">Deelnemer</th>
              <th class="w-20 px-2 py-2 text-center font-medium" title="Langste reeks exacte uitslagen op een rij">Op een rij</th>
            </tr>
          </thead>
          <tbody>
            {exactStreaks.map((r, i) => (
              <tr class:list={['border-b last:border-0', i >= 10 && 'more-row hidden']}>
                <td class="w-6 px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
                <td class="px-2 py-2.5">
                  <div class="flex min-w-0 items-center gap-2">
                    {r.winnerIso && <Flag iso={r.winnerIso} name={r.winnerName ?? undefined} class="shrink-0 text-base" />}
                    <a href={`/deelnemer/${r.participantId}`} class="min-w-0 truncate font-medium hover:underline">{r.name}</a>
                    {r.position != null && (
                      <span class="inline-flex h-5 min-w-[1.4rem] shrink-0 items-center justify-center rounded bg-muted px-1 text-[11px] font-semibold tabular-nums text-muted-foreground" title="Plaats in het klassement">{r.position}</span>
                    )}
                  </div>
                </td>
                <td class="whitespace-nowrap px-2 py-2.5 text-center font-bold tabular-nums">{r.correct}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {exactStreaks.length > 10 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${exactStreaks.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {exactStreaks.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>
  </div>
  )}

  {popular.length > 0 && (
    <section class="mt-8">
      <SectionHeading title="Populairste uitslagen">
        <InfoToggle text="De scores die deelnemers het vaakst tipten, over alle wedstrijden samen." />
      </SectionHeading>
      <div class="rounded-xl border bg-card p-4">
        <div class="space-y-2.5">
          {popular.map((s) => (
            <div class="flex items-center gap-3">
              <div class="shrink-0"><ScoreBoxes home={s.home} away={s.away} size="sm" /></div>
              <div class="h-2.5 flex-1 overflow-hidden rounded-full bg-muted">
                <div class="h-full rounded-full bg-gold" style={`width:${Math.round((s.count / popularMax) * 100)}%`}></div>
              </div>
              <span class="w-10 shrink-0 text-right text-sm font-bold tabular-nums">{s.count}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <div class="mt-8 grid gap-8 md:grid-cols-2">
    <section>
      <SectionHeading title="Meest getipte eindwinnaar" />
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="w-6 px-2 py-2 text-center font-medium">#</th>
              <th class="px-2 py-2 text-left font-medium">Land</th>
              <th class="px-2 py-2 text-center font-medium">Aantal</th>
            </tr>
          </thead>
          <tbody>
            {chosenWinners.map((w, i) => (
              <tr class:list={['border-b last:border-0', i >= 5 && 'more-row hidden']}>
                <td class="w-6 px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
                <td class="px-2 py-2.5">
                  <a href={`/land/${w.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={w.team.iso} name={w.team.name} class="shrink-0 text-base" />
                    <span class="truncate">{w.team.name}</span>
                  </a>
                </td>
                <td class="px-2 py-2.5 text-center font-bold tabular-nums">{w.count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {chosenWinners.length > 5 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${chosenWinners.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {chosenWinners.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>

    <section>
      <SectionHeading title="Meest getipte topschutter" />
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="w-6 px-2 py-2 text-center font-medium">#</th>
              <th class="px-2 py-2 text-left font-medium">Speler</th>
              <th class="w-14 px-2 py-2 text-center font-medium" title="Doelpunten op het WK">Goals</th>
              <th class="w-16 px-2 py-2 text-center font-medium" title="Aantal deelnemers dat hem tipte">Getipt</th>
            </tr>
          </thead>
          <tbody>
            {chosenScorers.map((s, i) => (
              <tr class:list={['border-b last:border-0', i >= 5 && 'more-row hidden']}>
                <td class="w-6 px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
                <td class="px-2 py-2.5">
                  <div class="flex items-center gap-2 font-medium">
                    {s.team && <Flag iso={s.team.iso} name={s.team.name} class="shrink-0 text-base" />}
                    {pickedSlugs.has(s.player)
                      ? <a href={`/topschutter/${pickedSlugs.get(s.player)}`} class="truncate hover:underline">{s.player}</a>
                      : <span class="truncate">{s.player}</span>}
                  </div>
                </td>
                <td class="px-2 py-2.5 text-center tabular-nums">{s.goals}</td>
                <td class="px-2 py-2.5 text-center font-bold tabular-nums">{s.count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {chosenScorers.length > 5 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${chosenScorers.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {chosenScorers.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>
  </div>

  <section class="mt-8">
    <SectionHeading title="Bonus — voorlopig op koers">
      <InfoToggle text="Voorlopige stand van de bonusvoorspellingen. Het vlaggetje toont de keuze: groene rand = staat nu op kop, rode (vage) rand = niet meer mogelijk, grijze rand = nog mogelijk. De eindwinnaar (W) blijft mogelijk tot het land is uitgeschakeld. T = topschutter, D+ = meeste doelpunten, D− = meeste tegendoelpunten. Bonuspunten worden pas na de finale definitief toegekend." />
    </SectionHeading>
    <div class="overflow-hidden rounded-xl border bg-card">
      <table class="w-full table-fixed text-sm">
        <colgroup>
          <col class="w-8" />
          <col />
          <col class="w-7" />
          <col class="w-7" />
          <col class="w-7" />
          <col class="w-7" />
          <col class="w-14" />
        </colgroup>
        <thead>
          <tr class="border-b text-muted-foreground">
            <th class="px-1 py-2 text-center font-medium">#</th>
            <th class="px-2 py-2 text-left font-medium">Deelnemer</th>
            {BONUS_COLS.map((c) => <th class="px-0.5 py-2 text-center font-medium" title={c.title}>{c.short}</th>)}
            <th class="px-1 py-2 text-center font-medium" title="Voorlopige bonuspunten">Bonus</th>
          </tr>
        </thead>
        <tbody>
          {bonusRows.map((row, i) => (
            <tr class:list={['border-b last:border-0', i >= 8 && 'more-row hidden']}>
              <td class="px-1 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
              <td class="px-2 py-2.5">
                <div class="flex min-w-0 items-center gap-2">
                  <a href={`/deelnemer/${row.participantId}`} class="min-w-0 truncate font-medium hover:underline">{row.name}</a>
                  <span class="inline-flex h-5 min-w-[1.4rem] shrink-0 items-center justify-center rounded bg-muted px-1 text-[11px] font-semibold tabular-nums text-muted-foreground" title="Plaats in het klassement">{row.position}</span>
                </div>
              </td>
              {BONUS_COLS.map((c) => {
                const cell = row.cells[c.key];
                const ring = cell.status === 'good' ? 'ring-2 ring-emerald-500'
                  : cell.status === 'bad' ? 'opacity-40 ring-1 ring-red-400'
                  : 'ring-1 ring-muted-foreground/30';
                const stTxt = cell.status === 'good' ? 'voorlopig juist' : cell.status === 'bad' ? 'niet meer mogelijk' : 'nog mogelijk';
                return (
                  <td class="px-0.5 py-2.5 text-center">
                    {cell.iso ? (
                      <span class:list={['inline-flex rounded-[3px]', ring]} title={`${cell.label} — ${stTxt}`}>
                        <Flag iso={cell.iso} name={cell.label} class="text-base" />
                      </span>
                    ) : (
                      <span class="text-muted-foreground/40" title={cell.label}>–</span>
                    )}
                  </td>
                );
              })}
              <td class="px-1 py-2.5 text-center font-bold tabular-nums">{row.provPoints}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    {bonusRows.length > 8 && (
      <div class="mt-3 flex justify-center">
        <button type="button" data-show-more data-label={`Toon alle ${bonusRows.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
          <span data-more-label>Toon alle {bonusRows.length}</span>
          <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
        </button>
      </div>
    )}
  </section>

  <script>
    document.querySelectorAll('[data-show-more]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const section = btn.closest('section');
        const rows = section?.querySelectorAll('.more-row');
        if (!rows?.length) return;
        const show = rows[0].classList.contains('hidden');
        rows.forEach((r) => r.classList.toggle('hidden', !show));
        btn.setAttribute('aria-expanded', String(show));
        const label = btn.querySelector('[data-more-label]');
        if (label) label.textContent = show ? 'Toon minder' : (btn.getAttribute('data-label') || 'Toon meer');
        btn.querySelector('[data-chevron]')?.classList.toggle('rotate-180', show);
      });
    });
  </script>

  <script is:inline>
    window.posthog?.capture('statistics_page_viewed');
  </script>
</Layout>
