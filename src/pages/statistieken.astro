---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import MatchStatRow from '@/components/MatchStatRow.astro';
import { topScorers, mostGoalsScored, mostGoalsConceded, topMatchesByPoints, topMatchesByWrong, topChosenWinners, topChosenTopScorers } from '@/lib/data';

const scorers = topScorers();
const scored = mostGoalsScored();
const conceded = mostGoalsConceded();
const topPoints = topMatchesByPoints(10);
const topWrong = topMatchesByWrong(10);
const chosenWinners = topChosenWinners(5);
const chosenScorers = topChosenTopScorers(5);
---
<Layout title="Statistieken">
  <h1 class="mb-1 text-2xl font-bold tracking-tight">Statistieken</h1>
  <p class="mb-6 text-sm text-muted-foreground">Doelpunten in de verlengingen tellen mee. Strafschoppenreeksen niet.</p>

  <section class="mb-8">
    <h2 class="mb-2 text-lg font-semibold">Topschutters</h2>
    <div class="overflow-x-auto rounded-xl border bg-card">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-muted-foreground">
            <th class="w-6 px-2 py-2 text-left font-medium">#</th>
            <th class="px-2 py-2 text-left font-medium">Speler</th>
            <th class="px-2 py-2 text-left font-medium">Land</th>
            <th class="px-2 py-2 text-right font-medium">Goals</th>
          </tr>
        </thead>
        <tbody>
          {scorers.map((s, i) => (
            <tr class:list={['border-b last:border-0', i >= 10 && 'more-row hidden']}>
              <td class="px-2 py-2 tabular-nums text-muted-foreground">{i + 1}</td>
              <td class="px-2 py-2 font-medium">{s.player}</td>
              <td class="px-2 py-2">
                {s.team ? (
                  <a href={`/land/${s.team.id}`} class="flex items-center gap-2 hover:underline">
                    <Flag iso={s.team.iso} name={s.team.name} class="text-base" />
                    <span>{s.team.name}</span>
                  </a>
                ) : '—'}
              </td>
              <td class="px-2 py-2 text-right font-bold tabular-nums">{s.goals}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    {scorers.length > 10 && (
      <button type="button" data-show-more data-label={`Toon alle ${scorers.length}`} class="mt-2 text-sm font-medium text-primary hover:underline">Toon alle {scorers.length}</button>
    )}
  </section>

  <div class="grid gap-8 md:grid-cols-2">
    <section>
      <h2 class="mb-2 text-lg font-semibold">Meeste doelpunten</h2>
      <div class="overflow-x-auto rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="px-2 py-2 text-left font-medium">Land</th>
              <th class="px-2 py-2 text-right font-medium">Voor</th>
            </tr>
          </thead>
          <tbody>
            {scored.map((t, i) => (
              <tr class:list={['border-b last:border-0', i >= 10 && 'more-row hidden']}>
                <td class="px-2 py-2">
                  <a href={`/land/${t.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={t.team.iso} name={t.team.name} class="text-base" />
                    <span>{t.team.name}</span>
                  </a>
                </td>
                <td class="px-2 py-2 text-right font-bold tabular-nums">{t.scored}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {scored.length > 10 && (
        <button type="button" data-show-more data-label={`Toon alle ${scored.length}`} class="mt-2 text-sm font-medium text-primary hover:underline">Toon alle {scored.length}</button>
      )}
    </section>

    <section>
      <h2 class="mb-2 text-lg font-semibold">Meeste tegendoelpunten</h2>
      <div class="overflow-x-auto rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="px-2 py-2 text-left font-medium">Land</th>
              <th class="px-2 py-2 text-right font-medium">Tegen</th>
            </tr>
          </thead>
          <tbody>
            {conceded.map((t, i) => (
              <tr class:list={['border-b last:border-0', i >= 10 && 'more-row hidden']}>
                <td class="px-2 py-2">
                  <a href={`/land/${t.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={t.team.iso} name={t.team.name} class="text-base" />
                    <span>{t.team.name}</span>
                  </a>
                </td>
                <td class="px-2 py-2 text-right font-bold tabular-nums">{t.conceded}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {conceded.length > 10 && (
        <button type="button" data-show-more data-label={`Toon alle ${conceded.length}`} class="mt-2 text-sm font-medium text-primary hover:underline">Toon alle {conceded.length}</button>
      )}
    </section>
  </div>

  <section class="mt-8">
    <h2 class="mb-1 text-lg font-semibold">Top 10 — meeste punten</h2>
    <p class="mb-2 text-xs text-muted-foreground">Gemiddeld aantal punten dat deelnemers per wedstrijd scoorden.</p>
    <div class="space-y-2">
      {topPoints.map((s, i) => (
        <MatchStatRow match={s.match} rank={i + 1} metric={s.avg.toFixed(1)} metricClass="bg-emerald-200 text-emerald-800 dark:bg-emerald-950/60 dark:text-emerald-300" />
      ))}
    </div>
  </section>

  <section class="mt-8">
    <h2 class="mb-1 text-lg font-semibold">Top 10 — meeste foute prono's</h2>
    <p class="mb-2 text-xs text-muted-foreground">Aantal deelnemers met 0 punten voor de wedstrijd.</p>
    <div class="space-y-2">
      {topWrong.map((s, i) => (
        <MatchStatRow match={s.match} rank={i + 1} metric={String(s.wrong)} metricClass="bg-red-200 text-red-800 dark:bg-red-950/60 dark:text-red-300" />
      ))}
    </div>
  </section>

  <div class="mt-8 grid gap-8 md:grid-cols-2">
    <section>
      <h2 class="mb-2 text-lg font-semibold">Meest getipte eindwinnaar</h2>
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full text-sm">
          <tbody>
            {chosenWinners.map((w, i) => (
              <tr class="border-b last:border-0">
                <td class="w-6 px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
                <td class="px-2 py-2.5">
                  <a href={`/land/${w.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={w.team.iso} name={w.team.name} class="shrink-0 text-base" />
                    <span class="truncate">{w.team.name}</span>
                  </a>
                </td>
                <td class="px-3 py-2.5 text-right font-bold tabular-nums">{w.count}×</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2 class="mb-2 text-lg font-semibold">Meest getipte topschutter</h2>
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full text-sm">
          <tbody>
            {chosenScorers.map((s, i) => (
              <tr class="border-b last:border-0">
                <td class="w-6 px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
                <td class="px-2 py-2.5">
                  <div class="flex items-center gap-2 font-medium">
                    {s.team && <Flag iso={s.team.iso} name={s.team.name} class="shrink-0 text-base" />}
                    <span class="truncate">{s.player}</span>
                  </div>
                </td>
                <td class="px-3 py-2.5 text-right font-bold tabular-nums">{s.count}×</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <script>
    document.querySelectorAll('[data-show-more]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const section = btn.closest('section');
        const rows = section?.querySelectorAll('.more-row');
        if (!rows?.length) return;
        const show = rows[0].classList.contains('hidden');
        rows.forEach((r) => r.classList.toggle('hidden', !show));
        btn.textContent = show ? 'Toon minder' : (btn.getAttribute('data-label') || 'Toon meer');
      });
    });
  </script>
</Layout>
