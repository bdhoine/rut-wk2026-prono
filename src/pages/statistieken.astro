---
import Layout from '@/layouts/Layout.astro';
import Flag from '@/components/Flag.astro';
import MatchStatRow from '@/components/MatchStatRow.astro';
import ScoreBoxes from '@/components/ScoreBoxes.astro';
import InfoToggle from '@/components/InfoToggle.astro';
import PageHeader from '@/components/PageHeader.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { topScorers, mostGoalsScored, mostGoalsConceded, topMatchesByPoints, topMatchesByWrong, topChosenWinners, topChosenTopScorers, popularScorelines } from '@/lib/data';

const scorers = topScorers();
const scored = mostGoalsScored();
const conceded = mostGoalsConceded();
// Hide all-zero rows of teams that haven't played yet behind "Toon alle"
// (early in the tournament they're just alphabetical noise).
const anyPlayed = scored.some((t) => t.played > 0);
const goalRowHidden = (t: { played: number }, i: number) => i >= 10 || (anyPlayed && t.played === 0);
const topPoints = topMatchesByPoints(10);
const topWrong = topMatchesByWrong(10);
// Show the top 5 by default; the rest is revealed with a "Toon alle" button.
const chosenWinners = topChosenWinners(Infinity);
const chosenScorers = topChosenTopScorers(Infinity);
const popular = popularScorelines(8);
const popularMax = popular[0]?.count ?? 1;
---
<Layout title="Statistieken">
  <PageHeader title="Statistieken">
    <InfoToggle text="Doelpunten in de verlengingen tellen mee. Strafschoppenreeksen niet." />
  </PageHeader>

  <section class="mb-8">
    <SectionHeading title="Topschutters" />
    <div class="overflow-x-auto rounded-xl border bg-card">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-muted-foreground">
            <th class="w-6 px-2 py-2 text-left font-medium">#</th>
            <th class="px-2 py-2 text-left font-medium">Speler</th>
            <th class="px-2 py-2 text-left font-medium">Land</th>
            <th class="px-2 py-2 text-center font-medium">Goals</th>
          </tr>
        </thead>
        <tbody>
          {scorers.map((s, i) => (
            <tr class:list={['border-b last:border-0', i >= 10 && 'more-row hidden']}>
              <td class="px-2 py-2.5 tabular-nums text-muted-foreground">{i + 1}</td>
              <td class="px-2 py-2.5 font-medium">{s.player}</td>
              <td class="px-2 py-2.5">
                {s.team ? (
                  <a href={`/land/${s.team.id}`} class="flex items-center gap-2 hover:underline">
                    <Flag iso={s.team.iso} name={s.team.name} class="text-base" />
                    <span>{s.team.name}</span>
                  </a>
                ) : '—'}
              </td>
              <td class="px-2 py-2.5 text-center font-bold tabular-nums">{s.goals}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    {scorers.length > 10 && (
      <div class="mt-3 flex justify-center">
        <button type="button" data-show-more data-label={`Toon alle ${scorers.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
          <span data-more-label>Toon alle {scorers.length}</span>
          <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
        </button>
      </div>
    )}
  </section>

  <div class="grid gap-8 md:grid-cols-2">
    <section>
      <SectionHeading title="Meeste doelpunten" />
      <div class="overflow-x-auto rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="px-2 py-2 text-left font-medium">Land</th>
              <th class="px-2 py-2 text-center font-medium">Voor</th>
            </tr>
          </thead>
          <tbody>
            {scored.map((t, i) => (
              <tr class:list={['border-b last:border-0', goalRowHidden(t, i) && 'more-row hidden']}>
                <td class="px-2 py-2.5">
                  <a href={`/land/${t.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={t.team.iso} name={t.team.name} class="text-base" />
                    <span>{t.team.name}</span>
                  </a>
                </td>
                <td class="px-2 py-2.5 text-center font-bold tabular-nums">{t.scored}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {scored.length > 10 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${scored.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {scored.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>

    <section>
      <SectionHeading title="Meeste tegendoelpunten" />
      <div class="overflow-x-auto rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="px-2 py-2 text-left font-medium">Land</th>
              <th class="px-2 py-2 text-center font-medium">Tegen</th>
            </tr>
          </thead>
          <tbody>
            {conceded.map((t, i) => (
              <tr class:list={['border-b last:border-0', goalRowHidden(t, i) && 'more-row hidden']}>
                <td class="px-2 py-2.5">
                  <a href={`/land/${t.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={t.team.iso} name={t.team.name} class="text-base" />
                    <span>{t.team.name}</span>
                  </a>
                </td>
                <td class="px-2 py-2.5 text-center font-bold tabular-nums">{t.conceded}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {conceded.length > 10 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${conceded.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {conceded.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>
  </div>

  <section class="mt-8">
    <SectionHeading title="Top 10 — meeste punten">
      <InfoToggle text="Gemiddeld aantal punten dat deelnemers per wedstrijd scoorden." />
    </SectionHeading>
    <div class="space-y-2">
      {topPoints.map((s, i) => (
        <MatchStatRow match={s.match} rank={i + 1} metric={s.avg.toFixed(1)} metricClass="bg-emerald-200 text-emerald-800 dark:bg-emerald-950/60 dark:text-emerald-300" />
      ))}
    </div>
  </section>

  <section class="mt-8">
    <SectionHeading title="Top 10 — meeste foute prono's">
      <InfoToggle text="Aantal deelnemers met 0 punten voor de wedstrijd." />
    </SectionHeading>
    <div class="space-y-2">
      {topWrong.map((s, i) => (
        <MatchStatRow match={s.match} rank={i + 1} metric={String(s.wrong)} metricClass="bg-red-200 text-red-800 dark:bg-red-950/60 dark:text-red-300" />
      ))}
    </div>
  </section>

  {popular.length > 0 && (
    <section class="mt-8">
      <SectionHeading title="Populairste uitslagen">
        <InfoToggle text="De scores die deelnemers het vaakst tipten, over alle wedstrijden samen." />
      </SectionHeading>
      <div class="rounded-xl border bg-card p-4">
        <div class="space-y-2.5">
          {popular.map((s) => (
            <div class="flex items-center gap-3">
              <div class="shrink-0"><ScoreBoxes home={s.home} away={s.away} size="sm" /></div>
              <div class="h-2.5 flex-1 overflow-hidden rounded-full bg-muted">
                <div class="h-full rounded-full bg-gold" style={`width:${Math.round((s.count / popularMax) * 100)}%`}></div>
              </div>
              <span class="w-10 shrink-0 text-right text-sm font-bold tabular-nums">{s.count}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <div class="mt-8 grid gap-8 md:grid-cols-2">
    <section>
      <SectionHeading title="Meest getipte eindwinnaar" />
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="w-6 px-2 py-2 text-center font-medium">#</th>
              <th class="px-2 py-2 text-left font-medium">Land</th>
              <th class="px-2 py-2 text-center font-medium">Aantal</th>
            </tr>
          </thead>
          <tbody>
            {chosenWinners.map((w, i) => (
              <tr class:list={['border-b last:border-0', i >= 5 && 'more-row hidden']}>
                <td class="w-6 px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
                <td class="px-2 py-2.5">
                  <a href={`/land/${w.team.id}`} class="flex items-center gap-2 font-medium hover:underline">
                    <Flag iso={w.team.iso} name={w.team.name} class="shrink-0 text-base" />
                    <span class="truncate">{w.team.name}</span>
                  </a>
                </td>
                <td class="px-2 py-2.5 text-center font-bold tabular-nums">{w.count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {chosenWinners.length > 5 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${chosenWinners.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {chosenWinners.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>

    <section>
      <SectionHeading title="Meest getipte topschutter" />
      <div class="overflow-hidden rounded-xl border bg-card">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-muted-foreground">
              <th class="w-6 px-2 py-2 text-center font-medium">#</th>
              <th class="px-2 py-2 text-left font-medium">Speler</th>
              <th class="px-2 py-2 text-center font-medium">Aantal</th>
            </tr>
          </thead>
          <tbody>
            {chosenScorers.map((s, i) => (
              <tr class:list={['border-b last:border-0', i >= 5 && 'more-row hidden']}>
                <td class="w-6 px-2 py-2.5 text-center tabular-nums text-muted-foreground">{i + 1}</td>
                <td class="px-2 py-2.5">
                  <div class="flex items-center gap-2 font-medium">
                    {s.team && <Flag iso={s.team.iso} name={s.team.name} class="shrink-0 text-base" />}
                    <span class="truncate">{s.player}</span>
                  </div>
                </td>
                <td class="px-2 py-2.5 text-center font-bold tabular-nums">{s.count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {chosenScorers.length > 5 && (
        <div class="mt-3 flex justify-center">
          <button type="button" data-show-more data-label={`Toon alle ${chosenScorers.length}`} aria-expanded="false" class="inline-flex items-center gap-1.5 rounded-full border bg-card px-4 py-2 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-more-label>Toon alle {chosenScorers.length}</span>
            <svg data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 transition-transform"><path d="m6 9 6 6 6-6" /></svg>
          </button>
        </div>
      )}
    </section>
  </div>

  <script>
    document.querySelectorAll('[data-show-more]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const section = btn.closest('section');
        const rows = section?.querySelectorAll('.more-row');
        if (!rows?.length) return;
        const show = rows[0].classList.contains('hidden');
        rows.forEach((r) => r.classList.toggle('hidden', !show));
        btn.setAttribute('aria-expanded', String(show));
        const label = btn.querySelector('[data-more-label]');
        if (label) label.textContent = show ? 'Toon minder' : (btn.getAttribute('data-label') || 'Toon meer');
        btn.querySelector('[data-chevron]')?.classList.toggle('rotate-180', show);
      });
    });
  </script>
</Layout>
