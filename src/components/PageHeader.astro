---
// Consistent page title row. Slot holds inline extras (InfoToggle, badges);
// keep them direct children: InfoToggle's help text relies on the flex-wrap
// row + its own `basis-full` to drop to a new line.
interface Props {
  title: string;
  eyebrow?: string;
}
const { title, eyebrow } = Astro.props;
---
<div class="mb-5 flex flex-wrap items-center gap-2">
  {eyebrow && <span class="basis-full font-display text-xs font-bold uppercase tracking-[0.2em] text-primary">{eyebrow}</span>}
  <h1 class="text-2xl font-extrabold tracking-tight">{title}</h1>
  <slot />
</div>
