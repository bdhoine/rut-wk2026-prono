---
// Section (h2) heading with the diagonally-cut gold bar. Slot holds inline
// extras (InfoToggle, DeadlineBadge) — same flex-wrap contract as PageHeader.
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<div class="mb-2 flex flex-wrap items-center gap-2">
  <span class="bar-cut" aria-hidden="true"></span>
  <h2 class="text-lg font-semibold">{title}</h2>
  <slot />
</div>
