---
import Flag from './Flag.astro';
import type { StandingRow } from '@/lib/data';

interface Props {
  rows: StandingRow[];
  highlightTop?: number; // rows with rank <= this are highlighted as qualifying
}
const { rows, highlightTop = 2 } = Astro.props;
// Only mark qualifying spots once the group has actual results — an all-zero
// table with green rows reads as a (meaningless) verdict.
const hasResults = rows.some((r) => r.played > 0);
---
<div class="overflow-hidden rounded-xl border bg-card">
  <table class="w-full table-fixed text-sm">
    <colgroup>
      <col class="w-7" />
      <col />
      <col class="w-6" />
      <col class="w-6" />
      <col class="w-6" />
      <col class="w-6" />
      <col class="w-9" />
      <col class="w-9" />
    </colgroup>
    <thead>
      <tr class="border-b text-muted-foreground">
        <th class="px-2 py-2 text-center font-medium">#</th>
        <th class="px-2 py-2 text-left font-medium">Land</th>
        <th class="py-2 text-center font-medium" title="Gespeeld">M</th>
        <th class="py-2 text-center font-medium" title="Winst">W</th>
        <th class="py-2 text-center font-medium" title="Gelijk">G</th>
        <th class="py-2 text-center font-medium" title="Verlies">V</th>
        <th class="py-2 text-center font-medium" title="Doelsaldo">+/-</th>
        <th class="px-2 py-2 text-center font-medium" title="Punten">Ptn</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((r) => (
        <tr class:list={['border-b last:border-0', hasResults && r.rank <= highlightTop && 'bg-emerald-50/70 dark:bg-emerald-950/30']}>
          <td class="px-2 py-2.5 text-center tabular-nums text-muted-foreground">{r.rank}</td>
          <td class="px-2 py-2.5">
            {/* Short name: this table renders in narrow contexts (390px mobile,
                half-width grid column on desktop). Full name lives on the land page. */}
            <a href={`/land/${r.team.id}`} data-standing-team={r.team.id} class="flex items-center gap-2 font-medium hover:underline">
              <Flag iso={r.team.iso} name={r.team.name} class="shrink-0 text-base" />
              <span class="truncate">{r.team.shortName ?? r.team.name}</span>
            </a>
          </td>
          <td class="py-2.5 text-center tabular-nums">{r.played}</td>
          <td class="py-2.5 text-center tabular-nums">{r.won}</td>
          <td class="py-2.5 text-center tabular-nums">{r.drawn}</td>
          <td class="py-2.5 text-center tabular-nums">{r.lost}</td>
          <td class="py-2.5 text-center tabular-nums">{r.goalDiff > 0 ? `+${r.goalDiff}` : r.goalDiff}</td>
          <td class="px-2 py-2.5 text-center font-bold tabular-nums">{r.points}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
