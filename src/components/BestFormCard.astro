---
// "Beste vorm" card: the participant(s) with the highest points total over any
// 5 consecutive played matches. When several share the top window, the card
// becomes a small carousel (left/right) cycling through them.
import Flag from './Flag.astro';
import type { BestFormRow } from '@/lib/data';

interface Props {
  entries: BestFormRow[];
  windowSize?: number;
}
const { entries, windowSize = 5 } = Astro.props;
const multi = entries.length > 1;
const arrow = 'grid size-8 place-items-center rounded-full border bg-card text-muted-foreground shadow-sm transition-colors hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring';
---
<div data-bestform class="rounded-xl border bg-card p-4 shadow-sm">
  <div class="relative">
    {multi && (
      <button type="button" data-bf-prev aria-label="Vorige" class:list={[arrow, 'absolute left-0 top-1/2 z-10 -translate-y-1/2']}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="m15 18-6-6 6-6" /></svg>
      </button>
    )}
    {multi && (
      <button type="button" data-bf-next aria-label="Volgende" class:list={[arrow, 'absolute right-0 top-1/2 z-10 -translate-y-1/2']}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="m9 18 6-6-6-6" /></svg>
      </button>
    )}
    {entries.map((e, i) => (
      <div data-bf-slide class:list={['flex flex-col items-center gap-1.5 px-9 text-center', i !== 0 && 'hidden']}>
        <div class="flex min-w-0 items-center gap-2">
          {e.winnerIso && <Flag iso={e.winnerIso} name={e.winnerName ?? undefined} class="shrink-0 text-base" />}
          <a href={`/deelnemer/${e.participantId}`} class="min-w-0 truncate font-semibold hover:underline">{e.name}</a>
          {e.position != null && (
            <span class="inline-flex h-5 min-w-[1.4rem] shrink-0 items-center justify-center rounded bg-muted px-1 text-[11px] font-semibold tabular-nums text-muted-foreground" title="Plaats in het klassement">{e.position}</span>
          )}
        </div>
        <div class="font-display text-3xl font-extrabold leading-none tabular-nums text-gold">{e.sum}</div>
        <div class="text-xs text-muted-foreground">punten over {windowSize} wedstrijden</div>
        <div class="mt-0.5 flex items-center gap-1.5">
          {e.window.map((m) => <span class:list={['size-2.5 rounded-full', m.cls]} title={`${m.label}: ${m.pts}`}></span>)}
        </div>
      </div>
    ))}
  </div>
  {multi && (
    <div class="mt-3 text-center text-xs font-medium text-muted-foreground">
      <span data-bf-counter>1</span> / {entries.length}
    </div>
  )}
</div>

{multi && (
  <script>
    document.querySelectorAll('[data-bestform]').forEach((card) => {
      const slides = [...card.querySelectorAll('[data-bf-slide]')];
      const counter = card.querySelector('[data-bf-counter]');
      if (slides.length < 2) return;
      let cur = 0;
      const go = (next: number) => {
        slides[cur].classList.add('hidden');
        cur = (next + slides.length) % slides.length;
        slides[cur].classList.remove('hidden');
        if (counter) counter.textContent = String(cur + 1);
      };
      card.querySelector('[data-bf-prev]')?.addEventListener('click', () => go(cur - 1));
      card.querySelector('[data-bf-next]')?.addEventListener('click', () => go(cur + 1));
    });
  </script>
)}
