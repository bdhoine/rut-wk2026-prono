---
// Renders a score as two boxed numbers: [home] – [away].
// When either value is missing, shows an empty dash (never 0).
interface Props {
  home?: number | null;
  away?: number | null;
  size?: 'sm' | 'md' | 'lg';
  muted?: boolean;
}
const { home, away, size = 'md', muted = false } = Astro.props;
const has = home !== null && home !== undefined && away !== null && away !== undefined;
const sizes = {
  sm: 'h-6 min-w-6 text-xs',
  md: 'h-8 min-w-8 text-base',
  lg: 'h-12 min-w-12 text-2xl',
};
const box = `inline-flex items-center justify-center rounded-md border px-1.5 font-bold tabular-nums ${sizes[size]} ${muted ? 'border-transparent bg-muted/70 text-muted-foreground' : 'bg-muted'}`;
---
{has ? (
  <span class="inline-flex items-center gap-1.5">
    <span class={box}>{home}</span>
    <span class="text-muted-foreground">–</span>
    <span class={box}>{away}</span>
  </span>
) : (
  <span class="text-sm text-muted-foreground">–</span>
)}
