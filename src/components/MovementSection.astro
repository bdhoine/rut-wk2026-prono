---
// Stijgers & dalers + winnaars/verliezers for the most recent calendar day
// (today vs. the previous day), shown as two separate cards. All computed in
// src/lib/data.ts (latestMovements()).
import InfoToggle from './InfoToggle.astro';
import SectionHeading from './SectionHeading.astro';
import { latestMovements, type MovementRow } from '@/lib/data';
import { formatDayKey } from '@/lib/format';

const m = latestMovements();
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const periode = m ? `${cap(formatDayKey(m.day))} t.o.v. ${formatDayKey(m.prevDay)}` : '';

type Tone = 'up' | 'down';
// Green/red badge with the triangle + the relative number of positions moved.
function badge(r: MovementRow, tone: Tone): { text: string; cls: string } {
  const n = Math.abs(r.delta);
  return tone === 'up'
    ? { text: `▲ ${n}`, cls: 'bg-emerald-500/15 text-emerald-700 dark:text-emerald-400' }
    : { text: `▼ ${n}`, cls: 'bg-red-500/15 text-red-700 dark:text-red-400' };
}
---
{m === null ? (
  <section>
    <SectionHeading title="Stijgers & dalers">
      <InfoToggle text="Per kalenderdag: wie het meest steeg of daalde t.o.v. de vorige speeldag." />
    </SectionHeading>
    <p class="rounded-xl border bg-card px-4 py-6 text-center text-sm text-muted-foreground">
      Nog niet genoeg gespeeld om stijgers en dalers te tonen — dit verschijnt vanaf de tweede speeldag.
    </p>
  </section>
) : (
  <div class="space-y-6">
    <section>
      <SectionHeading title="Stijgers & dalers">
        <InfoToggle text="De sterkste stijgers en dalers in de stand t.o.v. de vorige speeldag (minstens 3 namen), met de positiewijziging (oude → nieuwe plaats)." />
      </SectionHeading>
      <div class="rounded-xl border bg-card p-3 shadow-sm sm:p-4">
        <p class="mb-3 text-xs font-medium text-muted-foreground">{periode}</p>
        <div class="grid gap-3 sm:grid-cols-2">
          {[
            { title: 'Sterkste stijgers', rows: m.risers, tone: 'up' as Tone, empty: 'Niemand gestegen.' },
            { title: 'Sterkste dalers', rows: m.fallers, tone: 'down' as Tone, empty: 'Niemand gedaald.' },
          ].map((col) => (
            <div>
              <div class="mb-1 flex items-center gap-1.5 px-2 text-xs font-semibold text-muted-foreground">
                <span aria-hidden="true" class={col.tone === 'up' ? 'text-emerald-600' : 'text-red-600'}>{col.tone === 'up' ? '▲' : '▼'}</span>
                {col.title}
              </div>
              {col.rows.length === 0 ? (
                <p class="px-2 py-1.5 text-sm text-muted-foreground">{col.empty}</p>
              ) : (
                <ul class="space-y-0.5">
                  {col.rows.map((r) => {
                    const b = badge(r, col.tone);
                    return (
                      <li>
                        <a href={`/deelnemer/${r.participantId}`} class="flex items-center gap-2 rounded-md px-2 py-1.5 hover:bg-muted">
                          <span class:list={['inline-flex min-w-[2.75rem] shrink-0 items-center justify-start rounded px-1.5 py-0.5 text-xs font-bold tabular-nums', b.cls]}>{b.text}</span>
                          <span class="min-w-0 flex-1 truncate text-sm font-medium">{r.name}</span>
                          <span class="shrink-0 text-xs tabular-nums text-muted-foreground">{r.prev}<span aria-hidden="true">→</span>{r.cur}</span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section>
      <SectionHeading title="Top 5 — winnaars & verliezers">
        <InfoToggle text="Wie sinds de vorige speeldag in de top 5 (de prijsplaatsen) is gekomen, en wie eruit is gevallen." />
      </SectionHeading>
      <div class="rounded-xl border bg-card p-3 shadow-sm sm:p-4">
        <p class="mb-3 text-xs font-medium text-muted-foreground">{periode}</p>
        <div class="grid gap-3 sm:grid-cols-2">
          {[
            { title: 'In de top 5', rows: m.winners, tone: 'up' as Tone, empty: 'Niemand nieuw in de top 5.' },
            { title: 'Uit de top 5', rows: m.losers, tone: 'down' as Tone, empty: 'Niemand uit de top 5.' },
          ].map((col) => (
            <div>
              <div class="mb-1 flex items-center gap-1.5 px-2 text-xs font-semibold text-muted-foreground">
                <span aria-hidden="true" class={col.tone === 'up' ? 'text-emerald-600' : 'text-red-600'}>{col.tone === 'up' ? '▲' : '▼'}</span>
                {col.title}
              </div>
              {col.rows.length === 0 ? (
                <p class="px-2 py-1.5 text-sm text-muted-foreground">{col.empty}</p>
              ) : (
                <ul class="space-y-0.5">
                  {col.rows.map((r) => {
                    const b = badge(r, col.tone);
                    return (
                      <li>
                        <a href={`/deelnemer/${r.participantId}`} class="flex items-center gap-2 rounded-md px-2 py-1.5 hover:bg-muted">
                          <span class:list={['inline-flex min-w-[2.75rem] shrink-0 items-center justify-start rounded px-1.5 py-0.5 text-xs font-bold tabular-nums', b.cls]}>{b.text}</span>
                          <span class="min-w-0 flex-1 truncate text-sm font-medium">{r.name}</span>
                          <span class="shrink-0 text-xs tabular-nums text-muted-foreground">{r.prev}<span aria-hidden="true">→</span>{r.cur}</span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
)}
