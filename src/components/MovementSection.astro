---
// Stijgers & dalers + winnaars/verliezers for the most recent calendar day
// (today vs. the previous day), shown as two separate cards. All computed in
// src/lib/data.ts (latestMovements()).
import InfoToggle from './InfoToggle.astro';
import SectionHeading from './SectionHeading.astro';
import MovementCard, { type MovementCol } from './MovementCard.astro';
import { latestMovements } from '@/lib/data';
import { formatDayKey } from '@/lib/format';

const m = latestMovements();
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const periode = m ? `${cap(formatDayKey(m.day))} t.o.v. ${formatDayKey(m.prevDay)}` : '';

const moversCols: MovementCol[] = m ? [
  { title: 'Sterkste stijgers', rows: m.risers, tone: 'up', empty: 'Niemand gestegen.' },
  { title: 'Sterkste dalers', rows: m.fallers, tone: 'down', empty: 'Niemand gedaald.' },
] : [];
const top5Cols: MovementCol[] = m ? [
  { title: 'In de top 5', rows: m.winners, tone: 'up', empty: 'Niemand nieuw in de top 5.' },
  { title: 'Uit de top 5', rows: m.losers, tone: 'down', empty: 'Niemand uit de top 5.' },
] : [];
---
{m === null ? (
  <section>
    <SectionHeading title="Stijgers & dalers">
      <InfoToggle text="Per kalenderdag: wie het meest steeg of daalde t.o.v. de vorige speeldag." />
    </SectionHeading>
    <p class="rounded-xl border bg-card px-4 py-6 text-center text-sm text-muted-foreground">
      Nog niet genoeg gespeeld om stijgers en dalers te tonen — dit verschijnt vanaf de tweede speeldag.
    </p>
  </section>
) : (
  <div class="space-y-6">
    <section>
      <SectionHeading title="Stijgers & dalers">
        <InfoToggle text="De sterkste stijgers en dalers in de stand t.o.v. de vorige speeldag (minstens 3 namen), met de positiewijziging (oude → nieuwe plaats)." />
      </SectionHeading>
      <MovementCard periode={periode} cols={moversCols} />
    </section>

    <section>
      <SectionHeading title="Top 5 — winnaars & verliezers">
        <InfoToggle text="Wie sinds de vorige speeldag in de top 5 (de prijsplaatsen) is gekomen, en wie eruit is gevallen." />
      </SectionHeading>
      <MovementCard periode={periode} cols={top5Cols} />
    </section>
  </div>
)}
