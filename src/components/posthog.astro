---
// PostHog analytics snippet for client-side tracking.
// Uses is:inline to prevent Astro from processing the script.
//
// Page-level metadata for the analytics dashboards:
//  - `pageName` is registered as a super property, so every event captured on
//    the page (pageview, autocapture, the custom *_viewed events) carries it.
//    It's safe to register because every page sets one, so it never goes stale.
//  - `pageProps` (e.g. a participant's username or a match's duel) is attached
//    to the $pageview event only — page-specific values must NOT be registered
//    or they'd leak onto later pages that don't have them.
// We disable the automatic pageview and fire it ourselves so these props are
// guaranteed to land on the initial pageview.
interface Props {
  pageName?: string;
  pageProps?: Record<string, string | number | null>;
}
const { pageName, pageProps = {} } = Astro.props;

// Analytics run on the PRODUCTION deploy only. Netlify exposes the deploy
// context in the `CONTEXT` build var ('production' | 'deploy-preview' |
// 'branch-deploy' | 'dev'); preview/branch deploys and local dev therefore
// never load PostHog. `PUBLIC_POSTHOG_FORCE=true` is an escape hatch to enable
// it locally while testing. When disabled we pass an empty token, so `init`
// stays a harmless no-op (same as when the keys are unset).
const enabled = process.env.CONTEXT === 'production' || import.meta.env.PUBLIC_POSTHOG_FORCE === 'true';
const apiKey = enabled ? (import.meta.env.PUBLIC_POSTHOG_PROJECT_TOKEN ?? '') : '';
const apiHost = enabled ? (import.meta.env.PUBLIC_POSTHOG_HOST ?? '') : '';
---
<script is:inline define:vars={{ apiKey, apiHost, pageName, pageProps }}>
  !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="capture identify alias people.set people.set_once set_config register register_once unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled onFeatureFlags getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures getActiveMatchingSurveys getSurveys getNextSurveyStep onSessionId".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
  posthog.init(apiKey || '', {
    api_host: apiHost || '',
    defaults: '2026-01-30',
    capture_pageview: false
  });
  if (pageName) posthog.register({ page_name: pageName });
  posthog.capture('$pageview', pageProps || {});
</script>
