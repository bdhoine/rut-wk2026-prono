---
// Live-scores control bar + client script. The toggle fetches the live function
// and then auto-refreshes every minute while on (the function caches 60s).
//
// Two modes:
//  - mode="overlay" (default): overlay the live score onto MatchCards already on
//    the page, matched by team iso pair (used on /programma and /kalender).
//  - mode="list": render in-progress matches as their own cards (used on the
//    home/klassement page, which has no match cards). In this mode the most
//    recently finished matches show automatically without the toggle (no API
//    call needed) — the toggle only adds live matches, which always render on
//    top. The section holds at most 3 cards: every live match, then the newest
//    finished ones to fill up, with the last 2 finished always included.
import { teams, matches, predictions, settings, getTeam } from '@/lib/data';
import { byKickoff } from '@/lib/format';

interface Props {
  mode?: 'overlay' | 'list';
  // List mode only: also show the most recently finished matches. When false,
  // only live matches appear (used on /klassement, which is live-only).
  showRecent?: boolean;
  // Overlay mode only: embed the scoring payload so rut:live-ranking events are
  // dispatched (needed on pages that show per-participant live point deltas, such
  // as deelnemer/[id]).
  ranking?: boolean;
}
const { mode = 'overlay', showRecent = true, ranking = false } = Astro.props;
const withScoring = mode === 'list' || ranking;
const teamMap = Object.fromEntries(teams.map((t) => [t.id, { name: t.name, iso: t.iso }]));

// Most recently finished matches for the home page (newest first; a few spare
// beyond the 3-card cap in case some are dropped as currently-live duplicates).
// Only meaningful in list mode with recent enabled.
const recent =
  mode === 'list' && showRecent
    ? matches
        .filter((m) => m.status === 'finished' && m.result && m.homeTeamId && m.awayTeamId)
        .sort((a, b) => byKickoff(b, a))
        .slice(0, 8)
        .map((m) => ({
          id: m.id,
          homeTeamId: m.homeTeamId,
          awayTeamId: m.awayTeamId,
          home: getTeam(m.homeTeamId)?.name ?? '',
          away: getTeam(m.awayTeamId)?.name ?? '',
          goalsHome: m.result!.home,
          goalsAway: m.result!.away,
          pens: m.penalties ?? null,
          goals: m.goals ?? null,
          kickoff: m.kickoff,
        }))
    : [];

// Data to recompute provisional ranking points client-side from live scores
// (list mode / home only). Covers matches not yet finished — finished matches
// already fold into the static ranking. Maps team iso pair -> predictions.
const liveMatches = matches.filter((m) => m.status !== 'finished' && m.homeTeamId && m.awayTeamId);
const liveMatchIds = new Set(liveMatches.map((m) => m.id));
const predsByMatch: Record<string, Record<string, [number, number]>> = {};
if (withScoring) {
  for (const p of predictions) {
    if (!liveMatchIds.has(p.matchId) || p.late) continue;
    (predsByMatch[p.matchId] ??= {})[p.participantId] = [p.home, p.away];
  }
}
const scoringPayload = withScoring
  ? {
      multipliers: settings.multipliers,
      matches: liveMatches.map((m) => ({ id: m.id, h: m.homeTeamId, a: m.awayTeamId, round: m.round })),
      preds: predsByMatch,
    }
  : null;

// Kickoff times of not-yet-finished matches, so the client can auto-enable live
// while a match is in progress and auto-disable once it's over (window-based,
// no API call needed for the decision). Each kickoff carries its venue offset.
const kickoffWindows = matches.filter((m) => m.status !== 'finished').map((m) => m.kickoff);

// The next planned match (earliest not-yet-finished, both teams known) — used
// only by the ?ff-simulate-live=H-A dev/QA flag to fake a live score without a
// real live match. Embedded in every mode.
const nextPlanned = matches
  .filter((m) => m.status !== 'finished' && m.homeTeamId && m.awayTeamId)
  .sort(byKickoff)[0];
const nextMatch = nextPlanned
  ? {
      id: nextPlanned.id,
      homeTeamId: nextPlanned.homeTeamId,
      awayTeamId: nextPlanned.awayTeamId,
      home: getTeam(nextPlanned.homeTeamId)?.name ?? '',
      away: getTeam(nextPlanned.awayTeamId)?.name ?? '',
      kickoff: nextPlanned.kickoff,
    }
  : null;
---
<div data-live-root data-live-mode={mode}>
  <div class="mb-4 flex flex-wrap items-center gap-2">
    <button
      id="live-toggle"
      type="button"
      aria-pressed="false"
      class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm font-medium transition-colors hover:bg-muted"
    >
      <span id="live-dot" class="size-2 rounded-full bg-muted-foreground/50"></span>
      <span id="live-label">Live scores</span>
    </button>
    <span id="live-status" class="text-xs text-muted-foreground" aria-live="polite"></span>
  </div>

  {mode === 'list' && (
    <div id="live-list" class="mb-6 hidden space-y-3" aria-live="polite">
      <h2 class="flex items-center gap-2 text-lg font-semibold"><span class="bar-cut" aria-hidden="true"></span>{showRecent ? 'Nu live & recent gespeeld' : 'Nu live'}</h2>
      <div id="live-list-cards" class="space-y-3"></div>
      <div id="recent-list-cards" class="space-y-3"></div>
    </div>
  )}

  <script type="application/json" id="live-teams" set:html={JSON.stringify(teamMap)}></script>
  <script type="application/json" id="live-windows" set:html={JSON.stringify(kickoffWindows)}></script>
  <script type="application/json" id="live-next-match" set:html={JSON.stringify(nextMatch)}></script>
  {mode === 'list' && <script type="application/json" id="live-recent" set:html={JSON.stringify(recent)}></script>}
  {withScoring && <script type="application/json" id="live-scoring" set:html={JSON.stringify(scoringPayload)}></script>}
</div>

<script>
  import { scorerLine } from '@/lib/scorers';

  const root = document.querySelector('[data-live-root]') as HTMLElement | null;
  if (root) {
    const mode = root.dataset.liveMode || 'overlay';
    const LIVE_KEY = 'rut-wk2026-live'; // persists the toggle across page navigation
    const toggle = document.getElementById('live-toggle')!;
    const dot = document.getElementById('live-dot')!;
    const label = document.getElementById('live-label')!;
    const status = document.getElementById('live-status')!;
    const listWrap = document.getElementById('live-list');
    const liveCards = document.getElementById('live-list-cards');
    const recentCards = document.getElementById('recent-list-cards');
    const teamMap = JSON.parse(document.getElementById('live-teams')?.textContent || '{}');
    const recentData = JSON.parse(document.getElementById('live-recent')?.textContent || '[]');
    const scoring = JSON.parse(document.getElementById('live-scoring')?.textContent || 'null');
    const kickoffWindows: number[] = (JSON.parse(document.getElementById('live-windows')?.textContent || '[]') as string[])
      .map((iso) => new Date(iso).getTime())
      .filter((t) => Number.isFinite(t));
    const scoringByPair = new Map<string, any>();
    if (scoring) for (const m of scoring.matches) { scoringByPair.set(`${m.h}|${m.a}`, m); scoringByPair.set(`${m.a}|${m.h}`, m); }

    // Dev/QA feature flag: ?ff-simulate-live=1-0 fakes a live score for the next
    // planned match so the live overlay can be exercised without a real live
    // match. It auto-enables live, bypasses the API fetch entirely, and never
    // nudges a results refresh. Works on any page that renders <LiveScores />.
    const nextMatch = JSON.parse(document.getElementById('live-next-match')?.textContent || 'null');
    const simMatch = (() => {
      const raw = new URLSearchParams(location.search).get('ff-simulate-live');
      if (raw == null || !nextMatch) return null;
      const m = raw.match(/^\s*(\d{1,2})\s*[-–:]\s*(\d{1,2})\s*$/);
      if (!m) return null;
      // Fabricate one scorer per simulated goal so the live scorer line can be QA'd.
      const fake = (n: number, teamId: string) =>
        Array.from({ length: n }, (_, i) => ({ player: 'Testspeler', teamId, minute: `${12 + i * 17}'` }));
      const goalsHome = Number(m[1]);
      const goalsAway = Number(m[2]);
      return {
        ...nextMatch,
        goalsHome,
        goalsAway,
        elapsed: 1,
        status: 'in',
        simulated: true,
        scorers: [...fake(goalsHome, nextMatch.homeTeamId), ...fake(goalsAway, nextMatch.awayTeamId)],
      };
    })();

    // Goal-scorer foot line (mirrors MatchScorers.astro's card layout): home
    // scorers right-aligned, ball divider, away scorers left-aligned. `hero`
    // switches to the light-on-dark tones of the match-detail hero panel.
    const esc = (s: string) => s.replace(/[&<>"']/g, (c) => `&#${c.charCodeAt(0)};`);
    const scorersFoot = (goals: any[] | null | undefined, homeId: string, awayId: string, hero = false) => {
      const h = scorerLine(goals ?? [], homeId);
      const a = scorerLine(goals ?? [], awayId);
      if (!h && !a) return '';
      const tone = hero ? 'text-ink-foreground/80' : 'text-muted-foreground';
      const ball = hero ? 'text-ink-foreground/50' : 'text-muted-foreground/60';
      return `<div class="live-scorers mt-2 flex items-start justify-center gap-2 text-[11px] leading-4 ${tone}"><span class="min-w-0 flex-1 text-right">${esc(h)}</span><span class="shrink-0 ${ball}" aria-hidden="true">⚽</span><span class="min-w-0 flex-1 text-left">${esc(a)}</span></div>`;
    };

    // Provisional ranking points from a live score (mirrors src/lib/scoring.ts).
    const basePts = (ph: number, pa: number, rh: number, ra: number) => {
      if (ph === rh && pa === ra) return 9;
      if (Math.sign(ph - pa) !== Math.sign(rh - ra)) return 0;
      return Math.max(3, 7 - (Math.abs(ph - rh) + Math.abs(pa - ra)));
    };

    function dispatchRanking(list: any[]) {
      if (!scoring) return;
      const deltas: Record<string, number> = {};
      for (const lm of list) {
        const m = scoringByPair.get(`${lm.homeTeamId}|${lm.awayTeamId}`);
        if (!m) continue;
        const swapped = m.h !== lm.homeTeamId; // align live goals to our home/away
        const rh = swapped ? lm.goalsAway : lm.goalsHome;
        const ra = swapped ? lm.goalsHome : lm.goalsAway;
        const mult = scoring.multipliers[m.round] ?? 1;
        const preds = scoring.preds[m.id] || {};
        for (const pid of Object.keys(preds)) {
          const [ph, pa] = preds[pid];
          deltas[pid] = (deltas[pid] || 0) + basePts(ph, pa, rh, ra) * mult;
        }
      }
      (window as any).__rutLiveDeltas = deltas;
      window.dispatchEvent(new CustomEvent('rut:live-ranking', { detail: { deltas } }));
    }

    // Broadcast the raw live matches so other pages (e.g. the match-detail page)
    // can react — the match page uses it to show provisional points per person.
    const dispatchLiveMatches = (list: any[]) => {
      (window as any).__rutLiveMatches = list;
      window.dispatchEvent(new CustomEvent('rut:live-matches', { detail: { matches: list } }));
    };

    const MAX_CARDS = 3; // live + recent combined
    const MIN_RECENT = 2; // the last two finished matches always show
    const POLL_MS = 60 * 1000; // auto-refresh cadence while live is on (matches the function's 60s cache)

    let enabled = false;
    let loading = false;
    let timer: ReturnType<typeof setInterval> | null = null;
    const touched = new Set<HTMLElement>();
    let liveKeys = new Set<string>();
    let prevLiveKeys = new Set<string>(); // live matches seen on the previous poll, to detect a match ending

    const fmtTime = (iso: string) => {
      try {
        return new Intl.DateTimeFormat('nl-BE', { hour: '2-digit', minute: '2-digit', timeZone: 'Europe/Brussels' }).format(new Date(iso));
      } catch { return ''; }
    };
    const fmtDateTime = (iso: string) => {
      try {
        return new Intl.DateTimeFormat('nl-BE', { weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit', timeZone: 'Europe/Brussels' }).format(new Date(iso));
      } catch { return ''; }
    };
    const key = (h: string, a: string) => `${h}|${a}`;

    // Nudge the results workflow to refresh the committed klassement sooner —
    // called only when a live match just ended (see load()). The function
    // applies the real guards (skips when a run is active or <5 min old); this
    // short debounce only coalesces the same transition across reloads/tabs.
    const TRIGGER_KEY = 'rut-wk2026-update-trigger';
    const triggerUpdate = async () => {
      try {
        const last = Number(sessionStorage.getItem(TRIGGER_KEY) || 0);
        if (Date.now() - last < 90 * 1000) return;
        sessionStorage.setItem(TRIGGER_KEY, String(Date.now()));
      } catch { /* ignore */ }
      try { await fetch('/.netlify/functions/trigger-update', { method: 'POST' }); } catch { /* ignore */ }
    };
    const minLabel = (m: any) => (m.simulated ? 'sim' : m.status === 'HT' ? 'rust' : m.elapsed != null ? `${m.elapsed}'` : 'live');
    const teamName = (id: string, fallback: string) => teamMap[id]?.name || fallback || id;
    const flag = (id: string, name: string) => `<span class="fi fi-${teamMap[id]?.iso || id} shrink-0 rounded-[2px] text-lg" role="img" aria-label="${name}"></span>`;
    const livePill = (gh: number, ga: number) =>
      `<span class="inline-flex items-center rounded-md bg-red-100 px-2 py-0.5 text-base font-bold tabular-nums text-red-800">${gh}<span class="px-1 text-red-400">–</span>${ga}</span>`;
    const finalPill = (gh: number, ga: number) =>
      `<span class="inline-flex items-center rounded-md bg-ink px-2 py-0.5 text-base font-bold tabular-nums text-ink-foreground shadow-sm">${gh}<span class="px-1 text-gold">–</span>${ga}</span>`;
    // Penalty score shown beneath the main score when decided on penalties.
    const penSub = (pens?: { home: number; away: number } | null) =>
      pens ? `<span class="text-[11px] font-semibold leading-none tabular-nums text-muted-foreground" title="na strafschoppen">${pens.home} – ${pens.away}</span>` : '';
    const liveBadge = (m: any) =>
      `<span class="live-badge inline-flex items-center gap-1 rounded-full bg-red-600 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-white"><span class="size-1.5 animate-pulse rounded-full bg-white"></span>${minLabel(m)}</span>`;

    function card(homeId: string, awayId: string, hName: string, aName: string, meta: string, scoreHtml: string, href?: string, sub?: string, foot?: string) {
      const el = document.createElement(href ? 'a' : 'div') as HTMLElement;
      if (href) (el as HTMLAnchorElement).href = href;
      el.className = href
        ? 'block rounded-xl border bg-card px-4 py-3 shadow-sm transition-all hover:border-primary/40 hover:shadow-md'
        : 'rounded-xl border bg-card px-4 py-3 shadow-sm';
      el.dataset.key = key(homeId, awayId);
      // Top-align so the team names stay on the score line even when the score
      // cell carries a second line (e.g. the penalty caption beneath it).
      el.innerHTML = `
        <div class="mb-2 flex items-center justify-center gap-2 text-center text-xs font-medium text-muted-foreground">${meta}</div>
        <div class="flex items-start justify-center gap-3">
          <div class="flex min-w-0 flex-1 items-center justify-end gap-2"><span class="truncate text-right font-medium">${hName}</span>${flag(homeId, hName)}</div>
          <div class="flex shrink-0 flex-col items-center gap-0.5">${scoreHtml}${sub || ''}</div>
          <div class="flex min-w-0 flex-1 items-center gap-2">${flag(awayId, aName)}<span class="truncate font-medium">${aName}</span></div>
        </div>${foot || ''}`;
      return el;
    }

    function renderRecent() {
      if (!recentCards) return;
      recentCards.innerHTML = '';
      // Fill the section up to MAX_CARDS after the live cards, but never show
      // fewer than the last MIN_RECENT finished matches. recentData is newest
      // first; matches currently shown as live are skipped.
      const slots = Math.max(MIN_RECENT, MAX_CARDS - liveKeys.size);
      const items = recentData
        .filter((m: any) => !liveKeys.has(key(m.homeTeamId, m.awayTeamId)))
        .slice(0, slots);
      for (const m of items) {
        recentCards.appendChild(
          card(m.homeTeamId, m.awayTeamId, teamName(m.homeTeamId, m.home), teamName(m.awayTeamId, m.away),
            `<span>${fmtDateTime(m.kickoff)}</span>`, finalPill(m.goalsHome, m.goalsAway),
            m.id ? `/wedstrijd/${m.id}` : undefined, penSub(m.pens),
            scorersFoot(m.goals, m.homeTeamId, m.awayTeamId)),
        );
      }
      updateListVisibility();
    }

    function updateListVisibility() {
      if (!listWrap) return;
      const has = (liveCards?.childElementCount || 0) + (recentCards?.childElementCount || 0) > 0;
      listWrap.classList.toggle('hidden', !has);
    }

    function clearLive() {
      if (mode === 'list') {
        if (liveCards) liveCards.innerHTML = '';
        liveKeys = new Set();
        renderRecent();
      } else {
        for (const c of touched) {
          const score = c.querySelector('.match-score');
          if (score && c.dataset.origScore != null) score.innerHTML = c.dataset.origScore;
          c.querySelector('.live-badge')?.remove();
          c.classList.remove('live-pad', 'live-hero');
        }
        touched.clear();
        document.querySelectorAll('.live-standing').forEach((el) => el.remove());
        document.querySelectorAll('.live-scorers').forEach((el) => el.remove());
      }
    }

    // Pulsing red dot + current score next to a team in a standings table
    // (poules page rows carry data-standing-team). Returns true if any row hit.
    function decorateStandings(m: any) {
      // On /poules, LivePoules fully recomputes + re-renders the tables (with its
      // own live badges), so skip the simple per-row score overlay there — but
      // still return whether a row exists so the "N live" counter stays right.
      const ownedByLivePoules = !!document.querySelector('[data-live-poules]');
      let any = false;
      const sides: [string, number, number][] = [
        [m.homeTeamId, m.goalsHome, m.goalsAway],
        [m.awayTeamId, m.goalsAway, m.goalsHome],
      ];
      for (const [id, gf, ga] of sides) {
        for (const el of document.querySelectorAll(`[data-standing-team="${id}"]`)) {
          any = true;
          if (ownedByLivePoules || el.querySelector('.live-standing')) continue;
          el.insertAdjacentHTML(
            'beforeend',
            `<span class="live-standing inline-flex shrink-0 items-center gap-1 text-xs font-semibold tabular-nums text-red-600 dark:text-red-400" title="live"><span class="size-1.5 animate-pulse rounded-full bg-red-600"></span>${gf}–${ga}</span>`,
          );
        }
      }
      return any;
    }

    function findCard(homeId: string, awayId: string) {
      const sel = (h: string, a: string) => document.querySelector<HTMLElement>(`[data-match-card][data-home-team="${h}"][data-away-team="${a}"]`);
      const direct = sel(homeId, awayId);
      if (direct) return { card: direct, swapped: false };
      const swapped = sel(awayId, homeId);
      if (swapped) return { card: swapped, swapped: true };
      return null;
    }

    function applyMatches(list: any[]) {
      clearLive();
      let shown = 0;
      if (mode === 'list') {
        liveKeys = new Set(list.map((m) => key(m.homeTeamId, m.awayTeamId)));
        if (liveCards) {
          for (const m of list) {
            const mid = scoringByPair.get(key(m.homeTeamId, m.awayTeamId))?.id;
            liveCards.appendChild(
              card(m.homeTeamId, m.awayTeamId, teamName(m.homeTeamId, m.home), teamName(m.awayTeamId, m.away),
                liveBadge(m), livePill(m.goalsHome, m.goalsAway), mid ? `/wedstrijd/${mid}` : undefined, undefined,
                scorersFoot(m.scorers, m.homeTeamId, m.awayTeamId)),
            );
            shown++;
          }
        }
        renderRecent();
        return shown;
      }
      for (const m of list) {
        if (decorateStandings(m)) shown++;
        const hit = findCard(m.homeTeamId, m.awayTeamId);
        if (!hit) continue;
        const { card: c, swapped } = hit;
        const gh = swapped ? m.goalsAway : m.goalsHome;
        const ga = swapped ? m.goalsHome : m.goalsAway;
        const score = c.querySelector('.match-score');
        // Where does the live badge go?
        //  - compact cards (kalender/programma): stacked above the pill in normal
        //    flow so the card grows to contain it (rows use items-end, so the
        //    pill lines up with the team names/flags).
        //  - match-detail hero (data-live-stack): badge absolutely positioned
        //    above the pill — the roomy hero contains it and the pill stays on
        //    the flag line.
        //  - otherwise: badge inserted into the card's meta line.
        const compact = !!c.querySelector('.match-meta-inline');
        const heroStack = !compact && c.hasAttribute('data-live-stack');
        const stack = compact || heroStack;
        if (score) {
          if (c.dataset.origScore == null) c.dataset.origScore = score.innerHTML;
          // Badge absolutely positioned above the pill (no added height), so the
          // pill stays on the team-name/flag line. Compact cards get a little
          // extra top padding (.live-pad) so the badge stays inside the card.
          score.innerHTML = stack
            ? `<span class="relative inline-flex items-center justify-center">${livePill(gh, ga)}<span class="absolute bottom-full left-1/2 mb-1 -translate-x-1/2 whitespace-nowrap">${liveBadge(m)}</span></span>`
            : livePill(gh, ga);
        }
        if (compact) c.classList.add('live-pad');
        if (heroStack) c.classList.add('live-hero');
        if (!stack) {
          const meta = c.querySelector('.match-meta');
          if (meta && !meta.querySelector('.live-badge')) meta.insertAdjacentHTML('afterbegin', liveBadge(m));
        }
        // Live scorer line at the card's foot, oriented to the card's sides.
        // Skipped on compact cards (kalender/programma keep their density);
        // the hero variant slots in above the venue line.
        if (!compact && m.scorers?.length && !c.querySelector('.live-scorers')) {
          const foot = scorersFoot(
            m.scorers,
            swapped ? m.awayTeamId : m.homeTeamId,
            swapped ? m.homeTeamId : m.awayTeamId,
            heroStack,
          );
          if (foot) {
            const venue = heroStack ? c.querySelector('p:last-of-type') : null;
            if (venue) venue.insertAdjacentHTML('beforebegin', foot);
            else c.insertAdjacentHTML('beforeend', foot);
          }
        }
        touched.add(c);
        shown++;
      }
      return shown;
    }

    async function load() {
      if (loading || document.hidden) return; // don't poll a hidden tab
      loading = true;
      status.textContent = 'Laden…';
      try {
        if (simMatch) {
          const list = [simMatch];
          const shown = applyMatches(list);
          dispatchRanking(list);
          dispatchLiveMatches(list);
          status.textContent = `⚠ Simulatie • ${shown} live (${simMatch.goalsHome}–${simMatch.goalsAway})`;
          return;
        }
        const res = await fetch('/.netlify/functions/live', { headers: { accept: 'application/json' } });
        if (res.status === 404) { status.textContent = 'Live werkt enkel op de gepubliceerde site.'; return; }
        const data = await res.json();
        if (!data.ok) {
          clearLive();
          status.textContent = data.error === 'rate-limit' ? 'Te veel aanvragen, probeer straks opnieuw.'
            : data.error === 'no-key' ? 'Live is nog niet geconfigureerd.'
            : 'Live tijdelijk niet beschikbaar.';
          return;
        }
        const shown = applyMatches(data.matches || []);
        dispatchRanking(data.matches || []);
        dispatchLiveMatches(data.matches || []);
        // Nudge a results update only when a live match has just ended (it
        // dropped out of the live set since the last poll) — its final score is
        // now committable. We don't trigger continuously during the window.
        const nowKeys = new Set<string>((data.matches || []).map((m: any) => key(m.homeTeamId, m.awayTeamId)));
        if ([...prevLiveKeys].some((k) => !nowKeys.has(k))) triggerUpdate();
        prevLiveKeys = nowKeys;
        const stamp = data.updatedAt ? fmtTime(data.updatedAt) : '';
        status.textContent = shown > 0
          ? `${shown} live • bijgewerkt ${stamp}`
          : `Geen wedstrijden live${stamp ? ` • ${stamp}` : ''}`;
      } catch {
        status.textContent = 'Live tijdelijk niet beschikbaar.';
      } finally {
        loading = false;
      }
    }

    function setEnabled(on: boolean, persist = true) {
      enabled = on;
      if (persist) { try { localStorage.setItem(LIVE_KEY, on ? '1' : '0'); } catch { /* ignore */ } }
      toggle.setAttribute('aria-pressed', String(on));
      dot.className = on ? 'size-2 rounded-full bg-red-600 animate-pulse' : 'size-2 rounded-full bg-muted-foreground/50';
      label.textContent = on ? 'Live aan' : 'Live scores';
      ['border-red-400/50', 'bg-red-500/15', 'text-red-700', 'dark:text-red-300'].forEach((c) => toggle.classList.toggle(c, on));
      if (timer) { clearInterval(timer); timer = null; }
      if (on) {
        load();
        timer = setInterval(load, POLL_MS); // auto-refresh while live
      } else {
        clearLive();
        dispatchRanking([]); // revert klassement to static totals
        dispatchLiveMatches([]);
        prevLiveKeys = new Set(); // forget the live set so re-enabling can't fake a "match ended"
        status.textContent = '';
      }
    }

    toggle.addEventListener('click', () => setEnabled(!enabled));

    // Pause polling while the tab is hidden; refresh + resume when it returns.
    document.addEventListener('visibilitychange', () => {
      if (!enabled) return;
      if (document.hidden) {
        if (timer) { clearInterval(timer); timer = null; }
      } else {
        load();
        if (!timer) timer = setInterval(load, POLL_MS);
      }
    });

    // Recently-finished matches show automatically (no API needed).
    if (mode === 'list') { renderRecent(); }

    // Auto-enable while a match is in progress and auto-disable once it's over,
    // based on kickoff windows (kickoff − 5 min … kickoff + 2.5 h). We only act
    // on a busy↔idle transition, so a manual toggle in between is respected
    // until the next match starts or ends.
    const PRE_MS = 5 * 60 * 1000;
    const PLAY_MS = 2.5 * 60 * 60 * 1000;
    const AUTO_MS = 30 * 1000; // how often to re-check the windows
    const matchBusyNow = () => {
      const now = Date.now();
      return kickoffWindows.some((k) => now >= k - PRE_MS && now <= k + PLAY_MS);
    };
    let lastBusy: boolean | null = null;
    const autoEvaluate = () => {
      const busy = matchBusyNow();
      if (busy === lastBusy) return;
      lastBusy = busy;
      setEnabled(busy, false); // auto state isn't persisted; manual clicks still are
    };
    if (simMatch) {
      setEnabled(true, false); // simulation: force live on and keep it on
    } else {
      autoEvaluate(); // set the initial state from the current time
      setInterval(autoEvaluate, AUTO_MS);
    }

  }
</script>
