---
// Build-time inline SVG line chart of a participant's klassement position over
// time. Y is inverted with rank 1 fixed at the top (always visible, never
// rescaled to the participant's own range); a higher line = a better position.
interface Props {
  points: { day: string; position: number }[];
}
const { points } = Astro.props;

const W = 320;
const H = 76;
const padL = 24;
const padR = 8;
const padT = 8;
const padB = 16;

const positions = points.map((p) => p.position);
const maxP = Math.max(2, ...positions); // bottom of the axis; >=2 so there's a span
const denom = maxP - 1;

const n = points.length;
const x = (i: number) => (n === 1 ? (padL + W - padR) / 2 : padL + (i * (W - padL - padR)) / (n - 1));
const y = (pos: number) => padT + ((pos - 1) / denom) * (H - padT - padB);

const coords = points.map((p, i) => ({ ...p, cx: x(i), cy: y(p.position) }));
const line = coords.map((c) => `${c.cx.toFixed(1)},${c.cy.toFixed(1)}`).join(' ');
const fmtDay = (d: string) => { const [, m, dd] = d.split('-'); return `${Number(dd)}/${Number(m)}`; };
const first = coords[0];
const last = coords[coords.length - 1];
const axisY = H - padB;
---
<div class="rounded-xl border bg-card px-3 py-2 shadow-sm">
  <svg viewBox={`0 0 ${W} ${H}`} class="h-auto w-full" role="img" aria-label={`Klassementsverloop: van plaats ${first.position} naar plaats ${last.position}`}>
    <!-- axes -->
    <line x1={padL} y1={padT} x2={padL} y2={axisY} class="stroke-border" stroke-width="1" />
    <line x1={padL} y1={axisY} x2={W - padR} y2={axisY} class="stroke-border" stroke-width="1" />
    <!-- y labels: 1 at top (always), worst at bottom -->
    <text x={padL - 4} y={padT + 2.5} text-anchor="end" class="fill-muted-foreground text-[6px]">1</text>
    <text x={padL - 4} y={axisY} text-anchor="end" class="fill-muted-foreground text-[6px]">{maxP}</text>
    <!-- x labels: first + last day -->
    <text x={first.cx} y={H - 3} text-anchor="middle" class="fill-muted-foreground text-[6px]">{fmtDay(first.day)}</text>
    {n > 1 && <text x={last.cx} y={H - 3} text-anchor="middle" class="fill-muted-foreground text-[6px]">{fmtDay(last.day)}</text>}
    <!-- series -->
    <polyline points={line} fill="none" stroke="#dca21f" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round" />
    {coords.map((c, i) => (
      <circle cx={c.cx} cy={c.cy} r={i === coords.length - 1 ? 3 : 2} fill="#dca21f" />
    ))}
    <text x={last.cx} y={last.cy - 5} text-anchor="middle" class="fill-foreground text-[7px] font-bold">{last.position}e</text>
  </svg>
</div>
