---
// A small "i" button that toggles a short info paragraph, for use next to a
// heading. Place inside a `flex flex-wrap items-center gap-2` row with the
// heading; the paragraph (basis-full) wraps onto its own line below when shown.
interface Props {
  text: string;
}
const { text } = Astro.props;
---
<button
  type="button"
  class="info-toggle grid size-6 shrink-0 place-items-center rounded-full border text-muted-foreground transition-colors hover:bg-muted hover:text-foreground aria-[expanded=true]:border-primary/40 aria-[expanded=true]:bg-secondary aria-[expanded=true]:text-foreground"
  aria-label="Meer info"
  aria-expanded="false"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5"><circle cx="12" cy="12" r="10" /><line x1="12" y1="11" x2="12" y2="16" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
</button>
<p class="info-text mt-1 hidden basis-full text-sm text-muted-foreground" set:html={text}></p>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement)?.closest('.info-toggle');
    if (!btn) return;
    const tip = btn.nextElementSibling;
    if (!tip?.classList.contains('info-text')) return;
    const nowHidden = tip.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!nowHidden));
  });
</script>
