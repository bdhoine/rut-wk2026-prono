---
import '@/styles/global.css';
import 'flag-icons/css/flag-icons.min.css';

interface Props {
  title?: string;
}
const { title = 'Rut Prono WK 2026' } = Astro.props;
const path = Astro.url.pathname;

const nav = [
  { href: '/', label: 'Klassement', match: (p: string) => p === '/' || p.startsWith('/deelnemer') },
  { href: '/komende', label: 'Komende', match: (p: string) => p.startsWith('/komende') },
  { href: '/kalender', label: 'Kalender', match: (p: string) => p.startsWith('/kalender') || p.startsWith('/wedstrijd') },
  { href: '/poules', label: 'Poules', match: (p: string) => p.startsWith('/poules') || p.startsWith('/land') },
  { href: '/stats', label: 'Stats', match: (p: string) => p.startsWith('/stats') },
];
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Klassement en pronostieken van de Rut Prono WK 2026." />
    <title>{title}</title>
  </head>
  <body class="min-h-screen pb-20 md:pb-0">
    <header class="sticky top-0 z-20 border-b bg-background/90 backdrop-blur">
      <div class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-4 py-3">
        <a href="/" class="flex items-center gap-2 font-bold tracking-tight">
          <span class="grid size-7 place-items-center rounded-md bg-primary text-primary-foreground text-sm">⚽</span>
          <span>Rut Prono <span class="text-primary">WK 2026</span></span>
        </a>
        <nav class="hidden gap-1 md:flex">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-md px-3 py-1.5 text-sm font-medium transition-colors',
                item.match(path) ? 'bg-secondary text-secondary-foreground' : 'text-muted-foreground hover:text-foreground',
              ]}
            >{item.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-6">
      <slot />
    </main>

    <nav class="fixed inset-x-0 bottom-0 z-20 border-t bg-background/95 backdrop-blur md:hidden">
      <div class="mx-auto grid max-w-3xl grid-cols-5">
        {nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'flex flex-col items-center gap-0.5 py-2.5 text-xs font-medium transition-colors',
              item.match(path) ? 'text-primary' : 'text-muted-foreground',
            ]}
          >{item.label}</a>
        ))}
      </div>
    </nav>
  </body>
</html>
