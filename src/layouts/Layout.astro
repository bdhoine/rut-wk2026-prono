---
import '@/styles/global.css';
import 'flag-icons/css/flag-icons.min.css';
import PostHog from '@/components/posthog.astro';

interface Props {
  title?: string;
  // Extra page-specific properties for analytics (e.g. { username } on a
  // participant page, { duel } on a match page). Attached to the PostHog
  // $pageview event.
  analytics?: Record<string, string | number | null>;
}
const { title = 'Rut Prono WK 2026', analytics = {} } = Astro.props;
const path = Astro.url.pathname;

// Human-readable page name for analytics: drop the brand suffix; the bare brand
// (home page) becomes "Home".
const pageName = title === 'Rut Prono WK 2026'
  ? 'Home'
  : title.replace(/\s*[—–-]\s*Rut Prono WK 2026$/, '');

// Top-level: Home · Klassement · Wedstrijden ▾ · Statistieken · ⋮ (Meer). The
// match-related pages live under the Wedstrijden dropdown; Reglement and
// Changelog live under the "Meer" three-dots dropdown.
const home = { href: '/', label: 'Home', active: path === '/' };
const klassement = { href: '/klassement', label: 'Klassement', active: path.startsWith('/klassement') || path.startsWith('/deelnemer') };
const wedstrijden = [
  { href: '/programma', label: 'Programma', active: path.startsWith('/programma') },
  { href: '/kalender', label: 'Kalender', active: path.startsWith('/kalender') || path.startsWith('/wedstrijd') },
  { href: '/poules', label: 'Poules', active: path.startsWith('/poules') || path.startsWith('/land') },
];
const wedstrijdenActive = wedstrijden.some((i) => i.active);
const statistieken = { href: '/statistieken', label: 'Statistieken', active: path.startsWith('/statistieken') };
const meer = [
  { href: '/reglement', label: 'Reglement', active: path.startsWith('/reglement') },
  { href: '/changelog', label: 'Changelog', active: path.startsWith('/changelog') },
];
const meerActive = meer.some((i) => i.active);

const topLinkCls = (active: boolean) => [
  'rounded-md px-2.5 py-1.5 text-sm font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold/60',
  active ? 'bg-gold text-gold-foreground' : 'text-white/65 hover:bg-white/10 hover:text-white',
];
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Klassement en pronostieken van de Rut Prono WK 2026." />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/favicon-180.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=Noto+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <PostHog pageName={pageName} pageProps={analytics} />
    <script is:inline>
      // Apply the theme before paint. Stored mode: 'light' | 'dark' | else 'auto'
      // (follows the OS).
      (() => {
        try {
          const m = localStorage.getItem('rut-theme');
          const dark = m === 'dark' || (m !== 'light' && matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.classList.toggle('dark', dark);
        } catch { /* ignore */ }
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <header class="sticky top-0 z-30 bg-ink text-ink-foreground">
      <div class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-4 py-3">
        <a href="/" class="flex shrink-0 items-center gap-2.5 font-display text-lg font-extrabold tracking-tight">
          <img src="/logo.png" alt="Café De Rut" width="36" height="36" class="size-9 shrink-0 rounded-full ring-1 ring-white/15" />
          <span class="whitespace-nowrap">Rut Prono <span class="text-gold">WK 2026</span></span>
        </a>

        <div class="flex items-center gap-1">
          <nav class="hidden items-center gap-1 md:flex">
            <a href={home.href} class:list={topLinkCls(home.active)}>{home.label}</a>
            <a href={klassement.href} class:list={topLinkCls(klassement.active)}>{klassement.label}</a>
            <div class="relative">
              <button
                type="button"
                data-dropdown
                aria-haspopup="true"
                aria-expanded="false"
                class:list={[...topLinkCls(wedstrijdenActive), 'inline-flex items-center gap-1']}
              >
                Wedstrijden
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-3.5"><path d="m6 9 6 6 6-6" /></svg>
              </button>
              <div data-dropdown-menu class="absolute right-0 top-full z-40 mt-1.5 hidden w-44 rounded-lg border bg-popover p-1 text-popover-foreground shadow-lg">
                {wedstrijden.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      'block rounded-md px-3 py-2 text-sm font-medium transition-colors',
                      item.active ? 'bg-gold text-gold-foreground' : 'hover:bg-muted',
                    ]}
                  >{item.label}</a>
                ))}
              </div>
            </div>
            <a href={statistieken.href} class:list={topLinkCls(statistieken.active)}>{statistieken.label}</a>
            <div class="relative">
              <button
                type="button"
                data-dropdown
                aria-haspopup="true"
                aria-expanded="false"
                aria-label="Meer"
                class:list={[...topLinkCls(meerActive), 'grid size-9 place-items-center !px-0']}
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5"><circle cx="12" cy="5" r="1.6" /><circle cx="12" cy="12" r="1.6" /><circle cx="12" cy="19" r="1.6" /></svg>
              </button>
              <div data-dropdown-menu class="absolute right-0 top-full z-40 mt-1.5 hidden w-44 rounded-lg border bg-popover p-1 text-popover-foreground shadow-lg">
                {meer.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      'block rounded-md px-3 py-2 text-sm font-medium transition-colors',
                      item.active ? 'bg-gold text-gold-foreground' : 'hover:bg-muted',
                    ]}
                  >{item.label}</a>
                ))}
              </div>
            </div>
          </nav>

          <button id="theme-toggle" type="button" aria-label="Thema: auto, licht of donker" title="Thema wisselen (auto / licht / donker)" class="grid size-9 place-items-center rounded-md text-white hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold/60">
            <!-- auto (contrast) -->
            <svg data-mode="auto" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-5"><circle cx="12" cy="12" r="9" /><path d="M12 3a9 9 0 0 0 0 18z" fill="currentColor" stroke="none" /></svg>
            <!-- light (sun) -->
            <svg data-mode="light" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden size-5"><circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" /></svg>
            <!-- dark (moon) -->
            <svg data-mode="dark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden size-5"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
          </button>

          <button id="menu-toggle" type="button" aria-label="Menu openen" class="-mr-1 grid size-9 place-items-center rounded-md text-white hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold/60 md:hidden">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="size-5"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
          </button>
        </div>
      </div>
      <div class="brand-stripe" aria-hidden="true"></div>
    </header>

    <div id="mobile-menu" class="hidden md:hidden">
      <div id="menu-backdrop" class="fixed inset-0 z-40 bg-black/40"></div>
      <nav class="fixed right-0 top-0 z-50 flex h-full w-72 max-w-[80vw] flex-col gap-1.5 bg-background p-4 shadow-xl">
        <div class="mb-2 flex items-center justify-between">
          <span class="text-lg font-bold tracking-tight">Menu</span>
          <button id="menu-close" type="button" aria-label="Menu sluiten" class="grid size-11 place-items-center rounded-md hover:bg-muted">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="size-6"><path d="M6 6l12 12M18 6 6 18" /></svg>
          </button>
        </div>
        <a
          href={home.href}
          class:list={[
            'flex min-h-12 items-center rounded-lg px-4 text-base font-medium transition-colors',
            home.active ? 'bg-gold text-gold-foreground' : 'text-foreground hover:bg-muted active:bg-muted',
          ]}
        >{home.label}</a>
        <a
          href={klassement.href}
          class:list={[
            'flex min-h-12 items-center rounded-lg px-4 text-base font-medium transition-colors',
            klassement.active ? 'bg-gold text-gold-foreground' : 'text-foreground hover:bg-muted active:bg-muted',
          ]}
        >{klassement.label}</a>
        {wedstrijden.map((item) => (
          <a
            href={item.href}
            class:list={[
              'flex min-h-12 items-center rounded-lg px-4 text-base font-medium transition-colors',
              item.active ? 'bg-gold text-gold-foreground' : 'text-foreground hover:bg-muted active:bg-muted',
            ]}
          >{item.label}</a>
        ))}
        <a
          href={statistieken.href}
          class:list={[
            'flex min-h-12 items-center rounded-lg px-4 text-base font-medium transition-colors',
            statistieken.active ? 'bg-gold text-gold-foreground' : 'text-foreground hover:bg-muted active:bg-muted',
          ]}
        >{statistieken.label}</a>
        {meer.map((item) => (
          <a
            href={item.href}
            class:list={[
              'flex min-h-12 items-center rounded-lg px-4 text-base font-medium transition-colors',
              item.active ? 'bg-gold text-gold-foreground' : 'text-foreground hover:bg-muted active:bg-muted',
            ]}
          >{item.label}</a>
        ))}
      </nav>
    </div>

    <main class="mx-auto w-full max-w-3xl flex-1 px-4 py-6">
      <slot />
    </main>

    <footer class="mt-10 bg-ink text-ink-foreground/70">
      <div class="brand-stripe" aria-hidden="true"></div>
      <div class="mx-auto max-w-3xl px-4 py-6 text-center text-xs">
        <p class="font-display font-semibold tracking-tight text-ink-foreground">Pronostiek <span class="text-gold">WK 2026</span> · Café De Rut, Weerde</p>
        <p class="mt-1.5">Enkel het officiële klassement in de WhatsApp-groep is geldig.</p>
        <p class="mt-2 flex flex-wrap items-center justify-center gap-x-3 gap-y-1">
          <a href="https://github.com/bdhoine/rut-wk2026-prono" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:text-gold">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.6 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z" /></svg>
            Broncode op GitHub
          </a>
          <span aria-hidden="true">·</span>
          <a href="https://github.com/bdhoine/rut-wk2026-prono/issues/new" target="_blank" rel="noopener" class="hover:text-gold">Probleem melden</a>
        </p>
      </div>
    </footer>

    <script>
      const menu = document.getElementById('mobile-menu');
      const open = () => menu?.classList.remove('hidden');
      const close = () => menu?.classList.add('hidden');
      document.getElementById('menu-toggle')?.addEventListener('click', open);
      document.getElementById('menu-close')?.addEventListener('click', close);
      document.getElementById('menu-backdrop')?.addEventListener('click', close);

      // Desktop nav dropdowns (Wedstrijden, Meer): click to toggle, only one
      // open at a time, close on outside click or Escape.
      const dropdowns = [...document.querySelectorAll<HTMLElement>('[data-dropdown]')].map((btn) => ({
        btn,
        menu: btn.parentElement?.querySelector<HTMLElement>('[data-dropdown-menu]') ?? null,
      }));
      const setDd = (d: { btn: HTMLElement; menu: HTMLElement | null }, show: boolean) => {
        d.menu?.classList.toggle('hidden', !show);
        d.btn.setAttribute('aria-expanded', String(show));
      };
      dropdowns.forEach((d) => {
        d.btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const willShow = d.menu?.classList.contains('hidden') ?? false;
          dropdowns.forEach((o) => setDd(o, o === d ? willShow : false));
        });
      });
      document.addEventListener('click', (e) => {
        dropdowns.forEach((d) => {
          if (d.menu && !d.menu.classList.contains('hidden') && !d.menu.contains(e.target as Node) && !d.btn.contains(e.target as Node)) setDd(d, false);
        });
      });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') dropdowns.forEach((d) => setDd(d, false)); });

      // Theme: cycles auto → light → dark. 'auto' follows the OS setting.
      const themeBtn = document.getElementById('theme-toggle');
      const mql = matchMedia('(prefers-color-scheme: dark)');
      const readMode = () => {
        try { const m = localStorage.getItem('rut-theme'); return m === 'light' || m === 'dark' ? m : 'auto'; } catch { return 'auto'; }
      };
      let mode = readMode();
      const applyMode = (m: string) => {
        mode = m;
        try { m === 'auto' ? localStorage.removeItem('rut-theme') : localStorage.setItem('rut-theme', m); } catch { /* ignore */ }
        document.documentElement.classList.toggle('dark', m === 'dark' || (m === 'auto' && mql.matches));
        themeBtn?.querySelectorAll('[data-mode]').forEach((el) => el.classList.toggle('hidden', el.getAttribute('data-mode') !== m));
      };
      applyMode(mode); // sync the icon on load
      themeBtn?.addEventListener('click', () => applyMode(mode === 'auto' ? 'light' : mode === 'light' ? 'dark' : 'auto'));
      mql.addEventListener('change', () => { if (mode === 'auto') applyMode('auto'); });
    </script>
  </body>
</html>
